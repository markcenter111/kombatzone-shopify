{%- comment -%}
  Section: sections/kz-collection.liquid
  Template: templates/collection.json
{%- endcomment -%}

{{ 'kz2-collection.css' | asset_url | stylesheet_tag }}

{%- paginate collection.products by section.settings.products_per_page -%}

<div class="kz-catalog">

  {%- comment -%} ── Breadcrumb ── {%- endcomment -%}
  <nav class="kz-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span aria-hidden="true">/</span>
    <span class="kz-breadcrumb__current">{{ collection.title }}</span>
  </nav>

  {%- comment -%} ── Collection Header ── {%- endcomment -%}
  <div class="kz-collection-header">
    <div class="kz-collection-header__top">
      <div>
        <h1 class="kz-collection-header__title">
          {%- assign title_words = collection.title | split: ' ' -%}
          {%- if title_words.size > 1 -%}
            {{ title_words.first }}<em>{{ title_words | slice: 1, 10 | join: ' ' }}</em>
          {%- else -%}
            {{ collection.title }}
          {%- endif -%}
        </h1>
      </div>
    </div>
  </div>

  {%- comment -%} ── Category Pills ── {%- endcomment -%}
  <div class="kz-cat-bar" role="list">

    <a href="{{ collection.url }}"
       class="kz-cat-btn{% unless current_tags %} kz-cat-btn--active{% endunless %}"
       role="listitem">
      TUTTI
    </a>

    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        {%- assign tag = block.settings.tag -%}
        {%- if collection.all_tags contains tag -%}
          {%- assign tag_url = collection.url | append: '/' | append: tag | handle -%}
          <a href="{{ tag_url }}"
             class="kz-cat-btn{% if current_tags contains tag %} kz-cat-btn--active{% endif %}"
             role="listitem"
             {{ block.shopify_attributes }}>
            {{ block.settings.label }}
          </a>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

  </div>

  {%- comment -%} Search (icona lente, a destra, apri al click) {%- endcomment -%}
  <style>
    .kz-search{max-width:1280px;margin:0 auto 10px;display:flex;justify-content:flex-end}
    .kz-search__form{display:flex;align-items:center;background:transparent;border:1px solid transparent;border-radius:9px;transition:background .2s,border-color .2s,box-shadow .2s}
    .kz-search__form.is-open{background:#141414;border-color:rgba(255,255,255,.14)}
    .kz-search__form.is-open:focus-within{border-color:#E8272A;box-shadow:0 0 0 2px rgba(232,39,42,.2)}
    .kz-search__input{width:0;opacity:0;padding:0;border:none;background:transparent;outline:none;color:#F2F0EB;font-family:inherit;font-size:14px;transition:width .25s ease,opacity .18s,padding .25s}
    .kz-search__form.is-open .kz-search__input{width:240px;opacity:1;padding:9px 6px 9px 12px}
    .kz-search__input::placeholder{color:#6a6a64}
    .kz-search__toggle{background:none;border:none;color:#b9b7b0;cursor:pointer;padding:8px 9px;display:flex;align-items:center;border-radius:9px;transition:color .15s}
    .kz-search__toggle:hover{color:#fff}
    .kz-search__form.is-open .kz-search__toggle{color:#E8272A}
    @media(max-width:600px){.kz-search__form.is-open .kz-search__input{width:150px}}
  </style>
  <div class="kz-search">
    <form class="kz-search__form" action="{{ routes.search_url }}" method="get" role="search" data-kz-search>
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" class="kz-search__input" placeholder="Cerca un prodotto..." autocomplete="off" aria-label="Cerca prodotti" data-kz-search-input tabindex="-1">
      <button type="button" class="kz-search__toggle" data-kz-search-toggle aria-label="Cerca">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3" stroke-linecap="round"/></svg>
      </button>
    </form>
  </div>
  <script>
  (function(){
    var form=document.querySelector('[data-kz-search]'); if(!form) return;
    var input=form.querySelector('[data-kz-search-input]');
    var toggle=form.querySelector('[data-kz-search-toggle]');
    var grid=document.getElementById('kz-grid');
    function apply(){
      var q=(input.value||'').trim().toLowerCase();
      if(!grid) return;
      var cards=grid.children, shown=0;
      for(var i=0;i<cards.length;i++){var c=cards[i];
        if(c.id==='kz-search-none')continue;
        if(c.classList&&c.classList.contains('kz-empty'))continue;
        var m=!q||(c.textContent||'').toLowerCase().indexOf(q)>-1;
        c.style.display=m?'':'none'; if(m)shown++;}
      var none=document.getElementById('kz-search-none');
      if(q&&shown===0){if(!none){none=document.createElement('p');none.id='kz-search-none';none.className='kz-empty';none.innerHTML='Niente in questa pagina. Premi Invio per cercare in tutto il negozio.';grid.appendChild(none);}none.style.display='';}
      else if(none){none.style.display='none';}
    }
    function openS(){form.classList.add('is-open');input.removeAttribute('tabindex');input.focus();}
    function closeS(){form.classList.remove('is-open');input.value='';input.setAttribute('tabindex','-1');apply();}
    toggle.addEventListener('click',function(){form.classList.contains('is-open')?closeS():openS();});
    input.addEventListener('input',apply);
    input.addEventListener('keydown',function(e){if(e.key==='Escape')closeS();});
    document.addEventListener('click',function(e){if(form.classList.contains('is-open')&&!form.contains(e.target)&&!input.value)closeS();});
  })();
  </script>

  {%- comment -%} ── Filter / Sort Bar ── {%- endcomment -%}
  <div class="kz-filter-bar">

    <div class="kz-filter-bar__left">
      <span class="kz-filter-bar__label">Filtri:</span>

      {%- comment -%} Filtro livello — solo se la collezione ha tag livello {%- endcomment -%}
      {%- if collection.all_tags contains 'principiante' or collection.all_tags contains 'intermedio' or collection.all_tags contains 'agonista' -%}
        <select class="kz-select"
                aria-label="Filtra per livello"
                onchange="window.location=this.value">
          <option value="{{ collection.url }}">Tutti i livelli</option>
          {%- if collection.all_tags contains 'principiante' -%}
            <option value="{{ collection.url }}/principiante"
              {%- if current_tags contains 'principiante' %} selected{%- endif %}>
              Principiante
            </option>
          {%- endif -%}
          {%- if collection.all_tags contains 'intermedio' -%}
            <option value="{{ collection.url }}/intermedio"
              {%- if current_tags contains 'intermedio' %} selected{%- endif %}>
              Intermedio
            </option>
          {%- endif -%}
          {%- if collection.all_tags contains 'agonista' -%}
            <option value="{{ collection.url }}/agonista"
              {%- if current_tags contains 'agonista' %} selected{%- endif %}>
              Agonista
            </option>
          {%- endif -%}
        </select>
      {%- endif -%}

      {%- assign vendors = section.settings.vendors | split: ',' -%}
      {%- capture kz_vendor_options -%}
        {%- for vendor in vendors -%}
          {%- assign v = vendor | strip -%}
          {%- if collection.all_tags contains v -%}
            <option value="{{ collection.url }}/{{ v | handle }}"
              {%- if current_tags contains v %} selected{%- endif %}>
              {{ v }}
            </option>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
      {%- if kz_vendor_options contains '<option' -%}
        <select class="kz-select"
                aria-label="Filtra per marca"
                onchange="window.location=this.value">
          <option value="{{ collection.url }}">Tutte le marche</option>
          {{ kz_vendor_options }}
        </select>
      {%- endif -%}

      
      {%- assign sizes = section.settings.sizes | split: ',' -%}
      {%- capture kz_size_options -%}
        {%- for size in sizes -%}
          {%- assign sz = size | strip -%}
          {%- if collection.all_tags contains sz -%}
            <option value="{{ collection.url }}/{{ sz | handle }}"
              {%- if current_tags contains sz %} selected{%- endif %}>
              {{ sz }}
            </option>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
      {%- if kz_size_options contains '<option' -%}
        <select class="kz-select"
                aria-label="Filtra per taglia"
                onchange="window.location=this.value">
          <option value="{{ collection.url }}">Tutte le taglie</option>
          {{ kz_size_options }}
        </select>
      {%- endif -%}
    </div>

    <div class="kz-filter-bar__right">
      <span class="kz-filter-bar__count">{{ paginate.items }} prodott{{ paginate.items | pluralize: 'o', 'i' }}</span>

      
      <select class="kz-select"
              aria-label="Ordina per"
              onchange="window.location=this.value">
        {%- for option in collection.sort_options -%}
          <option value="{{ collection.url }}?sort_by={{ option.value }}"
            {%- if collection.sort_by == option.value %} selected{%- endif %}>
            {%- case option.value -%}
              {%- when 'manual' -%}In evidenza
              {%- when 'relevance' -%}Più pertinenti
              {%- when 'best-selling' -%}Più venduti
              {%- when 'title-ascending' -%}Nome A–Z
              {%- when 'title-descending' -%}Nome Z–A
              {%- when 'price-ascending' -%}Prezzo: dal più basso
              {%- when 'price-descending' -%}Prezzo: dal più alto
              {%- when 'created-ascending' -%}Meno recenti
              {%- when 'created-descending' -%}Novità
              {%- else -%}{{ option.name }}
            {%- endcase -%}
          </option>
        {%- endfor -%}
      </select>
    </div>

  </div>

  {%- comment -%} ── Product Grid ── {%- endcomment -%}
  <div class="kz-product-grid kz-product-grid--{{ section.settings.grid_size }}" id="kz-grid">
    {%- for product in collection.products -%}
      {%- render 'kz2-product-card', product: product -%}
    {%- else -%}
      <p class="kz-empty">Nessun prodotto trovato in questa categoria.</p>
    {%- endfor -%}
  </div>

  {%- comment -%} ── Pagination ── {%- endcomment -%}
  {%- if paginate.pages > 1 -%}
    <nav class="kz-pagination" aria-label="Pagine prodotti">
      <div class="kz-pagination__inner">

        {%- comment -%} Freccia precedente {%- endcomment -%}
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="kz-page-btn kz-page-btn--arrow" aria-label="Pagina precedente">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
          </a>
        {%- else -%}
          <span class="kz-page-btn kz-page-btn--arrow kz-page-btn--disabled" aria-disabled="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
          </span>
        {%- endif -%}

        {%- comment -%} Indicatore pagina centrale {%- endcomment -%}
        <div class="kz-pagination__label">
          <span class="kz-pagination__current">{{ paginate.current_page }}</span>
          <span class="kz-pagination__sep">/</span>
          <span class="kz-pagination__total">{{ paginate.pages }}</span>
        </div>

        {%- comment -%} Pallini pagina {%- endcomment -%}
        <div class="kz-pagination__dots" aria-hidden="true">
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="kz-page-dot" aria-label="Pagina {{ part.title }}"></a>
            {%- else -%}
              {%- if part.title == paginate.current_page -%}
                <span class="kz-page-dot kz-page-dot--active"></span>
              {%- else -%}
                <span class="kz-page-dot kz-page-dot--gap">…</span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Freccia successiva {%- endcomment -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="kz-page-btn kz-page-btn--arrow kz-page-btn--next" aria-label="Pagina successiva">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
          </a>
        {%- else -%}
          <span class="kz-page-btn kz-page-btn--arrow kz-page-btn--next kz-page-btn--disabled" aria-disabled="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
          </span>
        {%- endif -%}

      </div>
    </nav>
  {%- endif -%}

  {%- comment -%} ── Trust Bar ── {%- endcomment -%}
  <div class="kz-trust-bar" aria-label="Garanzie">
    {%- for i in (1..4) -%}
      {%- assign show_key = 'trust_' | append: i | append: '_show' -%}
      {%- assign text_key = 'trust_' | append: i | append: '_text' -%}
      {%- assign icon_key = 'trust_' | append: i | append: '_icon' -%}
      {%- if section.settings[show_key] and section.settings[text_key] != blank -%}
        <div class="kz-trust-bar__item">
          {%- case section.settings[icon_key] -%}
            {%- when 'check' -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            {%- when 'truck' -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
            {%- when 'refresh' -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
            {%- when 'shield' -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
            {%- when 'star' -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/></svg>
            {%- when 'bolt' -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>
            {%- when 'tag' -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z"/></svg>
            {%- when 'clock' -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          {%- endcase -%}
          {{ section.settings[text_key] }}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

</div>

{%- endpaginate -%}

{%- render 'kz-product-modal' -%}
<script src="{{ 'kz-product-modal.js' | asset_url }}" defer></script>

<script>
  /* Dropdown custom: sostituisce le <select> native con menu in stile brand */
  (function () {
    var CARET = '<svg class="kz-dd-caret" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>';

    function closeAll(except) {
      document.querySelectorAll('.kz-dd.open').forEach(function (d) {
        if (d !== except) {
          d.classList.remove('open');
          var b = d.querySelector('.kz-dd-btn');
          if (b) b.setAttribute('aria-expanded', 'false');
        }
      });
    }

    document.querySelectorAll('select.kz-select').forEach(function (sel) {
      var dd = document.createElement('div');
      dd.className = 'kz-dd';
      if (sel.closest('.kz-filter-bar__right')) dd.classList.add('kz-dd--right');

      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'kz-dd-btn';
      btn.setAttribute('aria-haspopup', 'listbox');
      btn.setAttribute('aria-expanded', 'false');
      var selOpt = sel.options[sel.selectedIndex];
      btn.innerHTML = '<span class="kz-dd-label"></span>' + CARET;
      btn.querySelector('.kz-dd-label').textContent = selOpt ? selOpt.text.trim() : '';

      var panel = document.createElement('div');
      panel.className = 'kz-dd-panel';
      panel.setAttribute('role', 'listbox');
      Array.prototype.forEach.call(sel.options, function (o) {
        var it = document.createElement('button');
        it.type = 'button';
        it.className = 'kz-dd-opt' + (o.selected ? ' is-selected' : '');
        it.setAttribute('role', 'option');
        if (o.selected) it.setAttribute('aria-selected', 'true');
        it.textContent = o.text.trim();
        it.addEventListener('click', function () { window.location = o.value; });
        panel.appendChild(it);
      });

      dd.appendChild(btn);
      dd.appendChild(panel);
      sel.parentNode.insertBefore(dd, sel);
      sel.style.display = 'none';

      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        closeAll(dd);
        var open = dd.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    });

    document.addEventListener('click', function () { closeAll(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeAll(); });
  })();

  /* Reveal card allo scroll: fade-up con stagger quando entrano nel viewport */
  (function () {
    if (!('IntersectionObserver' in window)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    document.querySelectorAll('.kz-product-grid').forEach(function (grid) {
      grid.classList.add('kz-anim-ready');
      var io = new IntersectionObserver(function (entries) {
        var delay = 0;
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          entry.target.style.animationDelay = delay + 'ms';
          delay += 70;
          entry.target.classList.add('kz-in');
          io.unobserve(entry.target);
        });
      }, { rootMargin: '0px 0px -6% 0px', threshold: 0.05 });
      grid.querySelectorAll('.kz-card').forEach(function (card) { io.observe(card); });
    });
  })();
</script>

{% schema %}
{
  "name": "KombatZone Catalog v2",
  "tag": "div",
  "settings": [
    {
      "type": "select",
      "id": "grid_size",
      "label": "Dimensione griglia prodotti",
      "options": [
        { "value": "sm", "label": "Piccola (più prodotti)" },
        { "value": "md", "label": "Media (default)"       },
        { "value": "lg", "label": "Grande (meno prodotti)"}
      ],
      "default": "md"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24,
      "label": "Prodotti per pagina"
    },
    {
      "type": "text",
      "id": "vendors",
      "label": "Marche (separate da virgola)",
      "default": "Venum, Hayabusa, Leone, Cleto Reyes"
    },
    {

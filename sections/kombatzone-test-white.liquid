{% comment %}
  KOMBAT ZONE — White Test Section
  File: sections/kombatzone-test-white.liquid
  Simple white section used to verify GitHub → Shopify sync.
{% endcomment %}

<style>
  .kz-test-white {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    text-align: center;
    padding: {{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 600;
  }
</style>

<div class="kz-test-white">
  {{ section.settings.section_text }}
</div>

{% schema %}
{
  "name": "KZ Test White",
  "tag": "div",
  "class": "kz-test-white-section",
  "settings": [
    {
      "type": "text",
      "id": "section_text",
      "label": "Testo",
      "default": "sezione di test - sync ok"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Colore sfondo",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Colore testo",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superiore",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferiore",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "KZ Test White"
    }
  ]
}
{% endschema %}

{% comment %}
  KOMBAT ZONE — Hello Bar (test section)
  File: sections/kombatzone-hello-bar.liquid
  Simple announcement bar with red background, placed below the header.
{% endcomment %}

<style>
  .kz-hello-bar {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    text-align: center;
    padding: 10px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: .02em;
  }
</style>

<div class="kz-hello-bar">
  {{ section.settings.bar_text }}
</div>

{% schema %}
{
  "name": "KZ Hello Bar",
  "tag": "div",
  "class": "kz-hello-bar-section",
  "settings": [
    {
      "type": "text",
      "id": "bar_text",
      "label": "Testo",
      "default": "hello world"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Colore sfondo",
      "default": "#E8272A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Colore testo",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "KZ Hello Bar"
    }
  ]
}
{% endschema %}

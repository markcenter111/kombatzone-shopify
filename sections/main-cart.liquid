    margin: 0 0 26px;
  }
  #shopify-section-{{ section.id }} .kz-empty-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #E8272A;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 13px 24px;
    text-decoration: none;
    border-radius: 8px;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  #shopify-section-{{ section.id }} .kz-empty-cta:hover {
    background: #c41f22;
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(232,39,42,.35);
  }
  #shopify-section-{{ section.id }} .kz-empty-cta:active { transform: translateY(0) scale(.98); box-shadow: none; }
  #shopify-section-{{ section.id }} .kz-empty-also {
    width: 100%;
    max-width: 760px;
    margin-top: 36px;
    padding-top: 30px;
    border-top: 1px solid rgba(255,255,255,0.07);
    text-align: left;
  }
  #shopify-section-{{ section.id }} .kz-empty-also-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .02em;
    color: #F2F0EB;
    margin-bottom: 14px;
  }

  /* ----------------------------------------------------------------------
     Responsive: sotto i 900px la sidebar scende sotto la colonna prodotti
     invece di restare affiancata (sennò su mobile si sovrappongono).
     ---------------------------------------------------------------------- */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .kz-cart-body {
      grid-template-columns: 1fr;
    }
    #shopify-section-{{ section.id }} .kz-cart-items {
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
  }

  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .kz-page-header {
      padding: 16px 16px 14px;
    }
    #shopify-section-{{ section.id }} .kz-page-title { font-size: 26px; }
    #shopify-section-{{ section.id }} .kz-promo-bar,
    #shopify-section-{{ section.id }} .kz-cart-item,
    #shopify-section-{{ section.id }} .kz-also-like,
    #shopify-section-{{ section.id }} .kz-sidebar {
      padding-left: 16px;
      padding-right: 16px;
    }
    #shopify-section-{{ section.id }} .kz-cart-item {
      grid-template-columns: 76px 1fr;
      row-gap: 10px;
    }
    #shopify-section-{{ section.id }} .kz-item-img { width: 76px; height: 76px; }
    #shopify-section-{{ section.id }} .kz-item-right {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    #shopify-section-{{ section.id }} .kz-item-actions {
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
    }
    #shopify-section-{{ section.id }} .kz-qty-btn { width: 34px; height: 32px; }
    #shopify-section-{{ section.id }} .kz-qty-val { width: 36px; height: 32px; }
    /* Su mobile: griglia 2 colonne, le card vanno a capo dopo 2 per riga */
    .kz-also-grid {
      flex-wrap: wrap;
      justify-content: center;
      overflow-x: visible;
      gap: 8px;
    }
    .kz-also-grid .kz-also-card {
      flex: 0 0 calc(50% - 8px) !important;
      width: calc(50% - 8px);
      max-width: calc(50% - 8px);
    }
    #shopify-section-{{ section.id }} .kz-empty { padding: 56px 16px; }
    #shopify-section-{{ section.id }} .kz-empty-also { max-width: 100%; }
    #shopify-section-{{ section.id }} .kz-set-bundle { margin: 12px 16px; }

    /* Sticky checkout bar */
    #shopify-section-{{ section.id }} .kz-cart-section { padding-bottom: 66px; }
    #shopify-section-{{ section.id }} .kz-cart-sticky {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 998;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 10px 16px;
      padding-bottom: calc(10px + env(safe-area-inset-bottom));
      background: rgba(10,10,10,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1px solid rgba(255,255,255,0.08);
      transform: translateY(0);
      transition: transform .25s ease;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky.is-hidden { transform: translateY(110%); }
    #shopify-section-{{ section.id }} .kz-cart-sticky-total {
      display: flex;
      flex-direction: column;
      line-height: 1.15;
      flex-shrink: 0;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky-label {
      font-family: 'Inter', sans-serif;
      font-size: 8.5px;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #888880;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 21px;
      font-weight: 800;
      color: #F2F0EB;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky-btn {
      flex: 1;
      background: #E8272A;
      color: #fff;
      font-family: 'Inter', sans-serif;
      font-size: 11.5px;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      padding: 13px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      transition: background .2s ease, transform .15s ease;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky-btn:active { background: #c41f22; transform: scale(.98); }
  }

  /* === Upsell carrello su mobile: 2 card per riga, proporzionate === */
  @media (max-width: 600px) {
    #shopify-section-{{ section.id }} .kz-also-grid {
      display: flex !important;
      flex-wrap: wrap !important;
      justify-content: center !important;
      overflow: visible !important;
      gap: 10px !important;
      padding-bottom: 0 !important;
    }
    #shopify-section-{{ section.id }} .kz-also-grid > * { display: block !important; }
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card,
    #shopify-section-{{ section.id }} .kz-also-grid .kz-also-card {
      flex: 0 0 calc(50% - 5px) !important;
      width: calc(50% - 5px) !important;
      max-width: calc(50% - 5px) !important;
      min-width: 0 !important;
    }
    /* massimo 4 card = 2 righe pulite */
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card:nth-child(n+5),
    #shopify-section-{{ section.id }} .kz-also-grid .kz-also-card:nth-child(n+5) { display: none !important; }
    /* tipografia proporzionata alla card piccola */
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__body { padding: 10px !important; }
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__title { font-size: 12.5px !important; line-height: 1.25 !important; margin-bottom: 6px !important; }
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__type,
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__discipline { font-size: 9.5px !important; }
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__price-current { font-size: 15px !important; }
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__price-old { font-size: 11px !important; }
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__badge { font-size: 9px !important; padding: 2px 6px !important; }
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__cart-fab { width: 30px !important; height: 30px !important; }
    /* le pill contenuto affollano la card piccola: nascoste su mobile */
    #shopify-section-{{ section.id }} .kz-also-grid .kz-card__contenuto { display: none !important; }
  }
</style>

{%- assign free_shipping_threshold = section.settings.free_shipping_threshold -%}
{%- assign free_shipping_threshold_cents = free_shipping_threshold | times: 100 -%}
{%- assign remaining_cents = free_shipping_threshold_cents | minus: cart.original_total_price -%}
{%- if remaining_cents < 0 -%}{%- assign remaining_cents = 0 -%}{%- endif -%}
{%- assign progress_pct = cart.original_total_price | times: 100.0 | divided_by: free_shipping_threshold_cents -%}
{%- if progress_pct > 100 -%}{%- assign progress_pct = 100 -%}{%- endif -%}

{%- comment -%}
  Promo lancio: fino a free_ship_promo_end la spedizione è gratuita per TUTTI
  (stessa data del countdown nel banner). Scaduta la promo, torna
  automaticamente la soglia standard. Lasciare vuoto per disattivare.
{%- endcomment -%}
{%- assign kz_promo_active = false -%}
{%- assign kz_promo_end = section.settings.free_ship_promo_end -%}
{%- if kz_promo_end != blank -%}
  {%- assign kz_now_s = 'now' | date: '%s' | plus: 0 -%}
  {%- assign kz_end_s = kz_promo_end | date: '%s' | plus: 0 -%}
  {%- if kz_now_s < kz_end_s -%}
    {%- assign kz_promo_active = true -%}
    {%- assign remaining_cents = 0 -%}
    {%- assign progress_pct = 100 -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} Raccolta trust badge dai blocks della section, passata allo snippet cart-summary {%- endcomment -%}
{%- assign trust_badges = '' -%}
{%- capture trust_badges_json -%}
  [
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust_badge' -%}
        {"icon":{{ block.settings.icon | json }},"text":{{ block.settings.text | json }}}{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
{%- endcapture -%}
{%- assign trust_badges = trust_badges_json | strip_newlines | strip -%}

<div class="kz-cart-section" id="kz-cart-section-wrapper" data-section-id="{{ section.id }}">

  <div class="kz-page-header">
    <div class="kz-page-title-block">
      <div class="kz-page-title">{{ section.settings.page_title }}<br><span>{{ section.settings.page_title_accent }}</span></div>
      {%- if cart.item_count > 0 -%}
        <div class="kz-page-subtitle">
          {%- if remaining_cents == 0 -%}
            {{ section.settings.subtitle_unlocked | default: "Spedizione gratuita sbloccata. Sei a un passo dal completare l'equipaggiamento." }}
          {%- else -%}
            {{ section.settings.subtitle_default | default: "Controlla l'equipaggiamento, poi passa al" }} <strong>{{ section.settings.subtitle_default_bold | default: "checkout" }}</strong>.
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="kz-page-subtitle">{{ section.settings.subtitle_empty | default: "Il tuo prossimo allenamento inizia da qui." }}</div>
      {%- endif -%}
    </div>
    <div class="kz-item-count">{{ cart.item_count }} articol{% if cart.item_count == 1 %}o{% else %}i{% endif %}</div>
  </div>

  {%- if cart.item_count == 0 -%}

    {%- comment -%}
      "Potrebbero interessarti...": griglia prodotti dalla collezione scelta
      nelle impostazioni della sezione (es. una collezione "Best seller").
      Niente seed product (il carrello è vuoto, non c'è nulla da cui partire
      come con le product recommendations native), quindi qui usiamo una
      collezione configurata a mano una volta sola.
    {%- endcomment -%}
    {%- assign empty_collection = section.settings.empty_cart_collection -%}

    <div class="kz-empty">
      <div class="kz-empty-icon"><i class="ti ti-shopping-bag-x" aria-hidden="true"></i></div>
      <div class="kz-empty-heading">{{ section.settings.empty_cart_heading }}</div>
      {%- if section.settings.empty_cart_subtext != blank -%}
        <p class="kz-empty-subtext">{{ section.settings.empty_cart_subtext }}</p>
      {%- endif -%}
      <a href="{{ section.settings.empty_cart_button_link | default: routes.all_products_collection_url }}" class="kz-empty-cta">
        {{ section.settings.empty_cart_button_label }}
        <i class="ti ti-arrow-right" aria-hidden="true"></i>
      </a>

      {%- if empty_collection != blank and empty_collection.products.size > 0 -%}
        <div class="kz-empty-also">
          <div class="kz-empty-also-title">{{ section.settings.empty_cart_recommend_heading }}</div>
          <div class="kz-also-grid">
            {%- for product in empty_collection.products limit: section.settings.empty_cart_recommend_limit -%}
              {%- render 'kz2-product-card', product: product -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

  {%- else -%}

    <div class="kz-cart-body">
      <div class="kz-cart-items">

        {%- if remaining_cents == 0 -%}
          <div class="kz-promo-bar is-unlocked">
            <i class="ti ti-circle-check" aria-hidden="true"></i>
            {{ section.settings.promo_bar_unlocked_text | default: "Spedizione gratuita sbloccata — sei pronto per il checkout" }}
          </div>
        {%- elsif section.settings.promo_bar_text != blank -%}
          <div class="kz-promo-bar">
            <i class="ti ti-clock" aria-hidden="true"></i>
            {{ section.settings.promo_bar_text }}
            &nbsp;·&nbsp; Hai ancora <strong style="text-decoration:underline;">{{ remaining_cents | money }}</strong> al traguardo
          </div>
        {%- endif -%}

        <div style="padding: 10px 24px 0; background: #0a0a0a;">
          <div class="kz-progress-bar-wrap"><div class="kz-progress-bar{% if remaining_cents == 0 %} is-complete{% endif %}" style="width: {{ progress_pct }}%;"><span class="kz-progress-truck" aria-hidden="true"><i class="ti ti-truck-delivery"></i></span></div></div>
          <div class="kz-free-shipping-msg" data-free-shipping-msg>
            {%- if remaining_cents > 0 -%}
              Aggiungi <strong>{{ remaining_cents | money }} di prodotti</strong> per la spedizione gratuita
            {%- else -%}
              <strong>Hai sbloccato la spedizione gratuita!</strong>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Righe prodotto: l'omaggio automatico viene rilevato dentro lo snippet stesso {%- endcomment -%}
        {%- for item in cart.items -%}
          {%- if item.properties._kz_set == blank -%}
            {%- render 'cart-item', item: item, item_index: forloop.index -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Fighter Set: righe con la stessa proprieta _kz_set raggruppate in un bundle {%- endcomment -%}
        {%- assign kz_handled_sets = '' -%}
        {%- for item in cart.items -%}
          {%- assign kz_sid = item.properties._kz_set -%}
          {%- if kz_sid != blank -%}
            {%- assign kz_sid_token = '|' | append: kz_sid | append: '|' -%}
            {%- unless kz_handled_sets contains kz_sid_token -%}
              {%- assign kz_handled_sets = kz_handled_sets | append: kz_sid_token -%}
              {%- assign kz_set_count = 0 -%}
              {%- assign kz_set_total = 0 -%}
              {%- for it2 in cart.items -%}
                {%- if it2.properties._kz_set == kz_sid -%}
                  {%- assign kz_set_count = kz_set_count | plus: it2.quantity -%}
                  {%- assign kz_set_total = kz_set_total | plus: it2.final_line_price -%}
                {%- endif -%}
              {%- endfor -%}
              <div class="kz-set-bundle" data-set-id="{{ kz_sid }}">
                <div class="kz-set-head">
                  <span class="kz-set-head-title">Fighter Set <em>· {{ kz_set_count }} pezz{% if kz_set_count == 1 %}o{% else %}i{% endif %}</em></span>
                  <span class="kz-set-head-total">{{ kz_set_total | money }}</span>
                </div>
                {%- for it2 in cart.items -%}
                  {%- if it2.properties._kz_set == kz_sid -%}
                    {%- render 'cart-item', item: it2, item_index: forloop.index -%}
                  {%- endif -%}
                {%- endfor -%}
                <div class="kz-set-actions">
                  <a href="/pages/fighter-locker?edit_set={{ kz_sid | url_encode }}" class="kz-set-edit">Modifica set</a>
                  <button type="button" class="kz-set-remove" data-remove-set="{{ kz_sid }}">Rimuovi set</button>
                </div>
              </div>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%}
          Upsell con le product recommendations native di Shopify, basate sul
          primo prodotto presente in carrello. Il container parte nascosto
          (display:none) e viene popolato via JS chiamando l'endpoint
          /recommendations/products, che renderizza sections/cart-upsell-
          recommendations.liquid lato server: niente collezione da gestire a mano.
        {%- endcomment -%}
        {%- if section.settings.show_upsells -%}
          {%- assign seed_product_id = cart.items.first.product_id -%}
          <div
            class="kz-also-like"
            data-upsell-root
            data-seed-id="{{ seed_product_id }}"
            data-limit="{{ section.settings.upsell_limit }}"
            data-intent="{{ section.settings.upsell_intent }}"
            style="display:none;"
          >

            <div class="kz-also-header">
              <div class="kz-also-title">
                {%- if section.settings.upsell_title != blank -%}
                  {{ section.settings.upsell_title }}
                {%- else -%}
                  Completa il tuo <span>setup</span>
                {%- endif -%}
              </div>
            </div>
            <div class="kz-also-subtitle">{{ section.settings.upsell_subtitle | default: "Chi ha preso questo articolo ha aggiunto anche:" }}</div>
            <div class="kz-also-scroll-wrap">
              <button class="kz-also-arrow left" data-upsell-arrow="left" aria-label="Scorri a sinistra" hidden>
                <i class="ti ti-chevron-left"></i>
              </button>
              <div class="kz-also-grid" data-upsell-grid></div>
              <button class="kz-also-arrow right" data-upsell-arrow="right" aria-label="Scorri a destra" hidden>
                <i class="ti ti-chevron-right"></i>
              </button>
            </div>
          </div>
        {%- endif -%}

      </div>

      {%- render 'cart-summary', free_shipping_threshold: free_shipping_threshold, trust_badges: trust_badges, promo_active: kz_promo_active -%}

    </div>

    {%- comment -%} Sticky checkout — solo mobile, si nasconde quando il bottone reale è visibile {%- endcomment -%}
    <div class="kz-cart-sticky" data-cart-sticky>
      <div class="kz-cart-sticky-total">
        <span class="kz-cart-sticky-label">Totale</span>
        <span class="kz-cart-sticky-val">{{ cart.total_price | money }}</span>
      </div>
      <button type="button" onclick="window.location.href='/checkout'" class="kz-cart-sticky-btn">
        <i class="ti ti-lock" aria-hidden="true"></i>
        Procedi al checkout
      </button>
    </div>

  {%- endif -%}
</div>

<script>
  (function () {
    var sectionId = {{ section.id | json }};

    var stickyObserver = null;
    function initStickyCheckout() {
      var sticky = document.querySelector('[data-cart-sticky]');
      var realBtn = document.querySelector('.kz-checkout-btn');
      if (!sticky || !realBtn || !('IntersectionObserver' in window)) return;
      if (stickyObserver) stickyObserver.disconnect();
      stickyObserver = new IntersectionObserver(function (entries) {
        sticky.classList.toggle('is-hidden', entries[0].isIntersecting);
      }, { rootMargin: '0px 0px -8% 0px' });
      stickyObserver.observe(realBtn);
    }
    initStickyCheckout();

    function loadUpsells() {
      var container = document.querySelector('[data-upsell-root]');
      if (!container) return;

      var seedId = container.dataset.seedId;
      if (!seedId) {
        container.style.display = 'none';
        return;
      }

      var limit = container.dataset.limit || 3;
      var intent = container.dataset.intent || 'related';
      var grid = container.querySelector('[data-upsell-grid]');

      var url = '/recommendations/products'
        + '?section_id=cart-upsell-recommendations'
        + '&product_id=' + encodeURIComponent(seedId)
        + '&limit=' + encodeURIComponent(limit)
        + '&intent=' + encodeURIComponent(intent);

      fetch(url)
        .then(function (r) { return r.text(); })
        .then(function (html) {
          html = html.trim();
          if (!html) {
            container.style.display = 'none';
            return;
          }
          /* Shopify wrappa la sezione in <div class="shopify-section">.
             Estraiamo solo le .kz-also-card per non rompere il flex layout. */
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var cards = doc.querySelectorAll('.kz-card');
          if (!cards.length) { container.style.display = 'none'; return; }
          grid.innerHTML = '';
          cards.forEach(function(card) { grid.appendChild(card); });
          container.style.display = '';
        })
        .catch(function (err) {
          console.error('Errore recupero prodotti consigliati:', err);
          container.style.display = 'none';
        });
    }

    function refreshSection() {
      return fetch(window.location.pathname + '?sections=' + sectionId)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var html = data[sectionId];
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var newWrapper = doc.getElementById('kz-cart-section-wrapper');
          var oldWrapper = document.getElementById('kz-cart-section-wrapper');
          if (newWrapper && oldWrapper) {
            oldWrapper.replaceWith(newWrapper);
          }
          loadUpsells();
          initStickyCheckout();
          document.dispatchEvent(new CustomEvent('cart:updated'));
        });
    }

    function changeLine(line, quantity) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: quantity })
      })
        .then(function (r) { return r.json(); })
        .then(function () { refreshSection(); })
        .catch(function (err) { console.error('Errore aggiornamento carrello:', err); });
    }

    function addVariant(variantId) {
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
      })
        .then(function (r) { return r.json(); })
        .then(function () { refreshSection(); })
        .catch(function (err) { console.error('Errore aggiunta al carrello:', err); });
    }

    function changeVariant(line, newVariantId, quantity) {
      // Leggiamo il carrello per ottenere il key stabile della riga da rimuovere,
      // poi aggiungiamo la nuova variante e azzeriamo la vecchia tramite key.
      var oldKey = null;

      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          var oldItem = cart.items[line - 1]; // line è 1-based
          if (oldItem) oldKey = oldItem.key;
          var newItem = { id: parseInt(newVariantId, 10), quantity: quantity };
          /* Conserva le proprietà della riga (es. _kz_set del Fighter Set):
             così cambiare taglia/colore non fa uscire il pezzo dal bundle */
          if (oldItem && oldItem.properties && Object.keys(oldItem.properties).length) {
            newItem.properties = oldItem.properties;
          }
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [newItem] })
          });
        })
        .then(function (r) { return r.json(); })
        .then(function () {
          if (!oldKey) return Promise.resolve();
          return fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: oldKey, quantity: 0 })
          });
        })
        .then(function () { refreshSection(); })
        .catch(function (err) { console.error('Errore cambio variante:', err); });
    }

    if (!window.kzCartHandlersBound) {
      window.kzCartHandlersBound = true;
      document.addEventListener('click', function (e) {
        var increaseBtn = e.target.closest('[data-qty-increase]');
        var decreaseBtn = e.target.closest('[data-qty-decrease]');
        var removeBtn = e.target.closest('[data-cart-remove]');
        var upsellBtn = e.target.closest('[data-upsell-add]');

        if (increaseBtn || decreaseBtn) {
          var row = (increaseBtn || decreaseBtn).closest('[data-cart-item]');
          if (!row) return;
          var line = parseInt(row.dataset.lineIndex, 10);
          var valueEl = row.querySelector('[data-qty-value]');
          var current = parseInt(valueEl.textContent, 10) || 1;
          var next = increaseBtn ? current + 1 : current - 1;
          if (next < 1) next = 0; // 0 rimuove la riga
          changeLine(line, next);
          return;
        }

        if (removeBtn) {
          var rowToRemove = removeBtn.closest('[data-cart-item]');
          if (!rowToRemove) return;
          var lineToRemove = parseInt(rowToRemove.dataset.lineIndex, 10);
          changeLine(lineToRemove, 0);
          return;
        }

        if (upsellBtn) {
          var card = upsellBtn.closest('[data-also-card]');
          var variantId = upsellBtn.dataset.variantId;
          if (!variantId && card) {
            var variantSelect = card.querySelector('[data-variant-select]');
            if (variantSelect) variantId = variantSelect.value;
          }
          if (variantId) addVariant(variantId);
          return;
        }
      });

      document.addEventListener('change', function (e) {
        var sizeSelect = e.target.closest('[data-variant-change]');
        if (!sizeSelect) return;
        var row = sizeSelect.closest('[data-cart-item]');
        if (!row) return;
        var line = parseInt(sizeSelect.dataset.lineIndex, 10);
        var newVariantId = sizeSelect.value;
        var valueEl = row.querySelector('[data-qty-value]');
        var quantity = valueEl ? (parseInt(valueEl.textContent, 10) || 1) : 1;
        changeVariant(line, newVariantId, quantity);
      });

      function kzFormatMoney(cents) {
        return '\u20AC' + (cents / 100).toFixed(2).replace('.', ',');
      }

      /* ── Tendina variante custom: taglia testo + pallino colore ── */
      var VDD_CARET = '<svg class="kz-vdd-caret" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>';

      function vddCloseAll(except) {
        document.querySelectorAll('.kz-vdd.open').forEach(function (d) {
          if (d !== except) d.classList.remove('open');
        });
      }

      function vddLabelHtml(text, colorIdx) {
        var parts = String(text).split(' / ');
        return parts.map(function (part, i) {
          if (i === colorIdx) {
            var c = part.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-');
            return '<span class="kz-item-color-dot" style="background-color:' + c + '" title="' + part + '"></span>';
          }
          return '<span>' + part + '</span>';
        }).join(' / ');
      }

      function initVariantDropdowns() {
        document.querySelectorAll('.kz-item-size-select').forEach(function (sel) {
          if (sel.dataset.kzVdd) return;
          sel.dataset.kzVdd = '1';
          var colorIdx = parseInt(sel.getAttribute('data-color-idx'), 10);

          var dd = document.createElement('div');
          dd.className = 'kz-vdd';
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'kz-vdd-btn';
          btn.setAttribute('aria-haspopup', 'listbox');
          var selOpt = sel.options[sel.selectedIndex];
          btn.innerHTML = '<span class="kz-vdd-label">' + vddLabelHtml(selOpt ? selOpt.text.trim() : '', colorIdx) + '</span>' + VDD_CARET;

          var panel = document.createElement('div');
          panel.className = 'kz-vdd-panel';
          panel.setAttribute('role', 'listbox');
          Array.prototype.forEach.call(sel.options, function (o) {
            var it = document.createElement('button');
            it.type = 'button';
            it.className = 'kz-vdd-opt' + (o.selected ? ' is-selected' : '');
            it.disabled = o.disabled;
            it.innerHTML = vddLabelHtml(o.text.trim(), colorIdx);
            it.addEventListener('click', function () {
              if (o.disabled) return;
              sel.value = o.value;
              dd.classList.remove('open');
              btn.querySelector('.kz-vdd-label').innerHTML = vddLabelHtml(o.text.trim(), colorIdx);
              sel.dispatchEvent(new Event('change', { bubbles: true }));
            });
            panel.appendChild(it);
          });

          dd.appendChild(btn);
          dd.appendChild(panel);
          sel.parentNode.insertBefore(dd, sel);
          sel.style.display = 'none';

          btn.addEventListener('click', function (e) {
            e.stopPropagation();
            vddCloseAll(dd);
            dd.classList.toggle('open');
          });
        });
      }
      initVariantDropdowns();
      document.addEventListener('click', function () { vddCloseAll(); });
      document.addEventListener('cart:updated', initVariantDropdowns);

      /* ── Rimuovi un intero Fighter Set (tutte le righe con la stessa _kz_set) ── */
      document.addEventListener('click', function (e) {
        var setBtn = e.target.closest('[data-remove-set]');
        if (!setBtn) return;
        var sid = setBtn.getAttribute('data-remove-set');
        setBtn.disabled = true;
        setBtn.style.opacity = '.5';
        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            var updates = {};
            cart.items.forEach(function (it) {
              if (it.properties && it.properties._kz_set === sid) updates[it.key] = 0;
            });
            return fetch('/cart/update.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ updates: updates })
            });
          })
          .then(function () { refreshSection(); })
          .catch(function () {
            setBtn.disabled = false;
            setBtn.style.opacity = '';
          });
      });

      document.addEventListener('click', function (e) {
        var removeBtn = e.target.closest('[data-coupon-remove]');
        if (!removeBtn) return;
        removeBtn.disabled = true;
        removeBtn.style.opacity = '.5';
        fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ discount: '' })
        })
          .then(function () { refreshSection(); })
          .catch(function () {
            removeBtn.disabled = false;
            removeBtn.style.opacity = '';
          });
      });

      document.addEventListener('submit', function (e) {
        var couponForm = e.target.closest('[data-coupon-form]');
        if (!couponForm) return;
        e.preventDefault();

        var input = couponForm.querySelector('[data-coupon-input]');
        var code = input ? input.value.trim() : '';
        if (!code) return;

        var submitBtn = couponForm.querySelector('[data-coupon-submit]');
        var msgEl = document.querySelector('[data-coupon-msg]');

        function setMsg(el, text, type) {
          if (!el) return;
          el.textContent = text;
          el.className = 'kz-coupon-msg show' + (type ? ' ' + type : '');
        }

        if (submitBtn) { submitBtn.disabled = true; submitBtn.classList.add('is-loading'); }
        setMsg(msgEl, 'Verifica in corso…', '');

        // Cart AJAX API: /cart/update.js con { discount: CODICE } applica lo
        // sconto direttamente al carrello (totali, chip e riepilogo si
        // aggiornano subito), senza passare dal checkout.
        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (cartBefore) {
            return fetch('/cart/update.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ discount: code })
            })
              .then(function (r) { return r.json(); })
              .then(function (cartAfter) {
                var saved = cartBefore.total_price - cartAfter.total_price;
                var applied = saved > 0 || cartAfter.total_discount > cartBefore.total_discount;
                return refreshSection().then(function () {
                  var newMsg = document.querySelector('[data-coupon-msg]');
                  if (applied) {
                    var savedAmount = saved > 0 ? saved : cartAfter.total_discount - cartBefore.total_discount;
                    setMsg(newMsg, 'Codice applicato: risparmi ' + kzFormatMoney(savedAmount) + '.', 'success');
                  } else {
                    setMsg(newMsg, 'Codice non valido, scaduto o non applicabile a questo ordine.', 'error');
                  }
                });
              });
          })
          .catch(function () {
            setMsg(msgEl, 'Errore durante la verifica del codice. Riprova.', 'error');
            if (submitBtn) { submitBtn.disabled = false; submitBtn.classList.remove('is-loading'); }
          });
      });
    }

    /* ── Bottone toggle dimensione card upsell ── */
    function initUpsellControls() {
      var root    = document.querySelector('[data-upsell-root]');
      if (!root) return;
      var grid    = root.querySelector('[data-upsell-grid]');
      var toggle  = root.querySelector('[data-upsell-size-toggle]');
      var label   = root.querySelector('[data-upsell-size-label]');
      var arrowL  = root.querySelector('[data-upsell-arrow="left"]');
      var arrowR  = root.querySelector('[data-upsell-arrow="right"]');
      if (!grid) return;

      /* Frecce scroll */
      var STEP = 140;
      function updateArrows() {
        if (!arrowL || !arrowR) return;
        var canScrollL = grid.scrollLeft > 4;
        var canScrollR = grid.scrollLeft + grid.clientWidth < grid.scrollWidth - 4;
        arrowL.hidden = !canScrollL;
        arrowR.hidden = !canScrollR;
      }
      if (arrowL) arrowL.addEventListener('click', function () { grid.scrollBy({ left: -STEP, behavior: 'smooth' }); });
      if (arrowR) arrowR.addEventListener('click', function () { grid.scrollBy({ left:  STEP, behavior: 'smooth' }); });
      grid.addEventListener('scroll', updateArrows);
      /* Aggiorna frecce dopo che le card sono nel DOM */
      setTimeout(updateArrows, 120);
    }

    /* Aspetta che loadUpsells inietti le card, poi inizializza i controlli */
    (function patchLoad() {
      var container = document.querySelector('[data-upsell-root]');
      if (!container) return;
      var grid = container.querySelector('[data-upsell-grid]');
      var observer = new MutationObserver(function (mutations) {
        if (mutations.some(function(m){ return m.addedNodes.length > 0; })) {
          observer.disconnect();
          initUpsellControls();
        }
      });
      if (grid) observer.observe(grid, { childList: true });
    })();
    loadUpsells();
  })();
</script>


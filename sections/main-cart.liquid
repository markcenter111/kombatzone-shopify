{%- comment -%}
  sections/main-cart.liquid
  ----------------------------------------------------------------------
  Sezione carrello Kombat Zone. Da usare in templates/cart.json (o
  templates/cart.liquid con {% section 'main-cart' %}).

  Nota: l'header/nav del mockup non è incluso qui perché normalmente
  fa parte di sections/header.liquid nel layout del tema.

  Dipendenze esterne: Tabler Icons (classi "ti ti-*") e i font Google
  "Barlow Condensed" e "Inter", caricati qui sotto via <link>. Se il
  tema li carica già a livello globale, questi tag possono essere rimossi.

  Dipendenza interna: sections/cart-upsell-recommendations.liquid, usata
  per renderizzare i prodotti "Spesso aggiunto insieme" tramite le product
  recommendations native di Shopify (vedi quel file per i dettagli).
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">

<style>
  #shopify-section-{{ section.id }} .kz-cart-section {
    background: #0a0a0a;
    font-family: 'Inter', sans-serif;
    color: #F2F0EB;
    font-size: 13px;
  }
  #shopify-section-{{ section.id }} .kz-page-header {
    background: #111111;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 22px 24px 18px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .kz-page-title-block { display: flex; flex-direction: column; gap: 6px; }
  #shopify-section-{{ section.id }} .kz-page-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: .02em;
  }
  #shopify-section-{{ section.id }} .kz-page-title span { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-page-subtitle {
    font-size: 12px;
    color: #888880;
    letter-spacing: .01em;
    line-height: 1.4;
    max-width: 420px;
  }
  #shopify-section-{{ section.id }} .kz-page-subtitle strong { color: #F2F0EB; font-weight: 600; }
  #shopify-section-{{ section.id }} .kz-item-count {
    font-size: 11px;
    color: #888880;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding-bottom: 4px;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .kz-cart-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 0;
    align-items: start;
  }
  #shopify-section-{{ section.id }} .kz-cart-items {
    padding: 0;
    border-right: 1px solid rgba(255,255,255,0.07);
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .kz-sidebar { min-width: 0; }
  #shopify-section-{{ section.id }} .kz-promo-bar {
    background: #E8272A;
    padding: 9px 24px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background .2s;
  }
  #shopify-section-{{ section.id }} .kz-promo-bar i { font-size: 14px; }
  #shopify-section-{{ section.id }} .kz-promo-bar.is-unlocked {
    background: rgba(76,187,122,0.12);
    color: #4cbb7a;
    border-bottom: 1px solid rgba(76,187,122,0.25);
  }
  #shopify-section-{{ section.id }} .kz-promo-bar.is-unlocked i { color: #4cbb7a; }
  #shopify-section-{{ section.id }} .kz-cart-item {
    display: grid;
    grid-template-columns: 104px 1fr auto;
    gap: 18px;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    align-items: center;
    background: #0a0a0a;
    transition: background .15s;
  }
  #shopify-section-{{ section.id }} .kz-cart-item:hover { background: #111; }
  #shopify-section-{{ section.id }} .kz-item-img {
    background: #141414;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 8px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
    overflow: hidden;
    transition: border-color .2s;
  }
  #shopify-section-{{ section.id }} .kz-cart-item:hover .kz-item-img { border-color: rgba(232,39,42,0.4); }
  #shopify-section-{{ section.id }} .kz-item-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ section.id }} .kz-item-img i { font-size: 30px; color: rgba(255,255,255,0.12); }
  #shopify-section-{{ section.id }} .kz-item-badge {
    position: absolute;
    top: 5px;
    left: 5px;
    background: #E8272A;
    color: #fff;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 4px;
    line-height: 1.4;
  }
  #shopify-section-{{ section.id }} .kz-item-info { display: flex; flex-direction: column; gap: 5px; }
  #shopify-section-{{ section.id }} .kz-item-cat {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #E8272A;
  }
  #shopify-section-{{ section.id }} .kz-item-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 19px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .01em;
    line-height: 1.1;
    color: #F2F0EB;
    display: block;
    transition: color .15s;
  }
  #shopify-section-{{ section.id }} .kz-item-name:hover { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-top: 2px;
  }
  #shopify-section-{{ section.id }} .kz-item-size {
    font-size: 10px;
    color: #888880;
    letter-spacing: .06em;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 2px 7px;
  }
  /* ── Bundle Fighter Set ── */
  #shopify-section-{{ section.id }} .kz-set-bundle {
    margin: 14px 24px;
    border: 1px solid rgba(232,39,42,0.35);
    border-radius: 12px;
    /* overflow visibile: la tendina variante deve poter uscire dalla card */
    background: linear-gradient(180deg, rgba(232,39,42,0.05), rgba(232,39,42,0) 70%);
  }
  #shopify-section-{{ section.id }} .kz-set-head { border-radius: 12px 12px 0 0; }
  #shopify-section-{{ section.id }} .kz-set-actions { border-radius: 0 0 12px 12px; }
  #shopify-section-{{ section.id }} .kz-set-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .kz-set-head-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: #E8272A;
  }
  #shopify-section-{{ section.id }} .kz-set-head-title em {
    font-style: normal;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    color: #888880;
    letter-spacing: .06em;
  }
  #shopify-section-{{ section.id }} .kz-set-head-total {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: #F2F0EB;
  }
  #shopify-section-{{ section.id }} .kz-set-bundle .kz-cart-item:last-of-type { border-bottom: none; }
  #shopify-section-{{ section.id }} .kz-set-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 16px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .kz-set-edit {
    display: inline-flex;
    align-items: center;
    padding: 7px 14px;
    border: 1px solid rgba(242,240,235,0.35);
    border-radius: 8px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color .2s ease, transform .2s ease, background .2s ease;
  }
  #shopify-section-{{ section.id }} .kz-set-edit:hover { border-color: #F2F0EB; transform: translateY(-1px); background: rgba(255,255,255,.04); }
  #shopify-section-{{ section.id }} .kz-set-remove {
    background: none;
    border: none;
    color: #3f3f3a;
    opacity: .8;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: 4px 2px;
    transition: color .15s, opacity .15s;
  }
  #shopify-section-{{ section.id }} .kz-set-remove:hover { color: #E8272A; opacity: 1; }

  /* Frecce del carosello upsell: rimosse */
  #shopify-section-{{ section.id }} .kz-also-arrow,
  .kz-also-arrow { display: none !important; }

  /* Upsell: griglia a righe complete come il catalogo.
     Card compatte, testi leggibili; le card oltre la riga piena si nascondono. */
  .kz-also-grid {
    display: flex !important;
    flex-wrap: wrap !important;
    justify-content: center !important;
    gap: 10px;
    overflow: visible !important;
  }
  .kz-also-grid .kz-also-card {
    width: auto !important;
    flex: 0 0 calc(16.666% - 9px) !important;
    max-width: calc(16.666% - 9px) !important;
  }
  .kz-also-grid .kz-also-card:nth-child(n+7) { display: none !important; }
  /* Tipografia proporzionata alle card */
  .kz-also-grid .kz-card__title { font-size: 13.5px; }
  .kz-also-grid .kz-card__price-current { font-size: 17px; }
  .kz-also-grid .kz-card__type,
  .kz-also-grid .kz-card__discipline { font-size: 10.5px; }
  @media (max-width: 1199px) {
    .kz-also-grid .kz-also-card { flex-basis: calc(25% - 8px) !important; max-width: calc(25% - 8px) !important; }
    .kz-also-grid .kz-also-card:nth-child(n+5) { display: none !important; }
  }
  @media (max-width: 540px) {
    .kz-also-grid .kz-also-card { flex-basis: calc(50% - 5px) !important; max-width: calc(50% - 5px) !important; }
    .kz-also-grid .kz-also-card:nth-child(n+3) { display: flex !important; }
    .kz-also-grid .kz-also-card:nth-child(n+5) { display: none !important; }
  }

  /* Tendina variante custom: taglia + pallino colore */
  #shopify-section-{{ section.id }} .kz-vdd { position: relative; display: inline-block; }
  #shopify-section-{{ section.id }} .kz-vdd-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 600;
    color: #F2F0EB;
    letter-spacing: .04em;
    background: #161616;
    border: 1px solid rgba(242,240,235,0.25);
    border-radius: 8px;
    padding: 8px 12px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: border-color .15s, transform .1s;
  }
  #shopify-section-{{ section.id }} .kz-vdd-btn:hover { border-color: rgba(242,240,235,0.6); transform: translateY(-1px); }
  #shopify-section-{{ section.id }} .kz-vdd.open .kz-vdd-btn { border-color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-vdd-caret {
    width: 11px;
    height: 11px;
    color: #777;
    transition: transform .2s ease;
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .kz-vdd.open .kz-vdd-caret { transform: rotate(180deg); color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-vdd-panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: max(100%, 150px);
    background: #161616;
    border: 1px solid #2a2a2a;
    border-radius: 10px;
    padding: 6px;
    z-index: 60;
    box-shadow: 0 18px 44px rgba(0,0,0,.65);
    opacity: 0;
    transform: translateY(-6px) scale(.98);
    transform-origin: top;
    pointer-events: none;
    transition: opacity .16s ease, transform .16s ease;
    display: flex;
    flex-direction: column;
    gap: 2px;
    max-height: 300px;
    overflow-y: auto;
    min-width: 170px;
    scrollbar-width: thin;
    scrollbar-color: #333 transparent;
  }
  #shopify-section-{{ section.id }} .kz-vdd-panel::-webkit-scrollbar { width: 6px; }
  #shopify-section-{{ section.id }} .kz-vdd-panel::-webkit-scrollbar-thumb { background: #333; border-radius: 99px; }
  #shopify-section-{{ section.id }} .kz-vdd-panel::-webkit-scrollbar-track { background: transparent; }
  #shopify-section-{{ section.id }} .kz-vdd.open .kz-vdd-panel { opacity: 1; transform: none; pointer-events: auto; }
  #shopify-section-{{ section.id }} .kz-vdd-opt {
    display: flex;
    align-items: center;
    gap: 7px;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    border-radius: 6px;
    padding: 8px 10px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #aaa;
    cursor: pointer;
    white-space: nowrap;
    transition: background .12s, color .12s;
  }
  #shopify-section-{{ section.id }} .kz-vdd-opt:hover:not(:disabled) { background: rgba(232,39,42,.12); color: #fff; }
  #shopify-section-{{ section.id }} .kz-vdd-opt.is-selected { color: #fff; font-weight: 600; }
  #shopify-section-{{ section.id }} .kz-vdd-opt:disabled { opacity: .35; text-decoration: line-through; cursor: not-allowed; }
  #shopify-section-{{ section.id }} .kz-item-color-dot {
    display: inline-block;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.35);
    flex-shrink: 0;
    vertical-align: -2px;
  }
  #shopify-section-{{ section.id }} .kz-item-size-select {
    font-size: 12px;
    font-weight: 600;
    color: #F2F0EB;
    letter-spacing: .04em;
    background: #161616;
    border: 1px solid rgba(242,240,235,0.25);
    border-radius: 8px;
    padding: 8px 12px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    max-width: 180px;
    transition: border-color .15s, transform .1s;
  }
  #shopify-section-{{ section.id }} .kz-item-size-select:hover { border-color: rgba(242,240,235,0.6); transform: translateY(-1px); }
  #shopify-section-{{ section.id }} .kz-item-size-select:focus { outline: none; border-color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-custom-tag {
    font-size: 9px;
    color: #C9992A;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: rgba(201,153,42,0.1);
    border: 1px solid rgba(201,153,42,0.2);
    padding: 2px 6px;
  }
  #shopify-section-{{ section.id }} .kz-item-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .kz-item-price-main {
    font-size: 16px;
    font-weight: 600;
    color: #F2F0EB;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .kz-item-price-was {
    font-size: 11px;
    color: #4a4a44;
    text-decoration: line-through;
  }
  #shopify-section-{{ section.id }} .kz-item-save {
    font-size: 9px;
    font-weight: 700;
    color: #E8272A;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .kz-item-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .kz-qty {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    background: #161616;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kz-qty-btn {
    background: transparent;
    border: none;
    color: #a5a59d;
    width: 32px;
    height: 32px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 300;
    font-family: 'Inter', sans-serif;
    transition: background .15s, color .15s;
  }
  #shopify-section-{{ section.id }} .kz-qty-btn:hover { background: rgba(255,255,255,0.06); color: #fff; }
  #shopify-section-{{ section.id }} .kz-qty-btn:active { background: rgba(232,39,42,0.85); color: #fff; }
  #shopify-section-{{ section.id }} .kz-qty-val {
    background: transparent;
    color: #F2F0EB;
    font-size: 13px;
    font-weight: 700;
    width: 34px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .kz-remove-btn {
    background: none;
    border: none;
    color: #3f3f3a;
    opacity: .75;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: 'Inter', sans-serif;
    font-size: 8.5px;
    font-weight: 500;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: 4px 2px;
    transition: color .15s, opacity .15s;
  }
  #shopify-section-{{ section.id }} .kz-remove-btn:hover {
    color: #8a8a80;
    opacity: 1;
  }
  #shopify-section-{{ section.id }} .kz-delivery-estimate {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 10.5px;
    color: #888880;
    letter-spacing: .03em;
    margin: 2px 0 12px;
  }
  #shopify-section-{{ section.id }} .kz-delivery-estimate i { color: #4cbb7a; font-size: 14px; }
  #shopify-section-{{ section.id }} .kz-delivery-estimate strong { color: #F2F0EB; font-weight: 600; }
  #shopify-section-{{ section.id }} .kz-cart-sticky { display: none; }
  #shopify-section-{{ section.id }} .kz-free-gift {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 16px;
    padding: 14px 24px;
    background: rgba(201,153,42,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    align-items: center;
    border-left: 3px solid #C9992A;
  }
  #shopify-section-{{ section.id }} .kz-free-gift-img {
    background: #1a1a1a;
    border: 1px solid rgba(201,153,42,0.2);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kz-free-gift-img img { width: 100%; height: 100%; object-fit: cover; }
  #shopify-section-{{ section.id }} .kz-free-gift-img i { font-size: 24px; color: rgba(201,153,42,0.3); }
  #shopify-section-{{ section.id }} .kz-free-tag {
    font-size: 9px;
    font-weight: 700;
    color: #C9992A;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .kz-free-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    color: #F2F0EB;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .kz-free-desc { font-size: 10px; color: #888880; }
  #shopify-section-{{ section.id }} .kz-sidebar {
    padding: 20px 20px;
    background: #0f0f0f;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  #shopify-section-{{ section.id }} .kz-coupon-wrap { display: flex; gap: 0; margin-bottom: 18px; }
  #shopify-section-{{ section.id }} .kz-coupon-input {
    flex: 1;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    border-right: none;
    border-radius: 4px 0 0 4px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    padding: 9px 12px;
    letter-spacing: .06em;
    text-transform: uppercase;
    outline: none;
    transition: border-color .15s;
  }
  #shopify-section-{{ section.id }} .kz-coupon-input:focus { border-color: rgba(232,39,42,0.5); }
  #shopify-section-{{ section.id }} .kz-coupon-input::placeholder { color: #4a4a44; }
  #shopify-section-{{ section.id }} .kz-coupon-btn {
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0 4px 4px 0;
    color: #888880;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 9px 14px;
    cursor: pointer;
    white-space: nowrap;
    transition: background .15s, color .15s;
  }
  #shopify-section-{{ section.id }} .kz-coupon-btn:hover { background: #242424; color: #F2F0EB; }

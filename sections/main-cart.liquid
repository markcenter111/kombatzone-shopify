{%- comment -%}
  sections/main-cart.liquid
  ----------------------------------------------------------------------
  Sezione carrello Kombat Zone. Da usare in templates/cart.json (o
  templates/cart.liquid con {% section 'main-cart' %}).

  Nota: l'header/nav del mockup non è incluso qui perché normalmente
  fa parte di sections/header.liquid nel layout del tema.

  Dipendenze esterne: Tabler Icons (classi "ti ti-*") e i font Google
  "Barlow Condensed" e "Inter", caricati qui sotto via <link>. Se il
  tema li carica già a livello globale, questi tag possono essere rimossi.

  Dipendenza interna: sections/cart-upsell-recommendations.liquid, usata
  per renderizzare i prodotti "Spesso aggiunto insieme" tramite le product
  recommendations native di Shopify (vedi quel file per i dettagli).
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">

<style>
  #shopify-section-{{ section.id }} .kz-cart-section {
    background: #0a0a0a;
    font-family: 'Inter', sans-serif;
    color: #F2F0EB;
    font-size: 13px;
  }
  #shopify-section-{{ section.id }} .kz-page-header {
    background: #111111;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 22px 24px 18px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .kz-page-title-block { display: flex; flex-direction: column; gap: 6px; }
  #shopify-section-{{ section.id }} .kz-page-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: .02em;
  }
  #shopify-section-{{ section.id }} .kz-page-title span { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-page-subtitle {
    font-size: 12px;
    color: #888880;
    letter-spacing: .01em;
    line-height: 1.4;
    max-width: 420px;
  }
  #shopify-section-{{ section.id }} .kz-page-subtitle strong { color: #F2F0EB; font-weight: 600; }
  #shopify-section-{{ section.id }} .kz-item-count {
    font-size: 11px;
    color: #888880;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding-bottom: 4px;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .kz-cart-body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 0;
    align-items: start;
  }
  #shopify-section-{{ section.id }} .kz-cart-items {
    padding: 0;
    border-right: 1px solid rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .kz-promo-bar {
    background: #E8272A;
    padding: 9px 24px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background .2s;
  }
  #shopify-section-{{ section.id }} .kz-promo-bar i { font-size: 14px; }
  #shopify-section-{{ section.id }} .kz-promo-bar.is-unlocked {
    background: rgba(76,187,122,0.12);
    color: #4cbb7a;
    border-bottom: 1px solid rgba(76,187,122,0.25);
  }
  #shopify-section-{{ section.id }} .kz-promo-bar.is-unlocked i { color: #4cbb7a; }
  #shopify-section-{{ section.id }} .kz-cart-item {
    display: grid;
    grid-template-columns: 104px 1fr auto;
    gap: 18px;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    align-items: center;
    background: #0a0a0a;
    transition: background .15s;
  }
  #shopify-section-{{ section.id }} .kz-cart-item:hover { background: #111; }
  #shopify-section-{{ section.id }} .kz-item-img {
    background: #141414;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 8px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
    overflow: hidden;
    transition: border-color .2s;
  }
  #shopify-section-{{ section.id }} .kz-cart-item:hover .kz-item-img { border-color: rgba(232,39,42,0.4); }
  #shopify-section-{{ section.id }} .kz-item-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ section.id }} .kz-item-img i { font-size: 30px; color: rgba(255,255,255,0.12); }
  #shopify-section-{{ section.id }} .kz-item-badge {
    position: absolute;
    top: 5px;
    left: 5px;
    background: #E8272A;
    color: #fff;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 4px;
    line-height: 1.4;
  }
  #shopify-section-{{ section.id }} .kz-item-info { display: flex; flex-direction: column; gap: 5px; }
  #shopify-section-{{ section.id }} .kz-item-cat {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #E8272A;
  }
  #shopify-section-{{ section.id }} .kz-item-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 19px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .01em;
    line-height: 1.1;
    color: #F2F0EB;
    display: block;
    transition: color .15s;
  }
  #shopify-section-{{ section.id }} .kz-item-name:hover { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-top: 2px;
  }
  #shopify-section-{{ section.id }} .kz-item-size {
    font-size: 10px;
    color: #888880;
    letter-spacing: .06em;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 2px 7px;
  }
  #shopify-section-{{ section.id }} .kz-item-size-select {
    font-size: 10px;
    color: #F2F0EB;
    letter-spacing: .06em;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 3px 6px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    max-width: 160px;
  }
  #shopify-section-{{ section.id }} .kz-item-size-select:focus { outline: 1px solid #E8272A; }
  #shopify-section-{{ section.id }} .kz-custom-tag {
    font-size: 9px;
    color: #C9992A;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: rgba(201,153,42,0.1);
    border: 1px solid rgba(201,153,42,0.2);
    padding: 2px 6px;
  }
  #shopify-section-{{ section.id }} .kz-item-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .kz-item-price-main {
    font-size: 16px;
    font-weight: 600;
    color: #F2F0EB;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .kz-item-price-was {
    font-size: 11px;
    color: #4a4a44;
    text-decoration: line-through;
  }
  #shopify-section-{{ section.id }} .kz-item-save {
    font-size: 9px;
    font-weight: 700;
    color: #E8272A;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .kz-qty {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.1);
  }
  #shopify-section-{{ section.id }} .kz-qty-btn {
    background: #1a1a1a;
    border: none;
    color: #888880;
    width: 26px;
    height: 26px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-family: 'Inter', sans-serif;
  }
  #shopify-section-{{ section.id }} .kz-qty-btn:hover { background: #242424; color: #F2F0EB; }
  #shopify-section-{{ section.id }} .kz-qty-val {
    background: #111;
    color: #F2F0EB;
    font-size: 12px;
    font-weight: 600;
    width: 30px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid rgba(255,255,255,0.07);
    border-right: 1px solid rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .kz-remove-btn {
    background: none;
    border: none;
    color: #4a4a44;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 0;
  }
  #shopify-section-{{ section.id }} .kz-remove-btn:hover { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-free-gift {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 16px;
    padding: 14px 24px;
    background: rgba(201,153,42,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    align-items: center;
    border-left: 3px solid #C9992A;
  }
  #shopify-section-{{ section.id }} .kz-free-gift-img {
    background: #1a1a1a;
    border: 1px solid rgba(201,153,42,0.2);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kz-free-gift-img img { width: 100%; height: 100%; object-fit: cover; }
  #shopify-section-{{ section.id }} .kz-free-gift-img i { font-size: 24px; color: rgba(201,153,42,0.3); }
  #shopify-section-{{ section.id }} .kz-free-tag {
    font-size: 9px;
    font-weight: 700;
    color: #C9992A;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .kz-free-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    color: #F2F0EB;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .kz-free-desc { font-size: 10px; color: #888880; }
  #shopify-section-{{ section.id }} .kz-sidebar {
    padding: 20px 20px;
    background: #0f0f0f;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  #shopify-section-{{ section.id }} .kz-coupon-wrap { display: flex; gap: 0; margin-bottom: 18px; }
  #shopify-section-{{ section.id }} .kz-coupon-input {
    flex: 1;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    border-right: none;
    border-radius: 4px 0 0 4px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    padding: 9px 12px;
    letter-spacing: .06em;
    text-transform: uppercase;
    outline: none;
    transition: border-color .15s;
  }
  #shopify-section-{{ section.id }} .kz-coupon-input:focus { border-color: rgba(232,39,42,0.5); }
  #shopify-section-{{ section.id }} .kz-coupon-input::placeholder { color: #4a4a44; }
  #shopify-section-{{ section.id }} .kz-coupon-btn {
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0 4px 4px 0;
    color: #888880;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 9px 14px;
    cursor: pointer;
    white-space: nowrap;
    transition: background .15s, color .15s;
  }
  #shopify-section-{{ section.id }} .kz-coupon-btn:hover { background: #242424; color: #F2F0EB; }
  #shopify-section-{{ section.id }} .kz-coupon-btn.is-loading { opacity: .6; cursor: wait; }
  #shopify-section-{{ section.id }} .kz-coupon-msg {
    font-size: 11px;
    margin: -10px 0 14px;
    display: none;
  }
  #shopify-section-{{ section.id }} .kz-coupon-msg.show { display: block; }
  #shopify-section-{{ section.id }} .kz-coupon-msg.success { color: #7cd992; }
  #shopify-section-{{ section.id }} .kz-coupon-msg.error { color: #e57373; }
  #shopify-section-{{ section.id }} .kz-summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 9px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 12px;
  }
  #shopify-section-{{ section.id }} .kz-summary-label { color: #888880; }
  #shopify-section-{{ section.id }} .kz-summary-val { color: #F2F0EB; font-weight: 500; }
  #shopify-section-{{ section.id }} .kz-summary-val.green { color: #4cbb7a; }
  #shopify-section-{{ section.id }} .kz-summary-val.red { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-summary-hype {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(76,187,122,0.08);
    border: 1px solid rgba(76,187,122,0.2);
    color: #4cbb7a;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: .02em;
    padding: 8px 10px;
    margin-top: 10px;
    border-radius: 4px;
  }
  #shopify-section-{{ section.id }} .kz-summary-hype i { font-size: 13px; }
  #shopify-section-{{ section.id }} .kz-summary-hype strong { font-weight: 800; }
  #shopify-section-{{ section.id }} .kz-summary-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 14px 0 16px;
  }
  #shopify-section-{{ section.id }} .kz-total-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: #F2F0EB;
  }
  #shopify-section-{{ section.id }} .kz-total-val {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 900;
    color: #F2F0EB;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .kz-checkout-btn {
    width: 100%;
    background: #E8272A;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 14px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 10px;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  #shopify-section-{{ section.id }} .kz-checkout-btn:hover {
    background: #c41f22;
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(232,39,42,0.35);
  }
  #shopify-section-{{ section.id }} .kz-checkout-btn:active { transform: translateY(0); box-shadow: none; }
  #shopify-section-{{ section.id }} .kz-paypal-btn-wrap { margin-bottom: 16px; }
  #shopify-section-{{ section.id }} .kz-trust-mini {
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .kz-trust-mini-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    color: #888880;
    letter-spacing: .04em;
  }
  #shopify-section-{{ section.id }} .kz-trust-mini-item i { color: #E8272A; font-size: 14px; }
  #shopify-section-{{ section.id }} .kz-progress-bar-wrap { background: #1a1a1a; height: 3px; margin: 0 0 6px; }
  #shopify-section-{{ section.id }} .kz-progress-bar { background: #E8272A; height: 3px; transition: background .2s; }
  #shopify-section-{{ section.id }} .kz-progress-bar.is-complete { background: #4cbb7a; }
  #shopify-section-{{ section.id }} .kz-free-shipping-msg {
    font-size: 10px;
    color: #888880;
    letter-spacing: .04em;
    margin-bottom: 16px;
  }
  #shopify-section-{{ section.id }} .kz-free-shipping-msg strong { color: #4cbb7a; }
  /*
    Le regole .kz-card / .kz-also-* qui sotto NON sono scoperte a
    #shopify-section-{{ section.id }} perché le card vengono iniettate via
    fetch (section.id diverso). Usano le stesse classi della collection page
    (kz2-collection.css) così la card è identica pixel per pixel.
    Se kz2-collection.css è già caricato globalmente nel layout, questo
    blocco è ridondante ma non causa conflitti.
  */

  /* ── Variabili condivise (no-op se già definite da kz2-collection.css) ── */
  :root {
    --kz-red:    #E8272A;
    --kz-dark:   #0a0a0a;
    --kz-card:   #141414;
    --kz-border: #222;
  }

  /* ── Sezione contenitore upsell ── */
  .kz-also-like {
    padding: 18px 24px 22px;
    border-top: 1px solid rgba(255,255,255,0.07);
    background: linear-gradient(180deg, rgba(232,39,42,0.04), transparent 60%);
  }
  .kz-also-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 4px;
    gap: 10px;
  }
  .kz-also-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 900;
    letter-spacing: .01em;
    text-transform: uppercase;
    color: #F2F0EB;
    margin: 0;
  }
  .kz-also-title span { color: #E8272A; }
  .kz-also-subtitle {
    font-size: 10.5px;
    color: #888880;
    letter-spacing: .01em;
    margin: 0 0 12px;
  }
  .kz-also-scroll-wrap { position: relative; }
  .kz-also-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.12);
    color: #888880;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 14px;
    transition: color .15s, background .15s;
  }
  .kz-also-arrow:hover { background: #242424; color: #F2F0EB; }
  .kz-also-arrow.left  { left: -10px; }
  .kz-also-arrow.right { right: -10px; }
  .kz-also-arrow[hidden] { display: none; }

  /* Griglia orizzontale scrollabile */
  .kz-also-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    justify-content: center;
    gap: 10px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }
  .kz-also-grid::-webkit-scrollbar { display: none; }
  .kz-also-grid > * { display: contents; }

  /* Larghezza fissa card nel carrello — Liquid token */
  .kz-also-grid .kz-also-card {
    flex: 0 0 {{ section.settings.upsell_card_size }}px !important;
    min-width: 0;
    display: flex !important;
  }
  .kz-also-grid.kz-size-normal .kz-also-card { flex-basis: 160px !important; }

  /* ── Card identica a kz2-product-card ── */
  .kz-card {
    background: var(--kz-card);
    border: 1px solid var(--kz-border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color .2s;
    display: flex;
    flex-direction: column;
  }
  .kz-card:hover { border-color: var(--kz-red); }

  .kz-card__image-wrap {
    display: block;
    background: #0f0f0f;
    position: relative;
    text-decoration: none;
    flex-shrink: 0;
    aspect-ratio: 1 / 1;
    height: auto;
    border-radius: 10px 10px 0 0;
    overflow: hidden;
  }
  .kz-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .kz-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 52px;
  }
  .kz-card__image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(transparent, var(--kz-card));
    pointer-events: none;
    z-index: 1;
  }
  .kz-card__badge {
    position: absolute;
    top: 8px;
    left: 8px;
    color: #fff;
    font-size: 10px;
    font-weight: 800;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: .06em;
    line-height: 1;
    z-index: 2;
  }
  .kz-card__bestseller-label {
    position: absolute;
    top: 0; left: 0; right: 0;
    background: var(--kz-red);
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    text-align: center;
    padding: 4px;
    letter-spacing: .1em;
    text-transform: uppercase;
    z-index: 3;
  }
  .kz-card__stock-badge {
    position: absolute;
    bottom: 8px; left: 8px;
    background: rgba(10,10,10,.88);
    border: 0.5px solid var(--kz-red);
    color: #e57373;
    font-size: 9px;
    font-weight: 600;

{%- comment -%}
  sections/main-cart.liquid
  ----------------------------------------------------------------------
  Sezione carrello Kombat Zone. Da usare in templates/cart.json (o
  templates/cart.liquid con {% section 'main-cart' %}).

  Nota: l'header/nav del mockup non è incluso qui perché normalmente
  fa parte di sections/header.liquid nel layout del tema.

  Dipendenze esterne: Tabler Icons (classi "ti ti-*") e i font Google
  "Barlow Condensed" e "Inter", caricati qui sotto via <link>. Se il
  tema li carica già a livello globale, questi tag possono essere rimossi.

  Dipendenza interna: sections/cart-upsell-recommendations.liquid, usata
  per renderizzare i prodotti "Spesso aggiunto insieme" tramite le product
  recommendations native di Shopify (vedi quel file per i dettagli).
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">

<style>
  #shopify-section-{{ section.id }} .kz-cart-section {
    background: #0a0a0a;
    font-family: 'Inter', sans-serif;
    color: #F2F0EB;
    font-size: 13px;
  }
  #shopify-section-{{ section.id }} .kz-page-header {
    background: #111111;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 22px 24px 18px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .kz-page-title-block { display: flex; flex-direction: column; gap: 6px; }
  #shopify-section-{{ section.id }} .kz-page-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: .02em;
  }
  #shopify-section-{{ section.id }} .kz-page-title span { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-page-subtitle {
    font-size: 12px;
    color: #888880;
    letter-spacing: .01em;
    line-height: 1.4;
    max-width: 420px;
  }
  #shopify-section-{{ section.id }} .kz-page-subtitle strong { color: #F2F0EB; font-weight: 600; }
  #shopify-section-{{ section.id }} .kz-item-count {
    font-size: 11px;
    color: #888880;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding-bottom: 4px;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .kz-cart-body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 0;
    align-items: start;
  }
  #shopify-section-{{ section.id }} .kz-cart-items {
    padding: 0;
    border-right: 1px solid rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .kz-promo-bar {
    background: #E8272A;
    padding: 9px 24px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background .2s;
  }
  #shopify-section-{{ section.id }} .kz-promo-bar i { font-size: 14px; }
  #shopify-section-{{ section.id }} .kz-promo-bar.is-unlocked {
    background: rgba(76,187,122,0.12);
    color: #4cbb7a;
    border-bottom: 1px solid rgba(76,187,122,0.25);
  }
  #shopify-section-{{ section.id }} .kz-promo-bar.is-unlocked i { color: #4cbb7a; }
  #shopify-section-{{ section.id }} .kz-cart-item {
    display: grid;
    grid-template-columns: 104px 1fr auto;
    gap: 18px;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    align-items: center;
    background: #0a0a0a;
    transition: background .15s;
  }
  #shopify-section-{{ section.id }} .kz-cart-item:hover { background: #111; }
  #shopify-section-{{ section.id }} .kz-item-img {
    background: #141414;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 8px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
    overflow: hidden;
    transition: border-color .2s;
  }
  #shopify-section-{{ section.id }} .kz-cart-item:hover .kz-item-img { border-color: rgba(232,39,42,0.4); }
  #shopify-section-{{ section.id }} .kz-item-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ section.id }} .kz-item-img i { font-size: 30px; color: rgba(255,255,255,0.12); }
  #shopify-section-{{ section.id }} .kz-item-badge {
    position: absolute;
    top: 5px;
    left: 5px;
    background: #E8272A;
    color: #fff;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 4px;
    line-height: 1.4;
  }
  #shopify-section-{{ section.id }} .kz-item-info { display: flex; flex-direction: column; gap: 5px; }
  #shopify-section-{{ section.id }} .kz-item-cat {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #E8272A;
  }
  #shopify-section-{{ section.id }} .kz-item-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 19px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .01em;
    line-height: 1.1;
    color: #F2F0EB;
    display: block;
    transition: color .15s;
  }
  #shopify-section-{{ section.id }} .kz-item-name:hover { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-top: 2px;
  }
  #shopify-section-{{ section.id }} .kz-item-size {
    font-size: 10px;
    color: #888880;
    letter-spacing: .06em;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 2px 7px;
  }
  #shopify-section-{{ section.id }} .kz-item-size-select {
    font-size: 10px;
    color: #F2F0EB;
    letter-spacing: .06em;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 3px 6px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    max-width: 160px;
  }
  #shopify-section-{{ section.id }} .kz-item-size-select:focus { outline: 1px solid #E8272A; }
  #shopify-section-{{ section.id }} .kz-custom-tag {
    font-size: 9px;
    color: #C9992A;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: rgba(201,153,42,0.1);
    border: 1px solid rgba(201,153,42,0.2);
    padding: 2px 6px;
  }
  #shopify-section-{{ section.id }} .kz-item-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .kz-item-price-main {
    font-size: 16px;
    font-weight: 600;
    color: #F2F0EB;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .kz-item-price-was {
    font-size: 11px;
    color: #4a4a44;
    text-decoration: line-through;
  }
  #shopify-section-{{ section.id }} .kz-item-save {
    font-size: 9px;
    font-weight: 700;
    color: #E8272A;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .kz-item-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .kz-qty {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 8px;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kz-qty-btn {
    background: #1a1a1a;
    border: none;
    color: #888880;
    width: 30px;
    height: 30px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-family: 'Inter', sans-serif;
    transition: background .15s, color .15s;
  }
  #shopify-section-{{ section.id }} .kz-qty-btn:hover { background: #242424; color: #F2F0EB; }
  #shopify-section-{{ section.id }} .kz-qty-btn:active { background: #E8272A; color: #fff; }
  #shopify-section-{{ section.id }} .kz-qty-val {
    background: #111;
    color: #F2F0EB;
    font-size: 13px;
    font-weight: 600;
    width: 34px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid rgba(255,255,255,0.07);
    border-right: 1px solid rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .kz-remove-btn {
    background: none;
    border: none;
    color: #3f3f3a;
    opacity: .75;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: 'Inter', sans-serif;
    font-size: 8.5px;
    font-weight: 500;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: 4px 2px;
    transition: color .15s, opacity .15s;
  }
  #shopify-section-{{ section.id }} .kz-remove-btn:hover {
    color: #8a8a80;
    opacity: 1;
  }
  #shopify-section-{{ section.id }} .kz-delivery-estimate {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 10.5px;
    color: #888880;
    letter-spacing: .03em;
    margin: 2px 0 12px;
  }
  #shopify-section-{{ section.id }} .kz-delivery-estimate i { color: #4cbb7a; font-size: 14px; }
  #shopify-section-{{ section.id }} .kz-delivery-estimate strong { color: #F2F0EB; font-weight: 600; }
  #shopify-section-{{ section.id }} .kz-cart-sticky { display: none; }
  #shopify-section-{{ section.id }} .kz-free-gift {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 16px;
    padding: 14px 24px;
    background: rgba(201,153,42,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    align-items: center;
    border-left: 3px solid #C9992A;
  }
  #shopify-section-{{ section.id }} .kz-free-gift-img {
    background: #1a1a1a;
    border: 1px solid rgba(201,153,42,0.2);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kz-free-gift-img img { width: 100%; height: 100%; object-fit: cover; }
  #shopify-section-{{ section.id }} .kz-free-gift-img i { font-size: 24px; color: rgba(201,153,42,0.3); }
  #shopify-section-{{ section.id }} .kz-free-tag {
    font-size: 9px;
    font-weight: 700;
    color: #C9992A;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .kz-free-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    color: #F2F0EB;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .kz-free-desc { font-size: 10px; color: #888880; }
  #shopify-section-{{ section.id }} .kz-sidebar {
    padding: 20px 20px;
    background: #0f0f0f;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  #shopify-section-{{ section.id }} .kz-coupon-wrap { display: flex; gap: 0; margin-bottom: 18px; }
  #shopify-section-{{ section.id }} .kz-coupon-input {
    flex: 1;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    border-right: none;
    border-radius: 4px 0 0 4px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    padding: 9px 12px;
    letter-spacing: .06em;
    text-transform: uppercase;
    outline: none;
    transition: border-color .15s;
  }
  #shopify-section-{{ section.id }} .kz-coupon-input:focus { border-color: rgba(232,39,42,0.5); }
  #shopify-section-{{ section.id }} .kz-coupon-input::placeholder { color: #4a4a44; }
  #shopify-section-{{ section.id }} .kz-coupon-btn {
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0 4px 4px 0;
    color: #888880;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 9px 14px;
    cursor: pointer;
    white-space: nowrap;
    transition: background .15s, color .15s;
  }
  #shopify-section-{{ section.id }} .kz-coupon-btn:hover { background: #242424; color: #F2F0EB; }
  #shopify-section-{{ section.id }} .kz-coupon-btn.is-loading { opacity: .6; cursor: wait; }
  #shopify-section-{{ section.id }} .kz-coupon-msg {
    font-size: 11px;
    margin: -10px 0 14px;
    display: none;
  }
  #shopify-section-{{ section.id }} .kz-coupon-msg.show { display: block; }
  #shopify-section-{{ section.id }} .kz-coupon-msg.success { color: #7cd992; }
  #shopify-section-{{ section.id }} .kz-coupon-msg.error { color: #e57373; }
  #shopify-section-{{ section.id }} .kz-coupon-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 10px 0 4px;
  }
  #shopify-section-{{ section.id }} .kz-coupon-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(232,39,42,0.07);
    border: 1px solid #E8272A;
    border-radius: 99px;
    padding: 5px 6px 5px 14px;
  }
  #shopify-section-{{ section.id }} .kz-coupon-tag-code {
    font-family: 'Inter', sans-serif;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #E8272A;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .kz-coupon-tag-x {
    background: none;
    border: none;
    color: #E8272A;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    padding: 0;
    transition: background .15s, color .15s;
  }
  #shopify-section-{{ section.id }} .kz-coupon-tag-x:hover { background: #E8272A; color: #fff; }
  #shopify-section-{{ section.id }} .kz-summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 9px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 12px;
  }
  #shopify-section-{{ section.id }} .kz-summary-label { color: #888880; }
  #shopify-section-{{ section.id }} .kz-summary-val { color: #F2F0EB; font-weight: 500; }
  #shopify-section-{{ section.id }} .kz-summary-val.green { color: #4cbb7a; }
  #shopify-section-{{ section.id }} .kz-summary-val.red { color: #E8272A; }
  #shopify-section-{{ section.id }} .kz-summary-hype {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(76,187,122,0.08);
    border: 1px solid rgba(76,187,122,0.2);
    color: #4cbb7a;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: .02em;
    padding: 8px 10px;
    margin-top: 10px;
    border-radius: 4px;
  }
  #shopify-section-{{ section.id }} .kz-summary-hype i { font-size: 13px; }
  #shopify-section-{{ section.id }} .kz-summary-hype strong { font-weight: 800; }
  #shopify-section-{{ section.id }} .kz-summary-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 14px 0 16px;
  }
  #shopify-section-{{ section.id }} .kz-total-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: #F2F0EB;
  }
  #shopify-section-{{ section.id }} .kz-total-val {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 900;
    color: #F2F0EB;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .kz-checkout-btn {
    width: 100%;
    background: #E8272A;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 14px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 10px;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  #shopify-section-{{ section.id }} .kz-checkout-btn:hover {
    background: #c41f22;
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(232,39,42,0.35);
  }
  #shopify-section-{{ section.id }} .kz-checkout-btn:active { transform: translateY(0); box-shadow: none; }
  #shopify-section-{{ section.id }} .kz-paypal-btn-wrap { margin-bottom: 16px; }
  #shopify-section-{{ section.id }} .kz-trust-mini {
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .kz-trust-mini-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    color: #888880;
    letter-spacing: .04em;
  }
  #shopify-section-{{ section.id }} .kz-trust-mini-item i { color: #E8272A; font-size: 14px; }
  #shopify-section-{{ section.id }} .kz-progress-bar-wrap { background: #1a1a1a; height: 3px; margin: 10px 0 12px; }
  #shopify-section-{{ section.id }} .kz-progress-bar { background: #E8272A; height: 3px; transition: background .2s; position: relative; min-width: 14px; }
  #shopify-section-{{ section.id }} .kz-progress-bar.is-complete { background: #4cbb7a; }
  #shopify-section-{{ section.id }} .kz-progress-truck {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translate(50%, -50%);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #0a0a0a;
    border: 2px solid #E8272A;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #E8272A;
    font-size: 12px;
    transition: border-color .2s, color .2s;
    z-index: 1;
  }
  #shopify-section-{{ section.id }} .kz-progress-bar.is-complete .kz-progress-truck { border-color: #4cbb7a; color: #4cbb7a; }
  #shopify-section-{{ section.id }} .kz-free-shipping-msg {
    font-size: 10px;
    color: #888880;
    letter-spacing: .04em;
    margin-bottom: 16px;
  }
  #shopify-section-{{ section.id }} .kz-free-shipping-msg strong { color: #4cbb7a; }
  /*
    Le regole .kz-card / .kz-also-* qui sotto NON sono scoperte a
    #shopify-section-{{ section.id }} perché le card vengono iniettate via
    fetch (section.id diverso). Usano le stesse classi della collection page
    (kz2-collection.css) così la card è identica pixel per pixel.
    Se kz2-collection.css è già caricato globalmente nel layout, questo
    blocco è ridondante ma non causa conflitti.
  */

  /* ── Variabili condivise (no-op se già definite da kz2-collection.css) ── */
  :root {
    --kz-red:    #E8272A;
    --kz-dark:   #0a0a0a;
    --kz-card:   #141414;
    --kz-border: #222;
  }

  /* ── Sezione contenitore upsell ── */
  .kz-also-like {
    padding: 18px 24px 22px;
    border-top: 1px solid rgba(255,255,255,0.07);
    background: linear-gradient(180deg, rgba(232,39,42,0.04), transparent 60%);
  }
  .kz-also-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 4px;
    gap: 10px;
  }
  .kz-also-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 900;
    letter-spacing: .01em;
    text-transform: uppercase;
    color: #F2F0EB;
    margin: 0;
  }
  .kz-also-title span { color: #E8272A; }
  .kz-also-subtitle {
    font-size: 10.5px;
    color: #888880;
    letter-spacing: .01em;
    margin: 0 0 12px;
  }
  .kz-also-scroll-wrap { position: relative; }
  .kz-also-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.12);
    color: #888880;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 14px;
    transition: color .15s, background .15s;
  }
  .kz-also-arrow:hover { background: #242424; color: #F2F0EB; }
  .kz-also-arrow.left  { left: -10px; }
  .kz-also-arrow.right { right: -10px; }
  .kz-also-arrow[hidden] { display: none; }

  /* Griglia orizzontale scrollabile */
  .kz-also-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    justify-content: center;
    gap: 10px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }
  .kz-also-grid::-webkit-scrollbar { display: none; }
  .kz-also-grid > * { display: contents; }

  /* Larghezza fissa card nel carrello — Liquid token */
  .kz-also-grid .kz-also-card {
    flex: 0 0 {{ section.settings.upsell_card_size }}px !important;
    min-width: 0;
    display: flex !important;
  }
  .kz-also-grid.kz-size-normal .kz-also-card { flex-basis: 160px !important; }

  /* ── Card identica a kz2-product-card ── */
  .kz-card {
    background: var(--kz-card);
    border: 1px solid var(--kz-border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color .2s;
    display: flex;
    flex-direction: column;
  }
  .kz-card:hover { border-color: var(--kz-red); }

  .kz-card__image-wrap {
    display: block;
    background: #0f0f0f;
    position: relative;
    text-decoration: none;
    flex-shrink: 0;
    aspect-ratio: 1 / 1;
    height: auto;
    border-radius: 10px 10px 0 0;
    overflow: hidden;
  }
  .kz-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .kz-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 52px;
  }
  .kz-card__image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(transparent, var(--kz-card));
    pointer-events: none;
    z-index: 1;
  }
  .kz-card__badge {
    position: absolute;
    top: 8px;
    left: 8px;
    color: #fff;
    font-size: 10px;
    font-weight: 800;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: .06em;
    line-height: 1;
    z-index: 2;
  }
  .kz-card__bestseller-label {
    position: absolute;
    top: 0; left: 0; right: 0;
    background: var(--kz-red);
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    text-align: center;
    padding: 4px;
    letter-spacing: .1em;
    text-transform: uppercase;
    z-index: 3;
  }
  .kz-card__stock-badge {
    position: absolute;
    bottom: 8px; left: 8px;
    background: rgba(10,10,10,.88);
    border: 0.5px solid var(--kz-red);
    color: #e57373;
    font-size: 9px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 99px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 4px;
    letter-spacing: .03em;
  }
  .kz-card__stock-badge svg { width: 10px; height: 10px; flex-shrink: 0; }

  /* FAB carrello — identico alla collection */
  @keyframes kz-fab-enter {
    from { opacity: 0; transform: scale(0.6); }
    to   { opacity: 1; transform: scale(1); }
  }
  .kz-card__cart-fab {
    position: absolute;
    bottom: 10px; right: 10px;
    z-index: 4;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(0,0,0,0.6);
    border: 1.5px solid rgba(255,255,255,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    animation: kz-fab-enter 0.3s cubic-bezier(.4,0,.2,1) 0.3s both;
    transition: background .25s ease, border-color .25s ease,
                transform .25s ease, box-shadow .25s ease;
    padding: 0;
  }
  .kz-card__cart-fab:hover {
    background: #E8272A;
    border-color: #E8272A;
    transform: scale(1.12);
    box-shadow: 0 0 14px rgba(232,39,42,0.6);
  }
  .kz-card__cart-fab:active {
    transform: scale(0.95);
    box-shadow: 0 0 6px rgba(232,39,42,0.4);
  }
  .kz-card__cart-fab:disabled {
    background: rgba(0,0,0,0.6) !important;
    border-color: rgba(255,255,255,0.1) !important;
    box-shadow: none !important;
    cursor: not-allowed;
    opacity: 0.4;
    animation: none;
  }
  .kz-card__cart-fab svg {
    width: 18px; height: 18px;
    color: #fff;
    flex-shrink: 0;
    display: block;
  }

  /* Body testo */
  .kz-card__body {
    padding: 12px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .kz-card__type {
    font-size: 10px;
    color: var(--kz-red);
    font-weight: 700;
    letter-spacing: .08em;
    margin-bottom: 4px;
  }
  .kz-card__discipline {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 4px;
  }
  .kz-card__title {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
    line-height: 1.3;
    text-decoration: none;
    flex: 1;
  }
  .kz-card__title:hover { color: var(--kz-red); }
  .kz-card__name-badge {
    display: inline-block;
    background: rgba(232,39,42,.1);
    border: 0.5px solid rgba(232,39,42,.35);
    color: #e57373;
    font-size: 9px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 99px;
    margin-bottom: 8px;
    letter-spacing: .04em;
  }
  .kz-card__price {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .kz-card__price-current {
    font-size: 16px;
    font-weight: 800;
    color: #fff;
  }
  .kz-card__price-old {
    font-size: 12px;
    color: #555;
    text-decoration: line-through;
  }
  .kz-card__contenuto {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }
  .kz-card__pezzo {
    font-size: 10px;
    color: var(--kz-red);
    background: rgba(232,39,42,0.08);
    border: 0.5px solid rgba(232,39,42,0.25);
    border-radius: 99px;
    padding: 2px 8px;
    white-space: nowrap;
    letter-spacing: .02em;
  }
  /* Bottone ATC testuale — nascosto via CSS, usato dal modal JS */
  .kz-card__atc { display: none; }

  /* Mobile: FAB leggermente più piccolo */
  @media (max-width: 600px) {
    .kz-card__cart-fab { width: 28px; height: 28px; bottom: 7px; right: 7px; }
    .kz-card__cart-fab svg { width: 15px; height: 15px; }
  }
  #shopify-section-{{ section.id }} .kz-empty {
    padding: 80px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .kz-empty-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(232,39,42,0.08);
    border: 1px solid rgba(232,39,42,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #E8272A;
    font-size: 26px;
    margin-bottom: 20px;
  }
  #shopify-section-{{ section.id }} .kz-empty-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .02em;
    color: #F2F0EB;
    margin-bottom: 8px;
  }
  #shopify-section-{{ section.id }} .kz-empty-subtext {
    font-size: 12px;
    line-height: 1.6;
    color: #888880;
    max-width: 360px;
    margin: 0 0 26px;
  }
  #shopify-section-{{ section.id }} .kz-empty-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #E8272A;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 13px 24px;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .kz-empty-cta:hover { background: #c41f22; }
  #shopify-section-{{ section.id }} .kz-empty-also {
    width: 100%;
    max-width: 760px;
    margin-top: 36px;
    padding-top: 30px;
    border-top: 1px solid rgba(255,255,255,0.07);
    text-align: left;
  }
  #shopify-section-{{ section.id }} .kz-empty-also-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .02em;
    color: #F2F0EB;
    margin-bottom: 14px;
  }

  /* ----------------------------------------------------------------------
     Responsive: sotto i 900px la sidebar scende sotto la colonna prodotti
     invece di restare affiancata (sennò su mobile si sovrappongono).
     ---------------------------------------------------------------------- */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .kz-cart-body {
      grid-template-columns: 1fr;
    }
    #shopify-section-{{ section.id }} .kz-cart-items {
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
  }

  @media (max-width: 540px) {
    #shopify-section-{{ section.id }} .kz-page-header {
      padding: 16px 16px 14px;
    }
    #shopify-section-{{ section.id }} .kz-page-title { font-size: 26px; }
    #shopify-section-{{ section.id }} .kz-promo-bar,
    #shopify-section-{{ section.id }} .kz-cart-item,
    #shopify-section-{{ section.id }} .kz-also-like,
    #shopify-section-{{ section.id }} .kz-sidebar {
      padding-left: 16px;
      padding-right: 16px;
    }
    #shopify-section-{{ section.id }} .kz-cart-item {
      grid-template-columns: 76px 1fr;
      row-gap: 10px;
    }
    #shopify-section-{{ section.id }} .kz-item-img { width: 76px; height: 76px; }
    #shopify-section-{{ section.id }} .kz-item-right {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    #shopify-section-{{ section.id }} .kz-item-actions {
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
    }
    #shopify-section-{{ section.id }} .kz-qty-btn { width: 34px; height: 32px; }
    #shopify-section-{{ section.id }} .kz-qty-val { width: 36px; height: 32px; }
    /* Su mobile: griglia 2 colonne, le card vanno a capo dopo 2 per riga */
    .kz-also-grid {
      flex-wrap: wrap;
      justify-content: center;
      overflow-x: visible;
      gap: 8px;
    }
    .kz-also-grid .kz-also-card {
      flex: 0 0 calc(50% - 8px) !important;
      width: calc(50% - 8px);
      max-width: calc(50% - 8px);
    }
    #shopify-section-{{ section.id }} .kz-empty { padding: 56px 16px; }
    #shopify-section-{{ section.id }} .kz-empty-also { max-width: 100%; }

    /* Sticky checkout bar */
    #shopify-section-{{ section.id }} .kz-cart-section { padding-bottom: 66px; }
    #shopify-section-{{ section.id }} .kz-cart-sticky {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 998;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 10px 16px;
      padding-bottom: calc(10px + env(safe-area-inset-bottom));
      background: rgba(10,10,10,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1px solid rgba(255,255,255,0.08);
      transform: translateY(0);
      transition: transform .25s ease;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky.is-hidden { transform: translateY(110%); }
    #shopify-section-{{ section.id }} .kz-cart-sticky-total {
      display: flex;
      flex-direction: column;
      line-height: 1.15;
      flex-shrink: 0;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky-label {
      font-family: 'Inter', sans-serif;
      font-size: 8.5px;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #888880;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 21px;
      font-weight: 800;
      color: #F2F0EB;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky-btn {
      flex: 1;
      background: #E8272A;
      color: #fff;
      font-family: 'Inter', sans-serif;
      font-size: 11.5px;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      padding: 13px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      transition: background .2s ease, transform .15s ease;
    }
    #shopify-section-{{ section.id }} .kz-cart-sticky-btn:active { background: #c41f22; transform: scale(.98); }
  }
</style>

{%- assign free_shipping_threshold = section.settings.free_shipping_threshold -%}
{%- assign free_shipping_threshold_cents = free_shipping_threshold | times: 100 -%}
{%- assign remaining_cents = free_shipping_threshold_cents | minus: cart.original_total_price -%}
{%- if remaining_cents < 0 -%}{%- assign remaining_cents = 0 -%}{%- endif -%}
{%- assign progress_pct = cart.original_total_price | times: 100.0 | divided_by: free_shipping_threshold_cents -%}
{%- if progress_pct > 100 -%}{%- assign progress_pct = 100 -%}{%- endif -%}

{%- comment -%} Raccolta trust badge dai blocks della section, passata allo snippet cart-summary {%- endcomment -%}
{%- assign trust_badges = '' -%}
{%- capture trust_badges_json -%}
  [
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust_badge' -%}
        {"icon":{{ block.settings.icon | json }},"text":{{ block.settings.text | json }}}{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
{%- endcapture -%}
{%- assign trust_badges = trust_badges_json | strip_newlines | strip -%}

<div class="kz-cart-section" id="kz-cart-section-wrapper" data-section-id="{{ section.id }}">

  <div class="kz-page-header">
    <div class="kz-page-title-block">
      <div class="kz-page-title">{{ section.settings.page_title }}<br><span>{{ section.settings.page_title_accent }}</span></div>
      {%- if cart.item_count > 0 -%}
        <div class="kz-page-subtitle">
          {%- if remaining_cents == 0 -%}
            {{ section.settings.subtitle_unlocked | default: "Spedizione gratuita sbloccata. Sei a un passo dal completare l'equipaggiamento." }}
          {%- else -%}
            {{ section.settings.subtitle_default | default: "Controlla l'equipaggiamento, poi passa al" }} <strong>{{ section.settings.subtitle_default_bold | default: "checkout" }}</strong>.
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="kz-page-subtitle">{{ section.settings.subtitle_empty | default: "Il tuo prossimo allenamento inizia da qui." }}</div>
      {%- endif -%}
    </div>
    <div class="kz-item-count">{{ cart.item_count }} articol{% if cart.item_count == 1 %}o{% else %}i{% endif %}</div>
  </div>

  {%- if cart.item_count == 0 -%}

    {%- comment -%}
      "Potrebbero interessarti...": griglia prodotti dalla collezione scelta
      nelle impostazioni della sezione (es. una collezione "Best seller").
      Niente seed product (il carrello è vuoto, non c'è nulla da cui partire
      come con le product recommendations native), quindi qui usiamo una
      collezione configurata a mano una volta sola.
    {%- endcomment -%}
    {%- assign empty_collection = section.settings.empty_cart_collection -%}

    <div class="kz-empty">
      <div class="kz-empty-icon"><i class="ti ti-shopping-bag-x" aria-hidden="true"></i></div>
      <div class="kz-empty-heading">{{ section.settings.empty_cart_heading }}</div>
      {%- if section.settings.empty_cart_subtext != blank -%}
        <p class="kz-empty-subtext">{{ section.settings.empty_cart_subtext }}</p>
      {%- endif -%}
      <a href="{{ section.settings.empty_cart_button_link | default: routes.all_products_collection_url }}" class="kz-empty-cta">
        {{ section.settings.empty_cart_button_label }}
        <i class="ti ti-arrow-right" aria-hidden="true"></i>
      </a>

      {%- if empty_collection != blank and empty_collection.products.size > 0 -%}
        <div class="kz-empty-also">
          <div class="kz-empty-also-title">{{ section.settings.empty_cart_recommend_heading }}</div>
          <div class="kz-also-grid">
            {%- for product in empty_collection.products limit: section.settings.empty_cart_recommend_limit -%}
              {%- render 'upsell-product-card', product: product -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

  {%- else -%}

    <div class="kz-cart-body">
      <div class="kz-cart-items">

        {%- if remaining_cents == 0 -%}
          <div class="kz-promo-bar is-unlocked">
            <i class="ti ti-circle-check" aria-hidden="true"></i>
            {{ section.settings.promo_bar_unlocked_text | default: "Spedizione gratuita sbloccata — sei pronto per il checkout" }}
          </div>
        {%- elsif section.settings.promo_bar_text != blank -%}
          <div class="kz-promo-bar">
            <i class="ti ti-clock" aria-hidden="true"></i>
            {{ section.settings.promo_bar_text }}
            &nbsp;·&nbsp; Hai ancora <strong style="text-decoration:underline;">{{ remaining_cents | money }}</strong> al traguardo
          </div>
        {%- endif -%}

        <div style="padding: 10px 24px 0; background: #0a0a0a;">
          <div class="kz-progress-bar-wrap"><div class="kz-progress-bar{% if remaining_cents == 0 %} is-complete{% endif %}" style="width: {{ progress_pct }}%;"><span class="kz-progress-truck" aria-hidden="true"><i class="ti ti-truck-delivery"></i></span></div></div>
          <div class="kz-free-shipping-msg" data-free-shipping-msg>
            {%- if remaining_cents > 0 -%}
              Aggiungi <strong>{{ remaining_cents | money }} di prodotti</strong> per la spedizione gratuita
            {%- else -%}
              <strong>Hai sbloccato la spedizione gratuita!</strong>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Righe prodotto: l'omaggio automatico viene rilevato dentro lo snippet stesso {%- endcomment -%}
        {%- for item in cart.items -%}
          {%- render 'cart-item', item: item, item_index: forloop.index -%}
        {%- endfor -%}

        {%- comment -%}
          Upsell con le product recommendations native di Shopify, basate sul
          primo prodotto presente in carrello. Il container parte nascosto
          (display:none) e viene popolato via JS chiamando l'endpoint
          /recommendations/products, che renderizza sections/cart-upsell-
          recommendations.liquid lato server: niente collezione da gestire a mano.
        {%- endcomment -%}
        {%- if section.settings.show_upsells -%}
          {%- assign seed_product_id = cart.items.first.product_id -%}
          <div
            class="kz-also-like"
            data-upsell-root
            data-seed-id="{{ seed_product_id }}"
            data-limit="{{ section.settings.upsell_limit }}"
            data-intent="{{ section.settings.upsell_intent }}"
            style="display:none;"
          >

            <div class="kz-also-header">
              <div class="kz-also-title">
                {%- if section.settings.upsell_title != blank -%}
                  {{ section.settings.upsell_title }}
                {%- else -%}
                  Completa il tuo <span>setup</span>
                {%- endif -%}
              </div>
            </div>
            <div class="kz-also-subtitle">{{ section.settings.upsell_subtitle | default: "Chi ha preso questo articolo ha aggiunto anche:" }}</div>
            <div class="kz-also-scroll-wrap">
              <button class="kz-also-arrow left" data-upsell-arrow="left" aria-label="Scorri a sinistra" hidden>
                <i class="ti ti-chevron-left"></i>
              </button>
              <div class="kz-also-grid" data-upsell-grid></div>
              <button class="kz-also-arrow right" data-upsell-arrow="right" aria-label="Scorri a destra" hidden>
                <i class="ti ti-chevron-right"></i>
              </button>
            </div>
          </div>
        {%- endif -%}

      </div>

      {%- render 'cart-summary', free_shipping_threshold: free_shipping_threshold, trust_badges: trust_badges -%}

    </div>

    {%- comment -%} Sticky checkout — solo mobile, si nasconde quando il bottone reale è visibile {%- endcomment -%}
    <div class="kz-cart-sticky" data-cart-sticky>
      <div class="kz-cart-sticky-total">
        <span class="kz-cart-sticky-label">Totale</span>
        <span class="kz-cart-sticky-val">{{ cart.total_price | money }}</span>
      </div>
      <button type="submit" form="kz-cart-form" name="checkout" class="kz-cart-sticky-btn">
        <i class="ti ti-lock" aria-hidden="true"></i>
        Procedi al checkout
      </button>
    </div>

  {%- endif -%}
</div>

<script>
  (function () {
    var sectionId = {{ section.id | json }};

    var stickyObserver = null;
    function initStickyCheckout() {
      var sticky = document.querySelector('[data-cart-sticky]');
      var realBtn = document.querySelector('.kz-checkout-btn');
      if (!sticky || !realBtn || !('IntersectionObserver' in window)) return;
      if (stickyObserver) stickyObserver.disconnect();
      stickyObserver = new IntersectionObserver(function (entries) {
        sticky.classList.toggle('is-hidden', entries[0].isIntersecting);
      }, { rootMargin: '0px 0px -8% 0px' });
      stickyObserver.observe(realBtn);
    }
    initStickyCheckout();

    function loadUpsells() {
      var container = document.querySelector('[data-upsell-root]');
      if (!container) return;

      var seedId = container.dataset.seedId;
      if (!seedId) {
        container.style.display = 'none';
        return;
      }

      var limit = container.dataset.limit || 3;
      var intent = container.dataset.intent || 'related';
      var grid = container.querySelector('[data-upsell-grid]');

      var url = '/recommendations/products'
        + '?section_id=cart-upsell-recommendations'
        + '&product_id=' + encodeURIComponent(seedId)
        + '&limit=' + encodeURIComponent(limit)
        + '&intent=' + encodeURIComponent(intent);

      fetch(url)
        .then(function (r) { return r.text(); })
        .then(function (html) {
          html = html.trim();
          if (!html) {
            container.style.display = 'none';
            return;
          }
          /* Shopify wrappa la sezione in <div class="shopify-section">.
             Estraiamo solo le .kz-also-card per non rompere il flex layout. */
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var cards = doc.querySelectorAll('.kz-also-card');
          if (!cards.length) { container.style.display = 'none'; return; }
          grid.innerHTML = '';
          cards.forEach(function(card) { grid.appendChild(card); });
          container.style.display = '';
        })
        .catch(function (err) {
          console.error('Errore recupero prodotti consigliati:', err);
          container.style.display = 'none';
        });
    }

    function refreshSection() {
      fetch(window.location.pathname + '?sections=' + sectionId)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var html = data[sectionId];
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var newWrapper = doc.getElementById('kz-cart-section-wrapper');
          var oldWrapper = document.getElementById('kz-cart-section-wrapper');
          if (newWrapper && oldWrapper) {
            oldWrapper.replaceWith(newWrapper);
          }
          loadUpsells();
          initStickyCheckout();
          document.dispatchEvent(new CustomEvent('cart:updated'));
        });
    }

    function changeLine(line, quantity) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: quantity })
      })
        .then(function (r) { return r.json(); })
        .then(function () { refreshSection(); })
        .catch(function (err) { console.error('Errore aggiornamento carrello:', err); });
    }

    function addVariant(variantId) {
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
      })
        .then(function (r) { return r.json(); })
        .then(function () { refreshSection(); })
        .catch(function (err) { console.error('Errore aggiunta al carrello:', err); });
    }

    function changeVariant(line, newVariantId, quantity) {
      // Leggiamo il carrello per ottenere il key stabile della riga da rimuovere,
      // poi aggiungiamo la nuova variante e azzeriamo la vecchia tramite key.
      var oldKey = null;

      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          var oldItem = cart.items[line - 1]; // line è 1-based
          if (oldItem) oldKey = oldItem.key;
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ id: parseInt(newVariantId, 10), quantity: quantity }] })
          });
        })
        .then(function (r) { return r.json(); })
        .then(function () {
          if (!oldKey) return Promise.resolve();
          return fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: oldKey, quantity: 0 })
          });
        })
        .then(function () { refreshSection(); })
        .catch(function (err) { console.error('Errore cambio variante:', err); });
    }

    if (!window.kzCartHandlersBound) {
      window.kzCartHandlersBound = true;
      document.addEventListener('click', function (e) {
        var increaseBtn = e.target.closest('[data-qty-increase]');
        var decreaseBtn = e.target.closest('[data-qty-decrease]');
        var removeBtn = e.target.closest('[data-cart-remove]');
        var upsellBtn = e.target.closest('[data-upsell-add]');

        if (increaseBtn || decreaseBtn) {
          var row = (increaseBtn || decreaseBtn).closest('[data-cart-item]');
          if (!row) return;
          var line = parseInt(row.dataset.lineIndex, 10);
          var valueEl = row.querySelector('[data-qty-value]');
          var current = parseInt(valueEl.textContent, 10) || 1;
          var next = increaseBtn ? current + 1 : current - 1;
          if (next < 1) next = 0; // 0 rimuove la riga
          changeLine(line, next);
          return;
        }

        if (removeBtn) {
          var rowToRemove = removeBtn.closest('[data-cart-item]');
          if (!rowToRemove) return;
          var lineToRemove = parseInt(rowToRemove.dataset.lineIndex, 10);
          changeLine(lineToRemove, 0);
          return;
        }

        if (upsellBtn) {
          var card = upsellBtn.closest('[data-also-card]');
          var variantId = upsellBtn.dataset.variantId;
          if (!variantId && card) {
            var variantSelect = card.querySelector('[data-variant-select]');
            if (variantSelect) variantId = variantSelect.value;
          }
          if (variantId) addVariant(variantId);
          return;
        }
      });

      document.addEventListener('change', function (e) {
        var sizeSelect = e.target.closest('[data-variant-change]');
        if (!sizeSelect) return;
        var row = sizeSelect.closest('[data-cart-item]');
        if (!row) return;
        var line = parseInt(sizeSelect.dataset.lineIndex, 10);
        var newVariantId = sizeSelect.value;
        var valueEl = row.querySelector('[data-qty-value]');
        var quantity = valueEl ? (parseInt(valueEl.textContent, 10) || 1) : 1;
        changeVariant(line, newVariantId, quantity);
      });

      function kzFormatMoney(cents) {
        return '\u20AC' + (cents / 100).toFixed(2).replace('.', ',');
      }

      document.addEventListener('click', function (e) {
        var removeBtn = e.target.closest('[data-coupon-remove]');
        if (!removeBtn) return;
        removeBtn.disabled = true;
        removeBtn.style.opacity = '.5';
        fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ discount: '' })
        })
          .then(function () { refreshSection(); })
          .catch(function () {
            removeBtn.disabled = false;
            removeBtn.style.opacity = '';
          });
      });

      document.addEventListener('submit', function (e) {
        var couponForm = e.target.closest('[data-coupon-form]');
        if (!couponForm) return;
        e.preventDefault();

        var input = couponForm.querySelector('[data-coupon-input]');
        var code = input ? input.value.trim() : '';
        if (!code) return;

        var submitBtn = couponForm.querySelector('[data-coupon-submit]');
        var msgEl = document.querySelector('[data-coupon-msg]');

        function setMsg(el, text, type) {
          if (!el) return;
          el.textContent = text;
          el.className = 'kz-coupon-msg show' + (type ? ' ' + type : '');
        }

        if (submitBtn) { submitBtn.disabled = true; submitBtn.classList.add('is-loading'); }
        setMsg(msgEl, 'Verifica in corso…', '');

        // Il codice sconto va nel PATH dell'URL (non come query string).
        // Colpiamo /discount/CODICE con redirect verso la pagina corrente
        // (non /checkout): cosi lo sconto viene associato al carrello/sessione
        // ma l'utente resta sul carrello e vede solo il ricalcolo del totale,
        // senza essere portato automaticamente al checkout.
        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (cartBefore) {
            var discountBefore = cartBefore.total_discount;
            return fetch('/discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent(window.location.pathname))
              .then(function () { return fetch('/cart.js'); })
              .then(function (r) { return r.json(); })
              .then(function (cartAfter) {
                return fetch(window.location.pathname + '?section_id=cart-section')
                  .then(function (r) { return r.text(); })
                  .then(function (html) {
                    var doc = new DOMParser().parseFromString(html, 'text/html');
                    var freshSummary = doc.querySelector('[data-cart-summary]');
                    var currentSummary = document.querySelector('[data-cart-summary]');
                    if (freshSummary && currentSummary) {
                      currentSummary.replaceWith(freshSummary);
                    }
                    var newMsg = document.querySelector('[data-coupon-msg]');
                    var discountAfter = cartAfter.total_discount;
                    if (discountAfter > discountBefore) {
                      setMsg(newMsg, 'Codice applicato: risparmi ' + kzFormatMoney(discountAfter - discountBefore) + '.', 'success');
                    } else {
                      setMsg(newMsg, 'Codice non valido, scaduto o non applicabile a questo ordine.', 'error');
                    }
                  });
              });
          })
          .catch(function () {
            setMsg(msgEl, 'Errore durante la verifica del codice. Riprova.', 'error');
            if (submitBtn) { submitBtn.disabled = false; submitBtn.classList.remove('is-loading'); }
          });
      });
    }

    /* ── Bottone toggle dimensione card upsell ── */
    function initUpsellControls() {
      var root    = document.querySelector('[data-upsell-root]');
      if (!root) return;
      var grid    = root.querySelector('[data-upsell-grid]');
      var toggle  = root.querySelector('[data-upsell-size-toggle]');
      var label   = root.querySelector('[data-upsell-size-label]');
      var arrowL  = root.querySelector('[data-upsell-arrow="left"]');
      var arrowR  = root.querySelector('[data-upsell-arrow="right"]');
      if (!grid) return;

      /* Frecce scroll */
      var STEP = 140;
      function updateArrows() {
        if (!arrowL || !arrowR) return;
        var canScrollL = grid.scrollLeft > 4;
        var canScrollR = grid.scrollLeft + grid.clientWidth < grid.scrollWidth - 4;
        arrowL.hidden = !canScrollL;
        arrowR.hidden = !canScrollR;
      }
      if (arrowL) arrowL.addEventListener('click', function () { grid.scrollBy({ left: -STEP, behavior: 'smooth' }); });
      if (arrowR) arrowR.addEventListener('click', function () { grid.scrollBy({ left:  STEP, behavior: 'smooth' }); });
      grid.addEventListener('scroll', updateArrows);
      /* Aggiorna frecce dopo che le card sono nel DOM */
      setTimeout(updateArrows, 120);
    }

    /* Aspetta che loadUpsells inietti le card, poi inizializza i controlli */
    (function patchLoad() {
      var container = document.querySelector('[data-upsell-root]');
      if (!container) return;
      var grid = container.querySelector('[data-upsell-grid]');
      var observer = new MutationObserver(function (mutations) {
        if (mutations.some(function(m){ return m.addedNodes.length > 0; })) {
          observer.disconnect();
          initUpsellControls();
        }
      });
      if (grid) observer.observe(grid, { childList: true });
    })();
    loadUpsells();
  })();
</script>


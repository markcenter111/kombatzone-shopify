    color: #E8272A;
    font-size: 26px;
    margin-bottom: 20px;
  }
  #shopify-section-{{ section.id }} .kz-empty-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 900;
    text-transform: uppercase;

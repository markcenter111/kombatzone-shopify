{% comment %}
  KOMBAT ZONE — Product Page
  File: sections/kombatzone-product.liquid

  Pagina prodotto completa costruita seguendo "The Perfect Product Page Builder":
  tag prodotto, galleria immagini/video, opzioni/varianti, pricing, CTA,
  objection busters (garanzia/spedizione/USP), descrizione persuasiva,
  accordion (specifiche/spedizione/resi/FAQ), recensioni, correlati.

  Responsive: mobile (galleria sopra, buy box sotto) e desktop (2 colonne).
  Colori: sfondo scuro coerente col resto del sito (#0a0a0a / #111111), accento rosso #E8272A.
{% endcomment %}

{{ 'https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@400;500;600;700&display=swap' | stylesheet_tag }}

{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<style>
  .kzpr-wrap {
    background: {{ section.settings.bg_color }};
    padding: 40px 32px 0;
    font-family: 'Inter', sans-serif;
    color: #F2F0EB;
  }

  .kzpr-grid {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: start;
  }

  /* ---------- Breadcrumb / tag ---------- */
  .kzpr-tags {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .kzpr-tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 5px 10px;
    background: #E8272A;
    color: #fff;
  }

  .kzpr-tag.secondary {
    background: transparent;
    border: 1px solid rgba(242,240,235,0.25);
    color: #F2F0EB;
  }

  /* ---------- Gallery ---------- */
  .kzpr-gallery {
    position: sticky;
    top: 24px;
  }

  .kzpr-main-media {
    aspect-ratio: 1/1;
    background: #1a1a1a;
    overflow: hidden;
    margin-bottom: 8px;
    position: relative;
    border-radius: 12px;
  }

  .kzpr-main-media img,
  .kzpr-main-media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .5s cubic-bezier(.2, .6, .2, 1);
    backface-visibility: hidden;
  }
  .kzpr-main-media:hover img { transform: scale(1.03); }

  .kzpr-thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
  }

  .kzpr-thumb {
    aspect-ratio: 1/1;
    background: #1a1a1a;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    padding: 0;
    display: block;
    border-radius: 8px;
    transition: border-color .15s ease, transform .15s ease, opacity .15s ease;
    opacity: .75;
  }

  .kzpr-thumb:hover { opacity: 1; transform: translateY(-2px); }
  .kzpr-thumb.active { border-color: #E8272A; opacity: 1; }

  .kzpr-thumb img,
  .kzpr-thumb video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kzpr-placeholder-media {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    opacity: .15;
  }

  .kzpr-placeholder-media svg { width: 48px; height: 48px; stroke: #F2F0EB; }

  /* ---------- Buy box ---------- */
  .kzpr-details { padding-top: 4px; }

  .kzpr-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 38px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.02;
    margin-bottom: 10px;
    color: #F2F0EB;
  }

  .kzpr-stars {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .kzpr-stars-icons { color: #C9992A; font-size: 14px; letter-spacing: 2px; }
  .kzpr-stars-count { font-size: 12px; color: #888880; }

  .kzpr-usp {
    font-size: 15px;
    color: #cfcdc6;
    line-height: 1.5;
    margin-bottom: 24px;
    max-width: 46ch;
  }

  .kzpr-pricing {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
  }

  .kzpr-price-now { font-size: 30px; font-weight: 700; color: #F2F0EB; }
  .kzpr-price-was { font-size: 17px; color: #6a6a62; text-decoration: line-through; }
  .kzpr-price-pct {
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    background: #E8272A;
    padding: 3px 8px;
  }

  .kzpr-bnpl {
    font-size: 12px;
    color: #888880;
    margin-bottom: 24px;
  }

  /* ---------- Variant picker ---------- */
  .kzpr-option-group { margin-bottom: 20px; }

  .kzpr-option-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #888880;
    margin-bottom: 10px;
  }

  .kzpr-swatches, .kzpr-size-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .kzpr-swatch {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid rgba(242,240,235,0.2);
    cursor: pointer;
    position: relative;
    padding: 0;
    background-size: cover;
    background-position: center;
  }

  .kzpr-swatch.active { border-color: #E8272A; }
  .kzpr-swatch.unavailable { opacity: .25; cursor: not-allowed; }

  .kzpr-size-btn {
    min-width: 48px;
    height: 48px;
    padding: 0 16px;
    background: transparent;
    border: 1px solid rgba(242,240,235,0.25);
    border-radius: 1px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .04em;
    cursor: pointer;
    transition: background .15s, border-color .15s, transform .1s;
  }

  .kzpr-size-btn:hover { border-color: rgba(242,240,235,0.6); transform: translateY(-1px); }
  .kzpr-size-btn.active { background: #E8272A; border-color: #E8272A; color: #fff; box-shadow: 0 0 14px rgba(232,39,42,.35); }
  .kzpr-size-btn.active:hover { background: #c41f22; }
  .kzpr-size-btn.unavailable { opacity: .3; text-decoration: line-through; cursor: not-allowed; }
  .kzpr-size-btn.unavailable:hover { transform: none; }

  .kzpr-size-guide-link {
    font-size: 11px;
    text-decoration: underline;
    color: #888880;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
  }

  /* ---------- Qty + Buy buttons ---------- */
  .kzpr-buy-row {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
  }

  .kzpr-qty {
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    background: #161616;
    overflow: hidden;
    height: 52px;
    flex-shrink: 0;
  }

  .kzpr-qty button {
    width: 44px;
    height: 100%;
    background: transparent;
    border: none;
    color: #a5a59d;
    font-size: 18px;
    font-weight: 300;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background .15s, color .15s;
  }

  .kzpr-qty button:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .kzpr-qty button:active { background: rgba(232,39,42,0.85); color: #fff; }

  .kzpr-qty input {
    width: 42px;
    height: 100%;
    background: transparent;
    border: none;
    color: #F2F0EB;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 0;
    margin: 0;
    box-sizing: border-box;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .kzpr-qty input::-webkit-outer-spin-button,
  .kzpr-qty input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .kzpr-add-to-cart {
    flex: 1;
    height: 52px;
    background: #E8272A;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }

  .kzpr-add-to-cart:hover {
    background: #c41f22;
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(232, 39, 42, .35);
  }
  .kzpr-add-to-cart:active { transform: translateY(0) scale(.98); box-shadow: none; }
  .kzpr-add-to-cart:disabled { background: #3a3a36; cursor: not-allowed; transform: none; box-shadow: none; }

  .kzpr-buy-now {
    width: 100%;
    height: 52px;
    background: transparent;
    color: #F2F0EB;
    border: 1px solid rgba(242,240,235,0.35);
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    cursor: pointer;
    margin-bottom: 24px;
    transition: border-color .2s ease, color .2s ease, transform .2s ease, background .2s ease;
  }

  .kzpr-buy-now:hover { border-color: #F2F0EB; transform: translateY(-2px); background: rgba(255,255,255,.04); }
  .kzpr-buy-now:active { transform: translateY(0) scale(.99); }

  /* ---------- Objection busters ---------- */
  .kzpr-objections {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 20px 0;
    border-top: 1px solid rgba(242,240,235,0.1);
    border-bottom: 1px solid rgba(242,240,235,0.1);
    margin-bottom: 28px;
  }

  .kzpr-objection {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .kzpr-objection svg { width: 20px; height: 20px; stroke: #E8272A; flex-shrink: 0; margin-top: 2px; }

  .kzpr-objection-text { font-size: 12.5px; line-height: 1.4; color: #cfcdc6; }
  .kzpr-objection-text strong { display: block; color: #F2F0EB; font-size: 13px; margin-bottom: 1px; }

  /* ---------- Benefits / features ---------- */
  .kzpr-benefits-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 14px;
    color: #F2F0EB;
  }

  .kzpr-benefits-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
  }

  .kzpr-benefits-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    line-height: 1.5;
    color: #cfcdc6;
    padding: 8px 0;
    border-bottom: 1px solid rgba(242,240,235,0.06);
  }

  .kzpr-benefits-list li:before {
    content: '';
    width: 6px;
    height: 6px;
    background: #E8272A;
    margin-top: 7px;
    flex-shrink: 0;
    border-radius: 50%;
  }

  .kzpr-description {
    font-size: 14px;
    line-height: 1.7;
    color: #cfcdc6;
    margin-bottom: 32px;
  }

  .kzpr-description p { margin: 0 0 12px; }

  /* ---------- Accordion ---------- */
  .kzpr-accordion { border-top: 1px solid rgba(242,240,235,0.1); }

  .kzpr-accordion-item { border-bottom: 1px solid rgba(242,240,235,0.1); }

  .kzpr-accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    background: none;
    border: none;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .02em;
    text-transform: uppercase;
    cursor: pointer;
    text-align: left;
  }

  .kzpr-accordion-trigger .kzpr-plus { font-size: 18px; transition: transform .2s; color: #E8272A; }
  .kzpr-accordion-item.open .kzpr-plus { transform: rotate(45deg); }

  .kzpr-accordion-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height .25s ease;
  }

  .kzpr-accordion-item.open .kzpr-accordion-panel { max-height: 600px; }

  .kzpr-accordion-panel-inner {
    padding: 0 0 18px;
    font-size: 13.5px;
    line-height: 1.6;
    color: #a8a69f;
  }

  .kzpr-accordion-panel-inner p { margin: 0 0 10px; }
  .kzpr-accordion-panel-inner a { color: #E8272A; }

  /* ---------- Reviews section (below fold) ---------- */
  .kzpr-reviews-section {
    max-width: 1280px;
    margin: 56px auto 0;
    padding: 64px 0;
    border-top: 1px solid rgba(242,240,235,0.1);
  }

  .kzpr-section-eyebrow {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #E8272A;
    margin-bottom: 8px;
  }

  .kzpr-section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 32px;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 32px;
    color: #F2F0EB;
  }

  .kzpr-reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .kzpr-review-card {
    background: #111111;
    padding: 22px;
  }

  .kzpr-review-stars { color: #C9992A; font-size: 13px; margin-bottom: 10px; }

  .kzpr-review-text {
    font-size: 13.5px;
    line-height: 1.6;
    color: #cfcdc6;
    margin-bottom: 16px;
  }

  .kzpr-review-author { display: flex; align-items: center; gap: 10px; }

  .kzpr-review-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #E8272A;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .kzpr-review-name { font-size: 12.5px; font-weight: 600; color: #F2F0EB; }
  .kzpr-review-sport { font-size: 11px; color: #6a6a62; }

  /* ---------- Related products ---------- */
  .kzpr-related-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 0 64px;
  }

  .kzpr-related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  /* Le card usano le stesse classi .kz-card del catalogo (kz2-collection.css),
     caricato nella sezione related qui sotto: identiche pixel per pixel. */

  /* ---------- Mobile ---------- */
  @media (max-width: 860px) {
    .kzpr-wrap { padding: 24px 16px 0; }
    .kzpr-grid { grid-template-columns: 1fr; gap: 28px; }
    .kzpr-gallery { position: static; }
    .kzpr-title { font-size: 28px; }
    .kzpr-thumbs { grid-template-columns: repeat(5, 1fr); }
    .kzpr-objections { grid-template-columns: 1fr; }
    .kzpr-reviews-grid { grid-template-columns: 1fr; }
    .kzpr-related-grid { grid-template-columns: repeat(2, 1fr); }
    .kzpr-section-title { font-size: 26px; }

  }

  /* ── MINI-POPUP "AGGIUNTO AL CARRELLO" (stesso del quick-buy) ── */
  #kzpr-added-{{ section.id }} {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease;
    z-index: 999998;
  }
  #kzpr-added-{{ section.id }}.show { opacity: 1; pointer-events: auto; }
  .kzpr-added-card {
    background: #161616;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 26px 26px 22px;
    width: min(320px, calc(100% - 48px));
    text-align: center;
    box-shadow: 0 22px 60px rgba(0,0,0,.6);
    transform: translateY(10px) scale(.96);
    transition: transform .25s cubic-bezier(.2,.6,.2,1);
  }
  #kzpr-added-{{ section.id }}.show .kzpr-added-card { transform: translateY(0) scale(1); }
  .kzpr-added-check {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(76,187,122,0.12);
    border: 1.5px solid #4cbb7a;
    color: #4cbb7a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }
  .kzpr-added-check svg { width: 22px; height: 22px; }
  .kzpr-added-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    color: #F2F0EB;
    margin-bottom: 16px;
  }
  .kzpr-added-cart {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: 46px;
    background: #E8272A;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    margin-bottom: 8px;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .kzpr-added-cart:hover { background: #c41f22; transform: translateY(-2px); box-shadow: 0 8px 22px rgba(232,39,42,.35); }
  .kzpr-added-cart:active { transform: translateY(0) scale(.98); box-shadow: none; }
  .kzpr-added-continue {
    width: 100%;
    height: 42px;
    background: transparent;
    border: 1px solid rgba(242,240,235,0.35);
    border-radius: 8px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color .2s ease, transform .2s ease, background .2s ease;
  }
  .kzpr-added-continue:hover { border-color: #F2F0EB; transform: translateY(-2px); background: rgba(255,255,255,.04); }

  /* Sticky add-to-cart bar — stile carrello, desktop e mobile */
  .kzpr-mobile-sticky-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 10px max(16px, calc((100vw - 1280px) / 2));
    padding-bottom: calc(10px + env(safe-area-inset-bottom));
    display: flex;
    align-items: center;
    gap: 14px;
    z-index: 40;
    transform: translateY(110%);
    transition: transform .25s ease;
  }

  .kzpr-mobile-sticky-bar.visible { transform: translateY(0); }

  .kzpr-mobile-sticky-price { font-size: 16px; font-weight: 700; color: #F2F0EB; flex-shrink: 0; }

  .kzpr-sticky-dot {
    display: inline-block;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.35);
    flex-shrink: 0;
  }

  .kzpr-sticky-hide {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    color: #a5a59d;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background .2s ease, color .2s ease, border-color .2s ease, transform .2s ease;
  }
  .kzpr-sticky-hide svg { width: 14px; height: 14px; }
  .kzpr-sticky-hide:hover { background: #E8272A; border-color: #E8272A; color: #fff; transform: scale(1.1); }
  .kzpr-sticky-hide:active { transform: scale(.95); }

  /* Tab per riaprire la barra quando nascosta */
  .kzpr-sticky-show {
    position: fixed;
    bottom: 14px;
    left: 14px;
    z-index: 39;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(10,10,10,0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.18);
    color: #a5a59d;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px);
    transition: opacity .2s ease, transform .2s ease, background .2s ease, color .2s ease, border-color .2s ease;
  }
  .kzpr-sticky-show svg { width: 15px; height: 15px; }
  .kzpr-sticky-show.show { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .kzpr-sticky-show:hover { background: #E8272A; border-color: #E8272A; color: #fff; }

  .kzpr-mobile-sticky-size {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 8px;
    background: #161616;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .04em;
    padding: 6px 12px;
    text-transform: uppercase;
  }

  .kzpr-mobile-sticky-btn {
    flex: 1;
    max-width: 520px;
    margin-left: auto;
    height: 46px;
    background: #E8272A;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .kzpr-mobile-sticky-btn:hover {
    background: #c41f22;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(232,39,42,.35);
  }
  .kzpr-mobile-sticky-btn:active { transform: scale(.98); box-shadow: none; }
</style>

<div class="kzpr-wrap" id="kzpr-{{ section.id }}">
  <div class="kzpr-grid">

    {%- comment -%} ============ GALLERY ============ {%- endcomment -%}
    <div class="kzpr-gallery">
      <div class="kzpr-main-media" id="kzpr-main-media-{{ section.id }}">
        {%- if product.featured_media -%}
          {%- if product.featured_media.media_type == 'video' -%}
            <video src="{{ product.featured_media.sources[0].url }}" autoplay muted loop playsinline></video>
          {%- else -%}
            <img
              src="{{ product.featured_media | image_url: width: 1200 }}"
              alt="{{ product.featured_media.alt | default: product.title | escape }}"
              width="{{ product.featured_media.width }}"
              height="{{ product.featured_media.height }}"
            >
          {%- endif -%}
        {%- else -%}
          <div class="kzpr-placeholder-media">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1"><rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M16 3v18"/></svg>
            <span>Foto prodotto</span>
          </div>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="kzpr-thumbs">
          {%- for media in product.media limit: 5 -%}
            <button
              class="kzpr-thumb{% if forloop.first %} active{% endif %}"
              data-media-id="{{ media.id }}"
              data-media-type="{{ media.media_type }}"
              data-media-url="{% if media.media_type == 'video' %}{{ media.sources[0].url }}{% else %}{{ media | image_url: width: 1200 }}{% endif %}"
              aria-label="Vedi immagine {{ forloop.index }}"
            >
              {%- if media.media_type == 'video' -%}
                <video src="{{ media.sources[0].url }}" muted playsinline></video>
              {%- else -%}
                <img src="{{ media | image_url: width: 200 }}" alt="{{ media.alt | escape }}" loading="lazy">
              {%- endif -%}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ============ BUY BOX ============ {%- endcomment -%}
    <div class="kzpr-details">

      <div class="kzpr-tags">
        {%- if product.tags contains 'novita' or product.tags contains 'new' -%}<span class="kzpr-tag">Novit&#224;</span>{%- endif -%}
        {%- if product.tags contains 'bestseller' or product.tags contains 'best-seller' -%}<span class="kzpr-tag">Best seller</span>{%- endif -%}
        {%- if product.tags contains 'edizione-limitata' or product.tags contains 'limited' -%}<span class="kzpr-tag secondary">Edizione limitata</span>{%- endif -%}
      </div>

      <h1 class="kzpr-title">{{ product.title }}</h1>

      {%- if section.settings.show_reviews_badge -%}
        <div class="kzpr-stars">
          <span class="kzpr-stars-icons">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="kzpr-stars-count">{{ section.settings.reviews_count }}</span>
        </div>
      {%- endif -%}

      {%- liquid
        comment
          Sottotitolo dinamico per categoria: set completi, abbigliamento,
          protezioni, accessori. Fallback: testo dalle impostazioni sezione.
        endcomment
        assign kz_usp = section.settings.usp_text
        assign kz_colls = product.collections | map: 'handle' | join: ','
        if kz_colls contains 'sets'
          assign kz_usp = 'Tutto quello che serve per entrare in palestra da protagonista. Un set completo e si vede subito chi fa sul serio.'
        elsif kz_colls contains 'protezioni'
          assign kz_usp = 'Protezione da combattimento vera, non da vetrina. Chi si allena ogni giorno non si presenta con mezze misure.'
        elsif kz_colls contains 'abbigliamento'
          assign kz_usp = 'Tessuti tecnici e vestibilità da atleta: reggono sudore, lavaggi e round infiniti. Vestiti come chi il ring lo comanda.'
        elsif kz_colls contains 'accessori'
          assign kz_usp = 'Il dettaglio che completa il tuo mondo da fighter. La mentalità da campione si costruisce anche fuori dal ring.'
        endif
      -%}
      {%- if kz_usp != blank -%}
        <p class="kzpr-usp">{{ kz_usp }}</p>
      {%- endif -%}

      <div class="kzpr-pricing">
        <span class="kzpr-price-now">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="kzpr-price-was">{{ current_variant.compare_at_price | money }}</span>
          {%- assign pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="kzpr-price-pct">&minus;{{ pct }}%</span>
        {%- endif -%}
      </div>
      {%- if section.settings.bnpl_text != blank -%}
        <div class="kzpr-bnpl">{{ section.settings.bnpl_text }}</div>
      {%- endif -%}

      {%- form 'product', product, id: 'kzpr-product-form', class: 'kzpr-form' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="kzpr-variant-id-{{ section.id }}">

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="kzpr-option-group">
              <div class="kzpr-option-label">
                {{ option.name }}
              </div>

              {%- if option.name == 'Colore' or option.name == 'Color' -%}
                <div class="kzpr-swatches">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="kzpr-swatch{% if value == option.selected_value %} active{% endif %}"
                      style="background-color: {{ value | handle }};"
                      data-option-index="{{ option.position | minus: 1 }}"
                      data-value="{{ value | escape }}"
                      aria-label="{{ value }}"
                    ></button>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <div class="kzpr-size-buttons">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="kzpr-size-btn{% if value == option.selected_value %} active{% endif %}"
                      data-option-index="{{ option.position | minus: 1 }}"
                      data-value="{{ value | escape }}"
                    >{{ value }}</button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}

          {%- if section.settings.show_size_guide -%}
            <a class="kzpr-size-guide-link" href="/pages/tabella-taglie" target="_blank" rel="noopener">Guida alle taglie</a>
          {%- endif -%}
        {%- endunless -%}

        <div class="kzpr-buy-row">
          <div class="kzpr-qty">
            <button type="button" class="kzpr-qty-minus" aria-label="Diminuisci quantit&#224;">&minus;</button>
            <input type="number" name="quantity" value="1" min="1" class="kzpr-qty-input" aria-label="Quantit&#224;">
            <button type="button" class="kzpr-qty-plus" aria-label="Aumenta quantit&#224;">+</button>
          </div>
          <button type="submit" class="kzpr-add-to-cart" {% unless current_variant.available %}disabled{% endunless %}>
            {%- if current_variant.available -%}
              {{ section.settings.add_to_cart_label }}
            {%- else -%}
              Esaurito
            {%- endif -%}
          </button>
        </div>

        {%- if section.settings.show_buy_now and current_variant.available -%}
          <button type="button" class="kzpr-buy-now" id="kzpr-buy-now-{{ section.id }}">
            {{ section.settings.buy_now_label }}
          </button>
        {%- endif -%}
      {%- endform -%}

      {%- comment -%} ---- Objection busters ---- {%- endcomment -%}
      <div class="kzpr-objections">
        {%- if section.settings.guarantee_text != blank -%}
          <div class="kzpr-objection">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6"><path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/></svg>
            <div class="kzpr-objection-text"><strong>Garanzia</strong>{{ section.settings.guarantee_text }}</div>
          </div>
        {%- endif -%}
        {%- if section.settings.shipping_text != blank -%}
          <div class="kzpr-objection">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6"><rect x="1" y="7" width="15" height="10" rx="1"/><path d="M16 10h4l3 3v4h-7z"/><circle cx="6" cy="19" r="2"/><circle cx="18" cy="19" r="2"/></svg>
            <div class="kzpr-objection-text"><strong>Spedizione</strong>{{ section.settings.shipping_text }}</div>
          </div>
        {%- endif -%}
        {%- if section.settings.usp1_text != blank -%}
          <div class="kzpr-objection">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6"><path d="M12 2l2.6 6.5L21 9l-5 4.5L17.5 21 12 17l-5.5 4L8 13.5 3 9l6.4-.5z"/></svg>
            <div class="kzpr-objection-text"><strong>{{ section.settings.usp1_title }}</strong>{{ section.settings.usp1_text }}</div>
          </div>
        {%- endif -%}
        {%- if section.settings.usp2_text != blank -%}
          <div class="kzpr-objection">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6"><path d="M20 6L9 17l-5-5"/></svg>
            <div class="kzpr-objection-text"><strong>{{ section.settings.usp2_title }}</strong>{{ section.settings.usp2_text }}</div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ---- Benefits ---- {%- endcomment -%}
      {%- if section.settings.benefits_title != blank -%}
        <div class="kzpr-benefits-title">{{ section.settings.benefits_title }}</div>
      {%- endif -%}
      <ul class="kzpr-benefits-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- comment -%} ---- Description ---- {%- endcomment -%}
      <div class="kzpr-description">
        {{ product.description }}
      </div>

      {%- comment -%} ---- Accordion: spec / shipping / returns / faq ---- {%- endcomment -%}
      <div class="kzpr-accordion">
        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion_item' -%}
            <div class="kzpr-accordion-item" {{ block.shopify_attributes }}>
              <button type="button" class="kzpr-accordion-trigger">
                {{ block.settings.heading }}
                <span class="kzpr-plus">+</span>
              </button>
              <div class="kzpr-accordion-panel">
                <div class="kzpr-accordion-panel-inner">{{ block.settings.content }}</div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>

  {%- comment -%} ============ REVIEWS ============ {%- endcomment -%}
  {%- assign has_reviews = false -%}
  {%- for block in section.blocks -%}{%- if block.type == 'review' -%}{%- assign has_reviews = true -%}{%- endif -%}{%- endfor -%}
  {%- if has_reviews -%}
    <div class="kzpr-reviews-section">
      <div class="kzpr-section-eyebrow">{{ section.settings.reviews_eyebrow }}</div>
      <div class="kzpr-section-title">{{ section.settings.reviews_title }}</div>
      <div class="kzpr-reviews-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <div class="kzpr-review-card" {{ block.shopify_attributes }}>
              <div class="kzpr-review-stars">
                {%- for i in (1..block.settings.stars) -%}&#9733;{%- endfor -%}
              </div>
              <div class="kzpr-review-text">&#8220;{{ block.settings.text }}&#8221;</div>
              <div class="kzpr-review-author">
                <div class="kzpr-review-avatar">{{ block.settings.initials }}</div>
                <div>
                  <div class="kzpr-review-name">{{ block.settings.name }}</div>
                  <div class="kzpr-review-sport">{{ block.settings.sport_location }}</div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ============ RELATED PRODUCTS ============ {%- endcomment -%}
  {%- if section.settings.show_related and product.metafields.related.size > 0 or section.settings.show_related -%}
    {{ 'kz2-collection.css' | asset_url | stylesheet_tag }}
    <div class="kzpr-related-section">
      <div class="kzpr-section-eyebrow">{{ section.settings.related_eyebrow }}</div>
      <div class="kzpr-section-title">{{ section.settings.related_title }}</div>
      <div class="kzpr-related-grid">
        {%- assign related_count = 0 -%}
        {%- for rec_product in collections[product.collections.first.handle].products -%}
          {%- if rec_product.id != product.id and related_count < 4 -%}
            {%- assign related_count = related_count | plus: 1 -%}
            {%- render 'kz2-product-card', product: rec_product -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    {%- render 'kz-product-modal' -%}
    <script src="{{ 'kz-product-modal.js' | asset_url }}" defer></script>
  {%- endif -%}

</div>

{%- comment -%} ============ MOBILE STICKY BAR ============ {%- endcomment -%}
<div class="kzpr-mobile-sticky-bar" id="kzpr-sticky-bar-{{ section.id }}">
  <button type="button" class="kzpr-sticky-hide" id="kzpr-sticky-hide-{{ section.id }}" aria-label="Nascondi barra">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
  </button>
  <div class="kzpr-mobile-sticky-price">{{ current_variant.price | money }}</div>
  {%- unless product.has_only_default_variant -%}
    {%- liquid
      assign kzpr_color_idx = -1
      for opt in product.options_with_values
        assign oname = opt.name | downcase
        if oname == 'color' or oname == 'colore' or oname == 'colour'
          assign kzpr_color_idx = forloop.index0
        endif
      endfor
    -%}
    <div class="kzpr-mobile-sticky-size" id="kzpr-sticky-size-{{ section.id }}" data-color-idx="{{ kzpr_color_idx }}">
      {%- for opt_val in current_variant.options -%}
        {%- if forloop.index0 == kzpr_color_idx -%}
          <span class="kzpr-sticky-dot" style="background-color: {{ opt_val | handle }};" title="{{ opt_val | escape }}"></span>
        {%- else -%}
          <span>{{ opt_val }}</span>
        {%- endif -%}
        {%- unless forloop.last %} / {% endunless -%}
      {%- endfor -%}
    </div>
  {%- endunless -%}
  <button type="button" class="kzpr-mobile-sticky-btn" id="kzpr-sticky-add-{{ section.id }}">
    {{ section.settings.add_to_cart_label }}
  </button>
</div>

<button type="button" class="kzpr-sticky-show" id="kzpr-sticky-show-{{ section.id }}" aria-label="Mostra barra acquisto">
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5"/></svg>
</button>

<div id="kzpr-added-{{ section.id }}" aria-hidden="true">
  <div class="kzpr-added-card">
    <div class="kzpr-added-check">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
    </div>
    <div class="kzpr-added-title">Aggiunto al carrello!</div>
    <a class="kzpr-added-cart" href="/cart">
      Vai al carrello
    </a>
    <button type="button" class="kzpr-added-continue" id="kzpr-added-continue-{{ section.id }}">Continua lo shopping</button>
  </div>
</div>

<script>
(function() {
  var root = document.getElementById('kzpr-{{ section.id }}');
  if (!root) return;

  var mainMedia = document.getElementById('kzpr-main-media-{{ section.id }}');
  var thumbs = root.querySelectorAll('.kzpr-thumb');

  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      thumbs.forEach(function(t) { t.classList.remove('active'); });
      thumb.classList.add('active');
      var type = thumb.getAttribute('data-media-type');
      var url = thumb.getAttribute('data-media-url');
      if (type === 'video') {
        mainMedia.innerHTML = '<video src="' + url + '" autoplay muted loop playsinline></video>';
      } else {
        mainMedia.innerHTML = '<img src="' + url + '" alt="">';
      }
    });
  });

  // Quantity stepper
  var qtyInput = root.querySelector('.kzpr-qty-input');
  var qtyMinus = root.querySelector('.kzpr-qty-minus');
  var qtyPlus = root.querySelector('.kzpr-qty-plus');
  if (qtyMinus && qtyPlus && qtyInput) {
    qtyMinus.addEventListener('click', function() {
      var v = Math.max(1, parseInt(qtyInput.value || 1) - 1);
      qtyInput.value = v;
    });
    qtyPlus.addEventListener('click', function() {
      var v = parseInt(qtyInput.value || 1) + 1;
      qtyInput.value = v;
    });
  }

  // Accordion
  var accordionItems = root.querySelectorAll('.kzpr-accordion-item');
  accordionItems.forEach(function(item) {
    var trigger = item.querySelector('.kzpr-accordion-trigger');
    trigger.addEventListener('click', function() {
      var wasOpen = item.classList.contains('open');
      accordionItems.forEach(function(i) { i.classList.remove('open'); });
      if (!wasOpen) item.classList.add('open');
    });
  });

  // Variant selection (size / color buttons)
  var variantData = {{ product.variants | json }};
  var selectedOptions = [];
  {%- for option in product.options_with_values -%}
    selectedOptions.push("{{ option.selected_value | escape }}");
  {%- endfor -%}

  function updateVariant() {
    var match = variantData.find(function(v) {
      return v.options.every(function(opt, i) { return opt === selectedOptions[i]; });
    });
    var hiddenInput = document.getElementById('kzpr-variant-id-{{ section.id }}');
    var addBtn = root.querySelector('.kzpr-add-to-cart');
    var priceEl = root.querySelector('.kzpr-price-now');
    var stickyPrice = document.querySelector('#kzpr-sticky-bar-{{ section.id }} .kzpr-mobile-sticky-price');
    var stickySize = document.getElementById('kzpr-sticky-size-{{ section.id }}');
    if (match && hiddenInput) {
      hiddenInput.value = match.id;
      if (addBtn) {
        addBtn.disabled = !match.available;
        addBtn.textContent = match.available ? '{{ section.settings.add_to_cart_label }}' : 'Esaurito';
      }
      if (priceEl && match.price) {
        priceEl.textContent = formatMoney(match.price);
      }
      if (stickyPrice && match.price) {
        stickyPrice.textContent = formatMoney(match.price);
      }
      if (stickySize && match.options) {
        var colorIdx = parseInt(stickySize.getAttribute('data-color-idx'), 10);
        stickySize.innerHTML = match.options.map(function(v, i) {
          if (i === colorIdx) {
            var c = String(v).toLowerCase().trim().replace(/[^a-z0-9]+/g, '-');
            return '<span class="kzpr-sticky-dot" style="background-color:' + c + '" title="' + v + '"></span>';
          }
          return '<span>' + v + '</span>';
        }).join(' / ');
      }
    }
  }

  function formatMoney(cents) {
    return '\u20AC' + (cents / 100).toFixed(2).replace('.', ',');
  }

  root.querySelectorAll('.kzpr-swatch, .kzpr-size-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = parseInt(btn.getAttribute('data-option-index'));
      var value = btn.getAttribute('data-value');
      selectedOptions[idx] = value;

      var group = btn.closest('.kzpr-option-group');
      group.querySelectorAll('.kzpr-swatch, .kzpr-size-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');

      updateVariant();
    });
  });

  // Mobile sticky bar: show after scrolling past buy box
  var stickyBar = document.getElementById('kzpr-sticky-bar-{{ section.id }}');
  var detailsEl = root.querySelector('.kzpr-add-to-cart') || root.querySelector('.kzpr-details');
  var stickyHideBtn = document.getElementById('kzpr-sticky-hide-{{ section.id }}');
  var stickyShowTab = document.getElementById('kzpr-sticky-show-{{ section.id }}');
  var stickyCollapsed = false;
  var stickyInZone = false;

  function syncSticky() {
    if (!stickyBar) return;
    if (stickyInZone && !stickyCollapsed) stickyBar.classList.add('visible');
    else stickyBar.classList.remove('visible');
    if (stickyShowTab) stickyShowTab.classList.toggle('show', stickyInZone && stickyCollapsed);
  }

  if (stickyBar && detailsEl) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        stickyInZone = !entry.isIntersecting && entry.boundingClientRect.top < 0;
        syncSticky();
      });
    }, { threshold: 0 });
    observer.observe(detailsEl);
  }
  if (stickyHideBtn) stickyHideBtn.addEventListener('click', function() { stickyCollapsed = true; syncSticky(); });
  if (stickyShowTab) stickyShowTab.addEventListener('click', function() { stickyCollapsed = false; syncSticky(); });

  /* ── Add to cart AJAX + mini-popup scelta (come il quick-buy) ── */
  var kzprForm = document.getElementById('kzpr-product-form');
  var kzprAdded = document.getElementById('kzpr-added-{{ section.id }}');
  var kzprBuyNow = document.getElementById('kzpr-buy-now-{{ section.id }}');
  var kzprGoCheckout = false;

  function kzprUpdateCartCount() {
    fetch('/cart.js').then(function(r){ return r.json(); }).then(function(cart){
      var badge = document.querySelector('.kz-cart-count');
      if (!badge) return;
      badge.textContent = cart.item_count > 0 ? cart.item_count : '';
      badge.style.display = cart.item_count > 0 ? '' : 'none';
    });
  }

  if (kzprForm) {
    kzprForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var addBtnEl = kzprForm.querySelector('.kzpr-add-to-cart');
      if (addBtnEl) addBtnEl.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(kzprForm)
      })
        .then(function(r){ return r.json(); })
        .then(function(){
          if (addBtnEl) addBtnEl.disabled = false;
          if (kzprGoCheckout) { window.location.href = '/checkout'; return; }
          kzprUpdateCartCount();
          if (kzprAdded) kzprAdded.classList.add('show');
          else window.location.href = '/cart';
        })
        .catch(function(){
          if (addBtnEl) addBtnEl.disabled = false;
          kzprGoCheckout = false;
        });
    });
  }
  if (kzprBuyNow) kzprBuyNow.addEventListener('click', function() {
    kzprGoCheckout = true;
    kzprForm.requestSubmit();
  });
  if (kzprAdded) {
    kzprAdded.addEventListener('click', function(e) { if (e.target === kzprAdded) kzprAdded.classList.remove('show'); });
    var contBtn = document.getElementById('kzpr-added-continue-{{ section.id }}');
    if (contBtn) contBtn.addEventListener('click', function() { kzprAdded.classList.remove('show'); });
  }

  var stickyAddBtn = document.getElementById('kzpr-sticky-add-{{ section.id }}');
  if (stickyAddBtn) {
    stickyAddBtn.addEventListener('click', function() {
      document.getElementById('kzpr-product-form').requestSubmit();
    });
  }
})();
</script>


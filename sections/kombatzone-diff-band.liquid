{% comment %}
  KOMBAT ZONE — Differentiator Band
  File: sections/kombatzone-diff-band.liquid
  Come usarlo: Online Store → Temi → Modifica codice → Sections → Add a new section → incolla questo file
  Poi vai su Customize e aggiungi la sezione "Kombat Zone — Vantaggi" dove preferisci
  (consigliato: subito dopo la griglia prodotti, prima della sezione personalizzazione).
{% endcomment %}

<style>
  #kz-diff-{{ section.id }} {
    --red: #E8272A;
    --ff-display: 'Barlow Condensed', sans-serif;
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 32px;
    padding-right: 32px;
    display: flex;
    align-items: center;
  }
  #kz-diff-{{ section.id }} .diff-item {
    flex: 1;
    padding: 0 40px;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.2);
  }
  #kz-diff-{{ section.id }} .diff-item:first-child { padding-left: 0; }
  #kz-diff-{{ section.id }} .diff-item:last-child { padding-right: 0; border-right: none; }
  #kz-diff-{{ section.id }} .diff-icon {
    font-size: 28px;
    margin-bottom: 12px;
    opacity: .95;
  }
  #kz-diff-{{ section.id }} .diff-icon svg {
    width: 32px;
    height: 32px;
    color: #fff;
    display: inline-block;
  }
  #kz-diff-{{ section.id }} .diff-title {
    font-family: var(--ff-display), sans-serif;
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .04em;
    margin-bottom: 4px;
    color: #fff;
  }
  #kz-diff-{{ section.id }} .diff-desc {
    font-size: 12px;
    color: rgba(255,255,255,0.7);
    line-height: 1.5;
  }

  @media (max-width: 700px) {
    #kz-diff-{{ section.id }} {
      flex-direction: column;
      align-items: stretch;
      gap: 24px;
    }
    #kz-diff-{{ section.id }} .diff-item {
      border-right: none !important;
      padding: 0 !important;
    }
  }
</style>

<div id="kz-diff-{{ section.id }}">
  {% for block in section.blocks %}
    <div class="diff-item" {{ block.shopify_attributes }}>
      <div class="diff-icon">
        {%- assign kz_ic = block.settings.icon | strip -%}
        {%- case kz_ic -%}
          {%- when '✦' , '✎' -%}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/></svg>
          {%- when '⚡' -%}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
          {%- when '↩' -%}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
          {%- when '🛡' -%}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
          {%- else -%}
            {{ block.settings.icon }}
        {%- endcase -%}
      </div>
      <div class="diff-title">{{ block.settings.title }}</div>
      <div class="diff-desc">{{ block.settings.desc }}</div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "KZ — Vantaggi",
  "tag": "section",
  "class": "kz-diff-band-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Colore di sfondo",
      "default": "#E8272A"
    },
    {
      "type": "header",
      "content": "Altezza sezione"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Spazio sopra",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Spazio sotto",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "diff_item",
      "name": "Vantaggio",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icona (emoji o simbolo)", "default": "✦" },
        { "type": "text", "id": "title", "label": "Titolo", "default": "Vantaggio" },
        { "type": "textarea", "id": "desc", "label": "Descrizione", "default": "Descrizione del vantaggio." }
      ]
    }
  ],
  "presets": [
    {
      "name": "KZ — Vantaggi",
      "blocks": [
        { "type": "diff_item", "settings": { "icon": "✦", "title": "Nome gratis", "desc": "Personalizzazione inclusa su ogni ordine — nessun costo extra." } },
        { "type": "diff_item", "settings": { "icon": "⚡", "title": "Spedizione EU", "desc": "Magazzino in Europa. Consegna in 48–72 ore lavorative." } },
        { "type": "diff_item", "settings": { "icon": "↩", "title": "Reso 30 giorni", "desc": "Taglia sbagliata? Cambi o rimborso senza domande." } }
      ]
    }
  ]
}
{% endschema %}

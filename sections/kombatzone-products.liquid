{% comment %}
  KOMBAT ZONE — Sezione Prodotti "I più scelti"
  File: sections/kombatzone-products.liquid
{% endcomment %}

{{ 'https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@400;500;600&display=swap' | stylesheet_tag }}

<style>
  .kzp-wrap {
    background: #0a0a0a;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 32px;
    padding-right: 32px;
  }

  .kzp-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 40px;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }

  .kzp-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #E8272A;
    margin-bottom: 8px;
  }

  .kzp-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 42px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: .01em;
    color: #F2F0EB;
  }

  .kzp-see-all {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #888880;
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    transition: color .15s;
    padding-bottom: 4px;
  }

  .kzp-see-all:hover { color: #F2F0EB; }

  .kzp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    max-width: 1440px;
    margin: 0 auto;
  }

  .kzp-card {
    position: relative;
    background: #1a1a1a;
    overflow: hidden;
    cursor: pointer;
    display: block;
    text-decoration: none;
  }

  .kzp-card.featured { grid-column: span 2; }

  .kzp-img {
    aspect-ratio: 3/4;
    background: #242424;
    position: relative;
    overflow: hidden;
  }

  .kzp-card.featured .kzp-img { aspect-ratio: 6/4; }

  .kzp-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kzp-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    opacity: .12;
  }

  .kzp-placeholder svg { width: 40px; height: 40px; stroke: #F2F0EB; }
  .kzp-placeholder span {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #F2F0EB;
  }

  .kzp-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #E8272A;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 4px 8px;
    z-index: 2;
  }

  .kzp-badge.gold { background: #C9992A; color: #1a0f00; }

  .kzp-info {
    padding: 14px 16px 18px;
  }

  .kzp-cat {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #4a4a44;
    margin-bottom: 4px;
  }

  .kzp-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .02em;
    margin-bottom: 8px;
    line-height: 1.1;
    color: #F2F0EB;
  }

  .kzp-pricing {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .kzp-price-now { font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600; color: #F2F0EB; }
  .kzp-price-was { font-family: 'Inter', sans-serif; font-size: 12px; color: #4a4a44; text-decoration: line-through; }
  .kzp-price-pct { font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 600; color: #E8272A; }

  /* Carrellino pop-up in basso a destra della foto (stesso stile del catalogo) */
  .kzp-cart-fab {
    position: absolute;
    bottom: 10px;
    right: 10px;
    z-index: 4;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    transition: background .25s ease, border-color .25s ease, transform .25s ease, box-shadow .25s ease;
  }
  .kzp-cart-fab svg { width: 16px; height: 16px; }
  .kzp-cart-fab:hover {
    background: #E8272A;
    border-color: #E8272A;
    transform: scale(1.12);
    box-shadow: 0 0 14px rgba(232, 39, 42, 0.6);
  }
  .kzp-cart-fab:active { transform: scale(0.95); }
  .kzp-cart-fab:disabled { opacity: .4; cursor: not-allowed; }

  .kzp-info {
    position: relative;
    z-index: 2;
    background: #1a1a1a;
  }

  /* Spacing controls */
  .kzp-spacing-bar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    margin-bottom: 16px;
  }

  .kzp-spacing-label {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #4a4a44;
  }

  .kzp-sp-btn {
    width: 28px;
    height: 28px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.07);
    color: #888880;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    transition: background .15s, color .15s;
    flex-shrink: 0;
  }

  .kzp-sp-btn:hover { background: #242424; color: #F2F0EB; }

  @media (max-width: 768px) {
    .kzp-grid { grid-template-columns: repeat(2, 1fr); }
    .kzp-card.featured { grid-column: span 2; }
    .kzp-wrap { padding-left: 16px; padding-right: 16px; }
  }
</style>

<div class="kzp-wrap" id="kzp-{{ section.id }}">


  <div class="kzp-header">
    <div>
      <div class="kzp-eyebrow">{{ section.settings.eyebrow }}</div>
      <div class="kzp-title">{{ section.settings.title }}</div>
    </div>
    {%- if section.settings.see_all_url != blank -%}
      <a href="{{ section.settings.see_all_url }}" class="kzp-see-all">
        {{ section.settings.see_all_label }}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    {%- endif -%}
  </div>

  <div class="kzp-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'product_card' -%}

        <a class="kzp-card{% if block.settings.featured %} featured{% endif %}"
           href="{{ block.settings.product_url }}"
           {{ block.shopify_attributes }}>

          <div class="kzp-img">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.name | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="kzp-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1"><rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M16 3v18"/></svg>
                <span>Foto prodotto</span>
              </div>
            {%- endif -%}

            {%- if block.settings.badge_label != blank -%}
              <div class="kzp-badge{% if block.settings.badge_gold %} gold{% endif %}">
                {{ block.settings.badge_label }}
              </div>
            {%- endif -%}
          </div>

          <div class="kzp-info">
            {%- if block.settings.category != blank -%}
              <div class="kzp-cat">{{ block.settings.category }}</div>
            {%- endif -%}
            <div class="kzp-name">{{ block.settings.name }}</div>
            <div class="kzp-pricing">
              <span class="kzp-price-now">{{ block.settings.price_now }}</span>
              {%- if block.settings.price_was != blank -%}
                <span class="kzp-price-was">{{ block.settings.price_was }}</span>
              {%- endif -%}
              {%- if block.settings.price_pct != blank -%}
                <span class="kzp-price-pct">{{ block.settings.price_pct }}</span>
              {%- endif -%}
            </div>
          </div>

        </a>

      {%- elsif block.type == 'product' -%}
        {%- assign p = block.settings.product -%}
        {%- if p != blank -%}
          {%- assign has_disc = false -%}
          {%- if p.compare_at_price > p.price -%}
            {%- assign has_disc = true -%}
            {%- assign p_pct = p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price | round -%}
          {%- endif -%}
          <a class="kzp-card{% if block.settings.featured %} featured{% endif %}"
             href="{{ p.url }}"
             {{ block.shopify_attributes }}>
            <div class="kzp-img">
              {%- if p.featured_image -%}
                <img
                  src="{{ p.featured_image | image_url: width: 800 }}"
                  alt="{{ p.title | escape }}"
                  width="{{ p.featured_image.width }}"
                  height="{{ p.featured_image.height }}"
                  loading="lazy"
                >
              {%- else -%}
                <div class="kzp-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke-width="1"><rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M16 3v18"/></svg>
                  <span>Foto prodotto</span>
                </div>
              {%- endif -%}
              {%- if block.settings.badge_label != blank -%}
                <div class="kzp-badge{% if block.settings.badge_gold %} gold{% endif %}">{{ block.settings.badge_label }}</div>
              {%- elsif p.tags contains 'bestseller' -%}
                <div class="kzp-badge">BESTSELLER</div>
              {%- elsif has_disc -%}
                <div class="kzp-badge">&minus;{{ p_pct }}%</div>
              {%- endif -%}
              <button
                type="button"
                class="kzp-cart-fab"
                data-kz-modal="{{ p.handle }}"
                aria-label="Aggiungi {{ p.title | escape }} al carrello"
                {%- unless p.available %} disabled aria-disabled="true"{%- endunless %}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M2.25 2.25a.75.75 0 0 0 0 1.5h1.386c.17 0 .318.114.362.278l2.558 9.592a3.752 3.752 0 0 0-2.806 3.63c0 .414.336.75.75.75h15.75a.75.75 0 0 0 0-1.5H5.378A2.25 2.25 0 0 1 7.5 15h11.218a.75.75 0 0 0 .674-.421 60.358 60.358 0 0 0 2.96-7.228.75.75 0 0 0-.525-.965A60.864 60.864 0 0 0 5.68 4.509l-.232-.867A1.875 1.875 0 0 0 3.636 2.25H2.25ZM3.75 20.25a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0ZM16.5 20.25a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Z"/>
                </svg>
              </button>
            </div>
            <div class="kzp-info">
              {%- assign p_cat = p.type -%}
              {%- if p_cat == blank -%}{%- assign p_cat = p.collections.first.title -%}{%- endif -%}
              {%- if p_cat != blank -%}
                <div class="kzp-cat">{{ p_cat }}</div>
              {%- endif -%}
              <div class="kzp-name">{{ p.title }}</div>
              <div class="kzp-pricing">
                <span class="kzp-price-now">{{ p.price | money }}</span>
                {%- if has_disc -%}
                  <span class="kzp-price-was">{{ p.compare_at_price | money }}</span>
                  <span class="kzp-price-pct">&minus;{{ p_pct }}%</span>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

</div>

{%- render 'kz-product-modal' -%}
<script src="{{ 'kz-product-modal.js' | asset_url }}" defer></script>

<script>
(function() {
  var wrap = document.getElementById('kzp-{{ section.id }}');
  var btnPlus = document.getElementById('kzp-plus-{{ section.id }}');
  var btnMinus = document.getElementById('kzp-minus-{{ section.id }}');
  var step = 16;
  var minPad = 0;
  var maxPad = 160;

  function getPad() {
    return parseInt(wrap.style.paddingBottom) || {{ section.settings.padding_bottom }};
  }

  function setPad(val) {
    val = Math.min(maxPad, Math.max(minPad, val));
    wrap.style.paddingBottom = val + 'px';
  }

  btnPlus.addEventListener('click', function() { setPad(getPad() + step); });
  btnMinus.addEventListener('click', function() { setPad(getPad() - step); });
})();
</script>

{% schema %}
{
  "name": "KZ Prodotti",
  "tag": "section",
  "class": "kz-products-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Testo sopra il titolo",
      "default": "Bestseller"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titolo sezione",
      "default": "I più scelti"
    },
    {
      "type": "text",
      "id": "see_all_label",
      "label": "Testo link 'vedi tutto'",
      "default": "Vedi tutto"
    },
    {
      "type": "url",
      "id": "see_all_url",
      "label": "Link 'vedi tutto'"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Testo bottone hover prodotto",
      "default": "Aggiungi al carrello"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Spazio sopra la sezione (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Spazio sotto la sezione (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Prodotto (automatico)",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Prodotto"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Card grande (featured)",
          "default": false
        },
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge personalizzato (opzionale)",
          "info": "Vuoto = automatico: BESTSELLER da tag o sconto %"
        },
        {
          "type": "checkbox",
          "id": "badge_gold",
          "label": "Badge dorato",
          "default": false
        }
      ]
    },
    {
      "type": "product_card",
      "name": "Card prodotto",
      "settings": [
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Card grande (occupa 2 colonne)",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto prodotto"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Link prodotto"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Categoria (es. MMA · Boxe)",
          "default": "Boxe"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nome prodotto",
          "default": "Guantoni Pro Series"
        },
        {
          "type": "text",
          "id": "price_now",
          "label": "Prezzo attuale",
          "default": "€47"
        },
        {
          "type": "text",
          "id": "price_was",
          "label": "Prezzo originale (opzionale)",
          "default": "€72"
        },
        {
          "type": "text",
          "id": "price_pct",
          "label": "Sconto % (opzionale, es. −35%)"
        },
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge (opzionale, es. −35% o Set completo)"
        },
        {
          "type": "checkbox",
          "id": "badge_gold",
          "label": "Badge colore oro (invece di rosso)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KZ Prodotti",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "featured": true,
            "category": "MMA · Boxe · Muay Thai",
            "name": "Fight Starter Kit",
            "price_now": "€84",
            "price_was": "€139",
            "price_pct": "−40%",
            "badge_label": "Set completo",
            "badge_gold": true
          }
        },
        {
          "type": "product_card",
          "settings": {
            "featured": false,
            "category": "Boxe",
            "name": "Guantoni Pro Series",
            "price_now": "€47",
            "price_was": "€72",
            "badge_label": "−35%",
            "badge_gold": false
          }
        },
        {
          "type": "product_card",
          "settings": {
            "featured": false,
            "category": "MMA",
            "name": "Shorts Combat",
            "price_now": "€38",
            "price_was": "€59",
            "price_pct": "−35%",
            "badge_gold": false
          }
        }
      ]
    }
  ]
}
{% endschema %}

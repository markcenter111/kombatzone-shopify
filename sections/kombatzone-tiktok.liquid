{% comment %}
  KOMBAT ZONE — Sezione TikTok
  File: sections/kombatzone-tiktok.liquid
{% endcomment %}

{{ 'https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@400;500;600&display=swap' | stylesheet_tag }}

<style>
  .kz-tt-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 28px;
    padding-right: 28px;
    background: {{ section.settings.bg_color }};
    font-family: 'Inter', sans-serif;
  }

  .kz-tt-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .kz-tt-profile {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .kz-tt-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #242424;
    border: 2px solid #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 900;
    color: #F2F0EB;
    overflow: hidden;
    flex-shrink: 0;
  }

  .kz-tt-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kz-tt-handle {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: #F2F0EB;
    margin-bottom: 4px;
  }

  .kz-tt-stats {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .kz-tt-stat {
    font-size: 10px;
    color: #4a4a44;
    letter-spacing: .04em;
  }

  .kz-tt-stat strong {
    color: #888880;
    font-weight: 600;
  }

  .kz-tt-follow-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.12);
    color: #F2F0EB;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 10px 20px;
    cursor: pointer;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    transition: background .15s;
  }

  .kz-tt-follow-btn:hover {
    background: #242424;
    color: #F2F0EB;
  }

  .kz-tt-follow-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .kz-tt-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
  }

  .kz-tt-card {
    position: relative;
    aspect-ratio: 9/16;
    background: #242424;
    overflow: hidden;
    cursor: pointer;
    display: block;
    text-decoration: none;
  }

  .kz-tt-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kz-tt-card-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 28px 12px 12px;
    background: linear-gradient(0deg, rgba(0,0,0,0.88) 0%, transparent 100%);
    pointer-events: none;
  }

  .kz-tt-views {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-bottom: 4px;
  }

  .kz-tt-caption {
    font-size: 10px;
    color: rgba(255,255,255,0.85);
    line-height: 1.4;
    font-weight: 500;
  }

  .kz-tt-overlay {
    position: absolute;
    inset: 0;
    background: rgba(232,39,42,0.65);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity .2s;
  }

  .kz-tt-card:hover .kz-tt-overlay {
    opacity: 1;
  }

  .kz-tt-overlay-txt {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #fff;
  }

  .kz-tt-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    border-radius: 2px;
    z-index: 2;
  }

  .kz-tt-badge.trending {
    background: rgba(255,0,80,0.18);
    color: #ff6b6b;
    border: 1px solid rgba(255,0,80,0.25);
  }

  .kz-tt-badge.new {
    background: rgba(0,242,234,0.12);
    color: #00c2ba;
    border: 1px solid rgba(0,242,234,0.2);
  }

  .kz-tt-placeholder {
    width: 100%;
    height: 100%;
    background: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kz-tt-cta-strip {
    margin-top: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.07);
    flex-wrap: wrap;
    gap: 12px;
  }

  .kz-tt-cta-txt {
    font-size: 12px;
    color: #888880;
  }

  .kz-tt-cta-txt strong {
    color: #F2F0EB;
    font-weight: 600;
  }

  .kz-tt-cta-btn {
    background: #242424;
    color: #fff;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 10px 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    transition: background .15s;
  }

  .kz-tt-cta-btn:hover {
    background: #2e2e2e;
    color: #fff;
  }

  .kz-eyebrow {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #E8272A;
    margin-bottom: 6px;
  }

  @media (max-width: 768px) {
    .kz-tt-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .kz-tt-section { padding-left: 16px; padding-right: 16px; }
  }
</style>

<section class="kz-tt-section" id="kz-tiktok-{{ section.id }}">

  <div class="kz-tt-header">
    <div class="kz-tt-profile">
      <div class="kz-tt-avatar">
        {%- if section.settings.profile_image != blank -%}
          <img src="{{ section.settings.profile_image | image_url: width: 120 }}" alt="{{ section.settings.handle | escape }}" width="52" height="52" loading="lazy">
        {%- else -%}
          {{ section.settings.avatar_initials }}
        {%- endif -%}
      </div>
      <div>
        <div class="kz-eyebrow">{{ section.settings.eyebrow }}</div>
        <div class="kz-tt-handle">{{ section.settings.handle }}</div>
        <div class="kz-tt-stats">
          <span class="kz-tt-stat"><strong>{{ section.settings.followers }}</strong> follower</span>
          <span class="kz-tt-stat"><strong>{{ section.settings.likes }}</strong> likes</span>
        </div>
      </div>
    </div>
    <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" class="kz-tt-follow-btn">
      <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <path d="M41 13.5A10.5 10.5 0 0 1 30.5 3v10.5H20v21a5.5 5.5 0 1 0 5.5-5.5V19a15.5 15.5 0 1 1-15.5 15.5V13.5H41Z" fill="white"/>
      </svg>
      {{ section.settings.follow_btn_text }}
    </a>
  </div>

  <div class="kz-tt-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'video' -%}
        <a class="kz-tt-card" href="{{ block.settings.video_url }}" target="_blank" rel="noopener" {{ block.shopify_attributes }}>

          {%- if block.settings.thumbnail != blank -%}
            <img
              class="kz-tt-thumb"
              src="{{ block.settings.thumbnail | image_url: width: 600 }}"
              alt="{{ block.settings.caption | escape }}"
              width="{{ block.settings.thumbnail.width }}"
              height="{{ block.settings.thumbnail.height }}"
              loading="lazy"
            >
          {%- else -%}
            <div class="kz-tt-placeholder">
              <svg width="36" height="36" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <path d="M41 13.5A10.5 10.5 0 0 1 30.5 3v10.5H20v21a5.5 5.5 0 1 0 5.5-5.5V19a15.5 15.5 0 1 1-15.5 15.5V13.5H41Z" fill="rgba(255,255,255,0.1)"/>
              </svg>
            </div>
          {%- endif -%}

          {%- if block.settings.badge != blank -%}
            <div class="kz-tt-badge {{ block.settings.badge }}">
              {%- if block.settings.badge == 'trending' -%}🔥 Trending{%- else -%}Nuovo{%- endif -%}
            </div>
          {%- endif -%}

          <div class="kz-tt-card-label">
            {%- if block.settings.views != blank -%}
              <div class="kz-tt-views">{{ block.settings.views }} views</div>
            {%- endif -%}
            <div class="kz-tt-caption">{{ block.settings.caption }}</div>
          </div>

          <div class="kz-tt-overlay">
            <span class="kz-tt-overlay-txt">▶ Guarda</span>
          </div>

        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="kz-tt-cta-strip">
    <div class="kz-tt-cta-txt">Segui <strong>{{ section.settings.handle }}</strong> drop, review e training content ogni settimana</div>
    <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" class="kz-tt-cta-btn">
      <svg width="14" height="14" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <path d="M41 13.5A10.5 10.5 0 0 1 30.5 3v10.5H20v21a5.5 5.5 0 1 0 5.5-5.5V19a15.5 15.5 0 1 1-15.5 15.5V13.5H41Z" fill="white"/>
      </svg>
      {{ section.settings.follow_btn_text }}
    </a>
  </div>

</section>

{% schema %}
{
  "name": "KZ TikTok",
  "tag": "section",
  "class": "kz-tiktok-section",
  "settings": [
    {
      "type": "header",
      "content": "Profilo"
    },
    {
      "type": "image_picker",
      "id": "profile_image",
      "label": "Foto profilo",
      "info": "Se vuota, mostra le iniziali al posto della foto"
    },
    {
      "type": "text",
      "id": "avatar_initials",
      "label": "Iniziali (se non carichi una foto)",
      "default": "KZ"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Testo sopra il titolo",
      "default": "Seguici su TikTok"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Handle TikTok",
      "default": "@kombatzoneofficial"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "Link profilo TikTok"
    },
    {
      "type": "text",
      "id": "followers",
      "label": "Numero follower",
      "default": "47K"
    },
    {
      "type": "text",
      "id": "likes",
      "label": "Numero likes",
      "default": "280K"
    },
    {
      "type": "text",
      "id": "follow_btn_text",
      "label": "Testo bottone Segui",
      "default": "Segui su TikTok"
    },
    {
      "type": "header",
      "content": "Aspetto sezione"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Colore di sfondo",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Spazio sopra",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Spazio sotto",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video TikTok",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Link al video TikTok"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail (screenshot del video)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Didascalia",
          "default": "Descrizione breve del video #kombatzone"
        },
        {
          "type": "text",
          "id": "views",
          "label": "Visualizzazioni (es. 124K)",
          "default": "124K"
        },
        {
          "type": "select",
          "id": "badge",
          "label": "Badge",
          "options": [
            { "value": "", "label": "Nessuno" },
            { "value": "trending", "label": "🔥 Trending" },
            { "value": "new", "label": "Nuovo" }
          ],
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KZ TikTok",
      "blocks": [
        {
          "type": "video",
          "settings": {
            "caption": "UFC Full Kit unboxing — guantoni + shorts + borsa 🥊 #mma #ufc",
            "views": "124K",
            "badge": "trending"
          }
        },
        {
          "type": "video",
          "settings": {
            "caption": "Personalizzazione gratis su ogni ordine 👊 #boxe #kombatzone",
            "views": "58K",
            "badge": "new"
          }
        },
        {
          "type": "video",
          "settings": {
            "caption": "Muay Thai training con i nostri shorts 🔴 #muaythai #training",
            "views": "91K",
            "badge": ""
          }
        },
        {
          "type": "video",
          "settings": {
            "caption": "Set completo a €84 — qualità da pro 💪 #mma #gear #kombatzone",
            "views": "37K",
            "badge": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}

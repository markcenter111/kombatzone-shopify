{%- comment -%}
  ╔══════════════════════════════════════════════════════════╗
  ║  KOMBAT ZONE — Fighter Locker (configuratore a layer)    ║
  ║  Section: sections/kz2-locker.liquid                     ║
  ║  JS:      assets/kz2-locker.js                           ║
  ║                                                          ║
  ║  Dati: prodotti della collezione scelta in admin, con    ║
  ║  metafield namespace kzone:                              ║
  ║    kzone.slot        (string)  testa|corpo|gambe|piedi|accessorio
  ║    kzone.layer_image (file)    PNG trasparente del pezzo ║
  ║    kzone.z_index     (number)  ordine di stacking        ║
  ║  Default outfit: primo prodotto taggato "bestseller"     ║
  ║  di ogni slot. Slot senza selezione = vuoto (nessun      ║
  ║  layer, nessun costo).                                   ║
  ╚══════════════════════════════════════════════════════════╝
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} .kz2-locker {
    background: #0a0a0a;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    padding: {{ section.settings.padding_top }}px 32px {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-head { max-width: 1280px; margin: 0 auto 28px; }
  #shopify-section-{{ section.id }} .kz2-locker-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #E8272A;
    margin-bottom: 8px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 38px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .kz2-locker-title em { font-style: normal; color: #E8272A; }
  #shopify-section-{{ section.id }} .kz2-locker-sub { font-size: 12.5px; color: #888880; margin-top: 8px; }

  #shopify-section-{{ section.id }} .kz2-locker-grid {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 560px) 1fr;
    gap: 40px;
    align-items: start;
  }

  /* ── STAGE ── */
  #shopify-section-{{ section.id }} .kz2-locker-stage {
    position: relative;
    aspect-ratio: 4 / 5;
    background:
      radial-gradient(ellipse 70% 55% at 50% 42%, rgba(232,39,42,0.10) 0%, transparent 70%),
      #141414;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kz2-locker-stage img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .kz2-locker-stage .kz2-locker-layer { transition: opacity .25s ease; }
  #shopify-section-{{ section.id }} .kz2-locker-stage .kz2-locker-layer.kz2-hidden { opacity: 0; }

  /* ── LOCKER ── */
  #shopify-section-{{ section.id }} .kz2-locker-tabs {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-tab {
    background: #1a1a1a;
    border: 1px solid #333;
    color: #aaa;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s, transform .15s, box-shadow .15s;
  }
  #shopify-section-{{ section.id }} .kz2-locker-tab:hover { background: #2a2a2a; border-color: #555; color: #fff; transform: translateY(-1px); }
  #shopify-section-{{ section.id }} .kz2-locker-tab.active {
    background: #E8272A;
    border-color: #E8272A;
    color: #fff;
    font-weight: 700;
    box-shadow: 0 0 14px rgba(232,39,42,.35);
  }
  #shopify-section-{{ section.id }} .kz2-locker-tab .kz2-locker-tab-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4cbb7a;
    margin-left: 6px;
    vertical-align: 1px;
  }

  #shopify-section-{{ section.id }} .kz2-locker-panel { display: none; }
  #shopify-section-{{ section.id }} .kz2-locker-panel.active { display: block; }

  #shopify-section-{{ section.id }} .kz2-locker-pieces {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(84px, 1fr));
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-piece {
    background: #141414;
    border: 1px solid #222;
    border-radius: 10px;
    padding: 6px;
    cursor: pointer;
    text-align: center;
    transition: border-color .2s, transform .2s, box-shadow .2s;
  }
  #shopify-section-{{ section.id }} .kz2-locker-piece:hover:not(.unavailable) {
    transform: translateY(-3px);
    box-shadow: 0 10px 22px rgba(0,0,0,.45);
    border-color: #555;
  }
  #shopify-section-{{ section.id }} .kz2-locker-piece.active { border-color: #E8272A; box-shadow: 0 0 14px rgba(232,39,42,.25); }
  #shopify-section-{{ section.id }} .kz2-locker-piece.unavailable { opacity: .35; cursor: not-allowed; }
  #shopify-section-{{ section.id }} .kz2-locker-piece-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 6px;
    background: #1a1a1a;
    display: block;
  }
  #shopify-section-{{ section.id }} .kz2-locker-piece-img.kz2-none {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4a4a44;
    font-size: 22px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-piece-name {
    font-size: 9.5px;
    color: #aaa;
    margin-top: 6px;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 24px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-piece-price {
    font-size: 10.5px;
    font-weight: 700;
    color: #F2F0EB;
    margin-top: 2px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-piece.active .kz2-locker-piece-name { color: #F2F0EB; }

  /* Taglie del pezzo selezionato — stessi bottoni della pagina prodotto */
  #shopify-section-{{ section.id }} .kz2-locker-sizes-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    color: #888880;
    text-transform: uppercase;
    margin: 16px 0 8px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-sizes { display: flex; gap: 6px; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .kz2-locker-size-btn {
    min-width: 44px;
    height: 44px;
    padding: 0 14px;
    background: transparent;
    border: 1px solid rgba(242,240,235,0.25);
    border-radius: 1px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .04em;
    cursor: pointer;
    transition: background .15s, border-color .15s, transform .1s;
  }
  #shopify-section-{{ section.id }} .kz2-locker-size-btn:hover:not(.unavailable) { border-color: rgba(242,240,235,0.6); transform: translateY(-1px); }
  #shopify-section-{{ section.id }} .kz2-locker-size-btn.active { background: #E8272A; border-color: #E8272A; color: #fff; box-shadow: 0 0 14px rgba(232,39,42,.35); }
  #shopify-section-{{ section.id }} .kz2-locker-size-btn.unavailable { opacity: .35; text-decoration: line-through; cursor: not-allowed; }

  /* ── BARRA TOTALE ── */
  #shopify-section-{{ section.id }} .kz2-locker-bar {
    position: sticky;
    bottom: 12px;
    margin-top: 22px;
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 12px 16px;
    z-index: 5;
  }
  #shopify-section-{{ section.id }} .kz2-locker-total-block { display: flex; flex-direction: column; line-height: 1.15; flex-shrink: 0; }
  #shopify-section-{{ section.id }} .kz2-locker-total-label {
    font-size: 8.5px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #888880;
  }
  #shopify-section-{{ section.id }} .kz2-locker-total {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 24px;
    font-weight: 800;
    color: #F2F0EB;
  }
  #shopify-section-{{ section.id }} .kz2-locker-count { font-size: 10px; color: #888880; }
  #shopify-section-{{ section.id }} .kz2-locker-cta {
    flex: 1;
    height: 50px;
    background: #E8272A;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  #shopify-section-{{ section.id }} .kz2-locker-cta:hover:not(:disabled) {
    background: #c41f22;
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(232,39,42,.35);
  }
  #shopify-section-{{ section.id }} .kz2-locker-cta:active { transform: translateY(0) scale(.98); box-shadow: none; }
  #shopify-section-{{ section.id }} .kz2-locker-cta:disabled { background: #3a3a36; cursor: not-allowed; transform: none; box-shadow: none; }

  /* ── MINI-POPUP CONFERMA (stesso pattern del quick-buy) ── */
  #shopify-section-{{ section.id }} .kz2-locker-added {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease;
    z-index: 999998;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added.show { opacity: 1; pointer-events: auto; }
  #shopify-section-{{ section.id }} .kz2-locker-added-card {
    background: #161616;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 26px 26px 22px;
    width: min(320px, calc(100% - 48px));
    text-align: center;
    box-shadow: 0 22px 60px rgba(0,0,0,.6);
    transform: translateY(10px) scale(.96);
    transition: transform .25s cubic-bezier(.2,.6,.2,1);
  }
  #shopify-section-{{ section.id }} .kz2-locker-added.show .kz2-locker-added-card { transform: translateY(0) scale(1); }
  #shopify-section-{{ section.id }} .kz2-locker-added-check {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(76,187,122,0.12);
    border: 1.5px solid #4cbb7a;
    color: #4cbb7a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added-check svg { width: 22px; height: 22px; }
  #shopify-section-{{ section.id }} .kz2-locker-added-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    color: #F2F0EB;
    margin-bottom: 16px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added-cart {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 46px;
    background: #E8272A;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    margin-bottom: 8px;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added-cart:hover { background: #c41f22; transform: translateY(-2px); box-shadow: 0 8px 22px rgba(232,39,42,.35); }
  #shopify-section-{{ section.id }} .kz2-locker-added-continue {
    width: 100%;
    height: 42px;
    background: transparent;
    border: 1px solid rgba(242,240,235,0.35);
    border-radius: 8px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color .2s ease, transform .2s ease, background .2s ease;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added-continue:hover { border-color: #F2F0EB; transform: translateY(-2px); background: rgba(255,255,255,.04); }

  #shopify-section-{{ section.id }} .kz2-locker-empty-state {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 0;
    text-align: center;
    color: #888880;
    font-size: 13px;
  }

  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .kz2-locker { padding-left: 16px; padding-right: 16px; }
    #shopify-section-{{ section.id }} .kz2-locker-grid { grid-template-columns: 1fr; gap: 24px; }
    #shopify-section-{{ section.id }} .kz2-locker-stage { max-width: 440px; margin: 0 auto; width: 100%; }
    #shopify-section-{{ section.id }} .kz2-locker-title { font-size: 30px; }
    #shopify-section-{{ section.id }} .kz2-locker-tabs { overflow-x: auto; flex-wrap: nowrap; padding-bottom: 4px; scrollbar-width: none; }
    #shopify-section-{{ section.id }} .kz2-locker-tabs::-webkit-scrollbar { display: none; }
    #shopify-section-{{ section.id }} .kz2-locker-tab { white-space: nowrap; flex-shrink: 0; }
    #shopify-section-{{ section.id }} .kz2-locker-bar { position: sticky; bottom: 10px; }
  }
</style>

{%- liquid
  assign src_collection = section.settings.source_collection
  assign valid_slots = 'testa,corpo,gambe,piedi,accessorio' | split: ','
-%}

<div class="kz2-locker" id="kz2-locker-{{ section.id }}" data-section-id="{{ section.id }}">

  <div class="kz2-locker-head">
    <div class="kz2-locker-eyebrow">{{ 'sections.kz2-locker.eyebrow' | t }}</div>
    <div class="kz2-locker-title">{{ 'sections.kz2-locker.title_1' | t }} <em>{{ 'sections.kz2-locker.title_2' | t }}</em></div>
    <div class="kz2-locker-sub">{{ 'sections.kz2-locker.subtitle' | t }}</div>
  </div>

  {%- capture pieces_json -%}
    [
    {%- assign first = true -%}
    {%- if src_collection != blank -%}
      {%- for p in src_collection.products limit: 60 -%}
        {%- assign slot = p.metafields.kzone.slot.value | downcase | strip -%}
        {%- if valid_slots contains slot and p.metafields.kzone.layer_image.value != blank -%}
          {%- unless first -%},{%- endunless -%}
          {%- assign first = false -%}
          {
            "handle": {{ p.handle | json }},
            "title": {{ p.title | json }},
            "slot": {{ slot | json }},
            "z": {{ p.metafields.kzone.z_index.value | default: 1 }},
            "layer": {{ p.metafields.kzone.layer_image.value | image_url: width: 1000 | json }},
            "thumb": {{ p.featured_image | image_url: width: 240 | json }},
            "available": {{ p.available | json }},
            "bestseller": {% if p.tags contains 'bestseller' %}true{% else %}false{% endif %},
            "variants": [
              {%- for v in p.variants -%}
                { "id": {{ v.id }}, "title": {{ v.title | json }}, "price": {{ v.price }}, "available": {{ v.available | json }} }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
    ]
  {%- endcapture -%}

  {%- assign has_pieces = false -%}
  {%- if pieces_json contains '"handle"' -%}{%- assign has_pieces = true -%}{%- endif -%}

  {%- if has_pieces -%}
    <div class="kz2-locker-grid">

      <div class="kz2-locker-stage" data-locker-stage>
        {%- if section.settings.base_image != blank -%}
          <img src="{{ section.settings.base_image | image_url: width: 1000 }}" alt="{{ 'sections.kz2-locker.stage_alt' | t }}" loading="lazy">
        {%- endif -%}
        {%- comment -%} I layer dei pezzi vengono montati qui dal JS, ordinati per z_index {%- endcomment -%}
      </div>

      <div class="kz2-locker-side">
        <div class="kz2-locker-tabs" role="tablist" data-locker-tabs>
          {%- for slot in valid_slots -%}
            <button type="button" class="kz2-locker-tab" role="tab" data-locker-tab="{{ slot }}">
              {{ 'sections.kz2-locker.slot_' | append: slot | t }}
            </button>
          {%- endfor -%}
        </div>

        {%- for slot in valid_slots -%}
          <div class="kz2-locker-panel" data-locker-panel="{{ slot }}">
            <div class="kz2-locker-pieces" data-locker-pieces="{{ slot }}"></div>
            <div data-locker-sizes-wrap="{{ slot }}" style="display:none">
              <div class="kz2-locker-sizes-label">{{ 'sections.kz2-locker.size' | t }}</div>
              <div class="kz2-locker-sizes" data-locker-sizes="{{ slot }}"></div>
            </div>
          </div>
        {%- endfor -%}

        <div class="kz2-locker-bar">
          <div class="kz2-locker-total-block">
            <span class="kz2-locker-total-label">{{ 'sections.kz2-locker.total' | t }}</span>
            <span class="kz2-locker-total" data-locker-total>€0,00</span>
            <span class="kz2-locker-count" data-locker-count></span>
          </div>
          <button type="button" class="kz2-locker-cta" data-locker-add disabled>
            {{ 'sections.kz2-locker.add_to_cart' | t }}
          </button>
        </div>
      </div>

    </div>

    <div class="kz2-locker-added" data-locker-added aria-hidden="true">
      <div class="kz2-locker-added-card">
        <div class="kz2-locker-added-check">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
        </div>
        <div class="kz2-locker-added-title">{{ 'sections.kz2-locker.added' | t }}</div>
        <a class="kz2-locker-added-cart" href="/cart">{{ 'sections.kz2-locker.go_cart' | t }}</a>
        <button type="button" class="kz2-locker-added-continue" data-locker-continue>{{ 'sections.kz2-locker.continue' | t }}</button>
      </div>
    </div>

    <script type="application/json" data-locker-data>{{ pieces_json }}</script>
    <script type="application/json" data-locker-i18n>
      {
        "none": {{ 'sections.kz2-locker.none' | t | json }},
        "piece": {{ 'sections.kz2-locker.piece' | t | json }},
        "pieces": {{ 'sections.kz2-locker.pieces' | t | json }},
        "out_of_stock": {{ 'sections.kz2-locker.out_of_stock' | t | json }},
        "error": {{ 'sections.kz2-locker.error' | t | json }}
      }
    </script>
    <script src="{{ 'kz2-locker.js' | asset_url }}" defer></script>
  {%- else -%}
    <div class="kz2-locker-empty-state">{{ 'sections.kz2-locker.empty_state' | t }}</div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "KZ — Fighter Locker",
  "tag": "section",
  "class": "kz2-locker-section",
  "settings": [
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Collezione pezzi del locker",
      "info": "Prodotti con metafield kzone.slot, kzone.layer_image, kzone.z_index"
    },
    {
      "type": "image_picker",
      "id": "base_image",
      "label": "Illustrazione base del fighter",
      "info": "Silhouette/base su cui si sovrappongono i layer"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "label": "Spazio sopra"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "label": "Spazio sotto"
    }
  ],
  "locales": {
    "it": {
      "eyebrow": "Fighter Locker",
      "title_1": "Monta il tuo",
      "title_2": "arsenale.",
      "subtitle": "Scegli i pezzi, guarda il fighter prendere forma, porta tutto sul ring.",
      "stage_alt": "Il tuo fighter",
      "slot_testa": "Testa",
      "slot_corpo": "Corpo",
      "slot_gambe": "Gambe",
      "slot_piedi": "Piedi",
      "slot_accessorio": "Accessori",
      "size": "Taglia",
      "none": "Vuoto",
      "total": "Totale set",
      "piece": "pezzo",
      "pieces": "pezzi",
      "add_to_cart": "Aggiungi il set al carrello",
      "added": "Set aggiunto al carrello!",
      "go_cart": "Vai al carrello",
      "continue": "Continua a montare",
      "out_of_stock": "Esaurito",
      "error": "Errore — riprova",
      "empty_state": "Configura la collezione sorgente e i metafield kzone.slot / kzone.layer_image sui prodotti per attivare il locker."
    },
    "en": {
      "eyebrow": "Fighter Locker",

{%- comment -%}
  ╔══════════════════════════════════════════════════════════╗
  ║  KOMBAT ZONE — Fighter Locker v2 (hotspot sul manichino) ║
  ║  Sezione: sections/kz2-locker.liquid                     ║
  ║  JS:      assets/kz2-locker.js                           ║
  ║                                                          ║
  ║  Slot: casco, maglia, pantaloncini, guanti,              ║
  ║        parastinchi, paradenti                            ║
  ║  I vecchi valori metafield vengono mappati:              ║
  ║  testa→casco, corpo→maglia, gambe→pantaloncini,          ║
  ║  piedi→parastinchi, accessorio→guanti                    ║
  ║                                                          ║
  ║  UX: pallini chiusi sul manichino → hover/tap apre il    ║
  ║  menu del pezzo → selezione = pallino verde.             ║
  ╚══════════════════════════════════════════════════════════╝
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} .kz2-locker {
    background: #0a0a0a;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    padding: {{ section.settings.padding_top }}px 32px {{ section.settings.padding_bottom }}px;
    font-size: 14px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-head { max-width: 1280px; margin: 0 auto 28px; }
  #shopify-section-{{ section.id }} .kz2-locker-eyebrow {
    font-size: 10px; font-weight: 700; letter-spacing: .18em;
    text-transform: uppercase; color: #E8272A; margin-bottom: 8px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 38px; font-weight: 900; text-transform: uppercase; line-height: 1;
  }
  #shopify-section-{{ section.id }} .kz2-locker-title em { font-style: normal; color: #E8272A; }
  #shopify-section-{{ section.id }} .kz2-locker-sub { font-size: 12.5px; color: #888880; margin-top: 8px; }

  #shopify-section-{{ section.id }} .kz2-locker-grid {
    max-width: 1280px; margin: 0 auto;
    display: grid; grid-template-columns: minmax(0, 620px) 1fr;
    gap: 40px; align-items: start;
  }

  /* ── PALCO ── */
  #shopify-section-{{ section.id }} .kz2-locker-stage { position: relative; }
  #shopify-section-{{ section.id }} .kz2-locker-canvas {
    position: relative;
    aspect-ratio: 4 / 5;
    background:
      radial-gradient(ellipse 75% 50% at 50% 38%, rgba(232,39,42,0.16) 0%, transparent 68%),
      radial-gradient(ellipse 120% 60% at 50% 108%, rgba(0,0,0,0.85) 0%, transparent 60%),
      repeating-linear-gradient(60deg, transparent 0, transparent 34px, rgba(255,255,255,0.02) 34px, rgba(255,255,255,0.02) 35px),
      repeating-linear-gradient(-60deg, transparent 0, transparent 34px, rgba(255,255,255,0.02) 34px, rgba(255,255,255,0.02) 35px),
      linear-gradient(180deg, #161314 0%, #0d0d0d 55%, #080808 100%);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .kz2-locker-canvas img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center; pointer-events: none;
    transition: transform .35s cubic-bezier(.2,.6,.2,1);
  }
  #shopify-section-{{ section.id }} .kz2-locker-canvas.kz2-zoomed img {
    transform: scale(1.5);
    transform-origin: 50% 26%;
  }
  #shopify-section-{{ section.id }} .kz2-zoom-btn {
    position: absolute; right: 12px; bottom: 12px; z-index: 12;
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(10,10,10,0.78);
    border: 1.5px solid rgba(255,255,255,0.3);
    color: #fff; cursor: pointer; padding: 0;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s ease, border-color .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  #shopify-section-{{ section.id }} .kz2-zoom-btn svg { width: 16px; height: 16px; }
  #shopify-section-{{ section.id }} .kz2-zoom-btn:hover {
    background: #E8272A; border-color: #E8272A; transform: scale(1.1);
    box-shadow: 0 0 14px rgba(232,39,42,.5);
  }
  #shopify-section-{{ section.id }} .kz2-zoom-btn.active { background: #E8272A; border-color: #E8272A; }
  #shopify-section-{{ section.id }} .kz2-locker-canvas .kz2-locker-layer { transition: opacity .25s ease; }
  #shopify-section-{{ section.id }} .kz2-locker-canvas .kz2-locker-layer.kz2-hidden { opacity: 0; }

  /* ── PALLINI HOTSPOT ── */
  #shopify-section-{{ section.id }} .kz2-dot-wrap { position: absolute; z-index: 10; }
  #shopify-section-{{ section.id }} .kz2-dot {
    width: 34px; height: 34px; border-radius: 50%;
    background: rgba(10,10,10,0.78);
    border: 2px solid rgba(255,255,255,0.45);
    color: #fff; cursor: pointer; padding: 0;
    display: flex; align-items: center; justify-content: center;
    transition: transform .2s ease, border-color .2s ease, background .2s ease, box-shadow .2s ease;
    animation: kz2-dot-pulse 2.4s ease-in-out infinite;
  }
  #shopify-section-{{ section.id }} .kz2-dot svg { width: 15px; height: 15px; transition: transform .25s ease; }
  #shopify-section-{{ section.id }} .kz2-dot:hover { transform: scale(1.15); border-color: #E8272A; box-shadow: 0 0 14px rgba(232,39,42,.5); }
  #shopify-section-{{ section.id }} .kz2-dot-wrap.open .kz2-dot { border-color: #E8272A; background: #E8272A; animation: none; }
  #shopify-section-{{ section.id }} .kz2-dot-wrap.open .kz2-dot svg { transform: rotate(45deg); }
  #shopify-section-{{ section.id }} .kz2-dot-wrap.filled .kz2-dot {
    border-color: #4cbb7a; background: #4cbb7a; animation: none;
    box-shadow: 0 0 12px rgba(76,187,122,.5);
  }
  @keyframes kz2-dot-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(232,39,42,0); }
    50%      { box-shadow: 0 0 0 6px rgba(232,39,42,.14); }
  }

  /* posizioni: lato sinistro = protezioni, destro = vestiti */
  #shopify-section-{{ section.id }} .kz2-dot-wrap[data-slot="paradenti"]   { left: 39%; top: 14%; }
  #shopify-section-{{ section.id }} .kz2-dot-wrap[data-slot="guanti"]      { left: 34%; top: 29%; }
  #shopify-section-{{ section.id }} .kz2-dot-wrap[data-slot="parastinchi"] { left: 37%; top: 74%; }
  #shopify-section-{{ section.id }} .kz2-dot-wrap[data-slot="casco"]       { left: 58%; top: 9%;  }
  #shopify-section-{{ section.id }} .kz2-dot-wrap[data-slot="maglia"]      { left: 61%; top: 32%; }
  #shopify-section-{{ section.id }} .kz2-dot-wrap[data-slot="pantaloncini"]{ left: 60%; top: 51%; }

  #shopify-section-{{ section.id }} .kz2-dot-label {
    position: absolute; top: 50%; transform: translateY(-50%);
    font-size: 9px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: #b9b7b0; white-space: nowrap; pointer-events: none;
  }
  #shopify-section-{{ section.id }} .kz2-dot-wrap.kz2-left .kz2-dot-label { right: calc(100% + 8px); }
  #shopify-section-{{ section.id }} .kz2-dot-wrap.kz2-right .kz2-dot-label { left: calc(100% + 8px); }

  /* ── POPOVER SCELTA PEZZO ── */
  #shopify-section-{{ section.id }} .kz2-pop {
    position: absolute; top: -8px; z-index: 30;
    width: 252px;
    background: #141414;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 12px;
    box-shadow: 0 22px 60px rgba(0,0,0,.65);
    opacity: 0; pointer-events: none;
    transform: translateY(6px) scale(.96);
    transition: opacity .18s ease, transform .22s cubic-bezier(.2,.6,.2,1);
    max-height: 360px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #333 transparent;
  }
  #shopify-section-{{ section.id }} .kz2-pop::-webkit-scrollbar { width: 6px; }
  #shopify-section-{{ section.id }} .kz2-pop::-webkit-scrollbar-thumb { background: #333; border-radius: 99px; }
  #shopify-section-{{ section.id }} .kz2-pop::-webkit-scrollbar-track { background: transparent; }
  #shopify-section-{{ section.id }} .kz2-dot-wrap.kz2-left .kz2-pop { right: calc(100% + 12px); }
  #shopify-section-{{ section.id }} .kz2-dot-wrap.kz2-right .kz2-pop { left: calc(100% + 12px); }
  #shopify-section-{{ section.id }} .kz2-dot-wrap.open .kz2-pop { opacity: 1; pointer-events: auto; transform: translateY(0) scale(1); }
  #shopify-section-{{ section.id }} .kz2-pop-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px; font-weight: 900; text-transform: uppercase; letter-spacing: .05em;
    color: #E8272A; margin-bottom: 10px;
  }
  #shopify-section-{{ section.id }} .kz2-pop-pieces {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;
  }
  #shopify-section-{{ section.id }} .kz2-piece {
    background: #1a1a1a; border: 1px solid #262626; border-radius: 8px;
    padding: 4px; cursor: pointer; text-align: center;
    transition: border-color .15s, transform .15s;
  }
  #shopify-section-{{ section.id }} .kz2-piece:hover:not(.unavailable) { transform: translateY(-2px); border-color: #555; }
  #shopify-section-{{ section.id }} .kz2-piece.active { border-color: #4cbb7a; box-shadow: 0 0 10px rgba(76,187,122,.25); }
  #shopify-section-{{ section.id }} .kz2-piece.unavailable { opacity: .35; cursor: not-allowed; }
  #shopify-section-{{ section.id }} .kz2-piece-img {
    width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 5px; display: block; background: #111;
  }
  #shopify-section-{{ section.id }} .kz2-piece-img.kz2-none {
    display: flex; align-items: center; justify-content: center; color: #4a4a44; font-size: 18px;
  }
  #shopify-section-{{ section.id }} .kz2-piece-name {
    font-size: 8.5px; color: #aaa; margin-top: 4px; line-height: 1.2;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    min-height: 20px;
  }
  #shopify-section-{{ section.id }} .kz2-piece-price { font-size: 9.5px; font-weight: 700; color: #F2F0EB; }
  #shopify-section-{{ section.id }} .kz2-pop-sizes-label {
    font-size: 8.5px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: #888880; margin: 10px 0 6px;
  }
  #shopify-section-{{ section.id }} .kz2-pop-sizes { display: flex; gap: 5px; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .kz2-size-btn {
    min-width: 32px; height: 30px; padding: 0 8px;
    background: transparent; border: 1px solid rgba(242,240,235,0.25); border-radius: 1px;
    color: #F2F0EB; font-family: 'Inter', sans-serif; font-size: 10.5px; font-weight: 600;
    cursor: pointer; transition: background .15s, border-color .15s;
  }
  #shopify-section-{{ section.id }} .kz2-size-btn.active { background: #E8272A; border-color: #E8272A; color: #fff; }
  #shopify-section-{{ section.id }} .kz2-size-btn.unavailable { opacity: .35; text-decoration: line-through; cursor: not-allowed; }

  /* ── COLONNA RIEPILOGO ── */
  #shopify-section-{{ section.id }} .kz2-side-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px; font-weight: 900; text-transform: uppercase; margin-bottom: 14px;
  }
  #shopify-section-{{ section.id }} .kz2-sum-row {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  #shopify-section-{{ section.id }} .kz2-sum-slot {
    font-size: 9.5px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #888880;
    flex-shrink: 0; width: 96px;
  }
  #shopify-section-{{ section.id }} .kz2-sum-val { font-size: 12px; color: #F2F0EB; flex: 1; }
  #shopify-section-{{ section.id }} .kz2-sum-val.kz2-empty { color: #4a4a44; }
  #shopify-section-{{ section.id }} .kz2-sum-price { font-size: 12px; font-weight: 700; color: #F2F0EB; flex-shrink: 0; }

  #shopify-section-{{ section.id }} .kz2-locker-bar {
    position: sticky; bottom: 12px; margin-top: 22px;
    display: flex; align-items: center; gap: 14px;
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;
    padding: 12px 16px; z-index: 5;
  }
  #shopify-section-{{ section.id }} .kz2-locker-total-block { display: flex; flex-direction: column; line-height: 1.15; flex-shrink: 0; }
  #shopify-section-{{ section.id }} .kz2-locker-total-label {
    font-size: 8.5px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #888880;
  }
  #shopify-section-{{ section.id }} .kz2-locker-total {
    font-family: 'Barlow Condensed', sans-serif; font-size: 24px; font-weight: 800; color: #F2F0EB;
  }
  #shopify-section-{{ section.id }} .kz2-locker-count { font-size: 10px; color: #888880; }
  #shopify-section-{{ section.id }} .kz2-locker-cta {
    flex: 1; height: 50px; background: #E8272A; color: #fff; border: none; border-radius: 8px;
    font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600;
    letter-spacing: .1em; text-transform: uppercase; cursor: pointer;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  #shopify-section-{{ section.id }} .kz2-locker-cta:hover:not(:disabled) {
    background: #c41f22; transform: translateY(-2px); box-shadow: 0 8px 22px rgba(232,39,42,.35);
  }
  #shopify-section-{{ section.id }} .kz2-locker-cta:active { transform: translateY(0) scale(.98); box-shadow: none; }
  #shopify-section-{{ section.id }} .kz2-locker-cta:disabled { background: #3a3a36; cursor: not-allowed; transform: none; box-shadow: none; }

  /* ── MINI-POPUP CONFERMA ── */
  #shopify-section-{{ section.id }} .kz2-locker-added {
    position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
    opacity: 0; pointer-events: none; transition: opacity .2s ease; z-index: 999998;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added.show { opacity: 1; pointer-events: auto; }
  #shopify-section-{{ section.id }} .kz2-locker-added-card {
    background: #161616; border: 1px solid rgba(255,255,255,0.1); border-radius: 14px;
    padding: 26px 26px 22px; width: min(320px, calc(100% - 48px)); text-align: center;
    box-shadow: 0 22px 60px rgba(0,0,0,.6);
    transform: translateY(10px) scale(.96);
    transition: transform .25s cubic-bezier(.2,.6,.2,1);
  }
  #shopify-section-{{ section.id }} .kz2-locker-added.show .kz2-locker-added-card { transform: translateY(0) scale(1); }
  #shopify-section-{{ section.id }} .kz2-locker-added-check {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(76,187,122,0.12); border: 1.5px solid #4cbb7a; color: #4cbb7a;
    display: flex; align-items: center; justify-content: center; margin: 0 auto 12px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added-check svg { width: 22px; height: 22px; }
  #shopify-section-{{ section.id }} .kz2-locker-added-title {
    font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 900;
    text-transform: uppercase; color: #F2F0EB; margin-bottom: 16px;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added-cart {
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 46px; background: #E8272A; color: #fff; border: none; border-radius: 8px;
    font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600;
    letter-spacing: .1em; text-transform: uppercase; cursor: pointer; text-decoration: none;
    margin-bottom: 8px; transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added-cart:hover { background: #c41f22; transform: translateY(-2px); box-shadow: 0 8px 22px rgba(232,39,42,.35); }
  #shopify-section-{{ section.id }} .kz2-locker-added-continue {
    width: 100%; height: 42px; background: transparent;
    border: 1px solid rgba(242,240,235,0.35); border-radius: 8px; color: #F2F0EB;
    font-family: 'Inter', sans-serif; font-size: 11.5px; font-weight: 600;
    letter-spacing: .08em; text-transform: uppercase; cursor: pointer;
    transition: border-color .2s ease, transform .2s ease, background .2s ease;
  }
  #shopify-section-{{ section.id }} .kz2-locker-added-continue:hover { border-color: #F2F0EB; transform: translateY(-2px); background: rgba(255,255,255,.04); }

  #shopify-section-{{ section.id }} .kz2-locker-empty-state {
    max-width: 1280px; margin: 0 auto; padding: 48px 0; text-align: center; color: #888880; font-size: 13px;
  }

  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .kz2-locker { padding-left: 16px; padding-right: 16px; }
    #shopify-section-{{ section.id }} .kz2-locker-grid { grid-template-columns: 1fr; gap: 24px; }
    #shopify-section-{{ section.id }} .kz2-locker-stage { max-width: 480px; margin: 0 auto; width: 100%; }
    #shopify-section-{{ section.id }} .kz2-locker-title { font-size: 30px; }
    #shopify-section-{{ section.id }} .kz2-pop { width: 216px; }
    #shopify-section-{{ section.id }} .kz2-dot-label { display: none; }
  }
</style>

{%- liquid
  assign src_collection = section.settings.source_collection
  assign valid_slots = 'casco,maglia,pantaloncini,guanti,parastinchi,paradenti' | split: ','
-%}

<div class="kz2-locker" id="kz2-locker-{{ section.id }}" data-section-id="{{ section.id }}">

  <div class="kz2-locker-head">
    <div class="kz2-locker-eyebrow">{{ 'sections.kz2-locker.eyebrow' | t }}</div>
    <div class="kz2-locker-title">{{ 'sections.kz2-locker.title_1' | t }} <em>{{ 'sections.kz2-locker.title_2' | t }}</em></div>
    <div class="kz2-locker-sub">{{ 'sections.kz2-locker.subtitle' | t }}</div>
  </div>

  {%- capture pieces_json -%}
    [
    {%- assign first = true -%}
    {%- if src_collection != blank -%}
      {%- for p in src_collection.products limit: 60 -%}
        {%- assign slot = p.metafields.kzone.slot.value | downcase | strip -%}
        {%- case slot -%}
          {%- when 'testa' -%}{%- assign slot = 'casco' -%}
          {%- when 'corpo' -%}{%- assign slot = 'maglia' -%}
          {%- when 'gambe' -%}{%- assign slot = 'pantaloncini' -%}
          {%- when 'piedi' -%}{%- assign slot = 'parastinchi' -%}
          {%- when 'accessorio' -%}{%- assign slot = 'guanti' -%}
        {%- endcase -%}
        {%- if valid_slots contains slot -%}
          {%- unless first -%},{%- endunless -%}
          {%- assign first = false -%}
          {
            "handle": {{ p.handle | json }},
            "title": {{ p.title | json }},
            "slot": {{ slot | json }},
            "z": {{ p.metafields.kzone.z_index.value | default: 1 }},
            "layer": {% if p.metafields.kzone.layer_image.value != blank %}{{ p.metafields.kzone.layer_image.value | image_url: width: 1000 | json }}{% else %}null{% endif %},
            "thumb": {{ p.featured_image | image_url: width: 240 | json }},
            "available": {{ p.available | json }},
            "bestseller": {% if p.tags contains 'bestseller' %}true{% else %}false{% endif %},
            "variants": [
              {%- for v in p.variants -%}
                { "id": {{ v.id }}, "title": {{ v.title | json }}, "price": {{ v.price }}, "available": {{ v.available | json }} }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
    ]
  {%- endcapture -%}

  {%- assign has_pieces = false -%}
  {%- if pieces_json contains '"handle"' -%}{%- assign has_pieces = true -%}{%- endif -%}

  {%- if has_pieces -%}
    <div class="kz2-locker-grid">

      <div class="kz2-locker-stage">
        <div class="kz2-locker-canvas" data-locker-stage>
          {%- if section.settings.base_image != blank -%}
            <img src="{{ section.settings.base_image | image_url: width: 1600 }}" alt="{{ 'sections.kz2-locker.stage_alt' | t }}" loading="lazy">
          {%- endif -%}
          <button type="button" class="kz2-zoom-btn" data-locker-zoom aria-label="Zoom" aria-pressed="false">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6"/></svg>
          </button>
        </div>

        {%- for slot in valid_slots -%}
          {%- assign side = 'kz2-right' -%}
          {%- if slot == 'guanti' or slot == 'parastinchi' or slot == 'paradenti' -%}{%- assign side = 'kz2-left' -%}{%- endif -%}
          <div class="kz2-dot-wrap {{ side }}" data-slot="{{ slot }}" data-locker-dot>
            <button type="button" class="kz2-dot" aria-haspopup="true" aria-expanded="false" aria-label="{{ 'sections.kz2-locker.slot_' | append: slot | t }}">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            </button>
            <span class="kz2-dot-label">{{ 'sections.kz2-locker.slot_' | append: slot | t }}</span>
            <div class="kz2-pop" role="menu">
              <div class="kz2-pop-title">{{ 'sections.kz2-locker.slot_' | append: slot | t }}</div>
              <div class="kz2-pop-pieces" data-locker-pieces="{{ slot }}"></div>
              <div data-locker-sizes-wrap="{{ slot }}" style="display:none">
                <div class="kz2-pop-sizes-label">{{ 'sections.kz2-locker.size' | t }}</div>
                <div class="kz2-pop-sizes" data-locker-sizes="{{ slot }}"></div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="kz2-locker-side">
        <div class="kz2-side-title">{{ 'sections.kz2-locker.your_set' | t }}</div>
        {%- for slot in valid_slots -%}
          <div class="kz2-sum-row" data-locker-sum="{{ slot }}">
            <span class="kz2-sum-slot">{{ 'sections.kz2-locker.slot_' | append: slot | t }}</span>
            <span class="kz2-sum-val kz2-empty" data-sum-name>{{ 'sections.kz2-locker.none' | t }}</span>
            <span class="kz2-sum-price" data-sum-price></span>
          </div>
        {%- endfor -%}

        <div class="kz2-locker-bar">
          <div class="kz2-locker-total-block">
            <span class="kz2-locker-total-label">{{ 'sections.kz2-locker.total' | t }}</span>
            <span class="kz2-locker-total" data-locker-total>€0,00</span>
            <span class="kz2-locker-count" data-locker-count></span>
          </div>
          <button type="button" class="kz2-locker-cta" data-locker-add disabled>
            {{ 'sections.kz2-locker.add_to_cart' | t }}
          </button>
        </div>
      </div>

    </div>

    <div class="kz2-locker-added" data-locker-added aria-hidden="true">
      <div class="kz2-locker-added-card">
        <div class="kz2-locker-added-check">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
        </div>
        <div class="kz2-locker-added-title">{{ 'sections.kz2-locker.added' | t }}</div>
        <a class="kz2-locker-added-cart" href="/cart">{{ 'sections.kz2-locker.go_cart' | t }}</a>
        <button type="button" class="kz2-locker-added-continue" data-locker-continue>{{ 'sections.kz2-locker.continue' | t }}</button>
      </div>
    </div>

    <script type="application/json" data-locker-data>{{ pieces_json }}</script>
    <script type="application/json" data-locker-i18n>
      {
        "none": {{ 'sections.kz2-locker.none' | t | json }},
        "piece": {{ 'sections.kz2-locker.piece' | t | json }},
        "pieces": {{ 'sections.kz2-locker.pieces' | t | json }},
        "out_of_stock": {{ 'sections.kz2-locker.out_of_stock' | t | json }},
        "error": {{ 'sections.kz2-locker.error' | t | json }},
        "update_set": {{ 'sections.kz2-locker.update_set' | t | json }}
      }
    </script>
    <script src="{{ 'kz2-locker.js' | asset_url }}" defer></script>
  {%- else -%}
    <div class="kz2-locker-empty-state">{{ 'sections.kz2-locker.empty_state' | t }}</div>
  {%- endif -%}

</div>


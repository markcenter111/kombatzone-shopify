{% comment %}
  KOMBAT ZONE — Product Quick-Buy Modal
  File: snippets/kz-product-modal.liquid
  Includi in theme.liquid prima di </body>:
    {% render 'kz-product-modal' %}
    <script src="{{ 'kz-product-modal.js' | asset_url }}" defer></script>
{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  /* ══════════════════════════════════════════
     CONFIGURAZIONE RAPIDA — modifica qui
     ══════════════════════════════════════════ */
  :root {
    --kz-modal-max-width: 1200px;  /* larghezza massima modal */
    --kz-modal-min-height: 520px;  /* altezza minima modal */
    --kz-modal-img-border: 5px solid #111; /* bordo immagine principale */
    --kz-modal-slide-speed: 0.4s;  /* velocità transizione slideshow */
  }

  /* ── OVERLAY ── */
  #kz-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.82);
    z-index: 999999;
    align-items: center;
    justify-content: center;
    padding: 24px 12px;
    overflow-y: auto;
  }
  #kz-modal-overlay.open { display: flex; }

  /* rimosso: ora gestito nel blocco responsive principale sotto */

  /* ── MODAL ── */
  #kz-modal-overlay { cursor: none; }
  .kz-modal { cursor: auto; }

  .kz-modal {
    background: #111;
    border: 0px solid #000;
    border-radius: 16px;
    width: 100%;
    max-width: var(--kz-modal-max-width);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    position: relative;
    margin: auto;
    font-family: 'Inter', sans-serif;
  }
  .kz-modal-inner {
    display: flex;
    flex-direction: row;
    min-height: var(--kz-modal-min-height);
  }

  /* ── CLOSE — assoluto dentro kz-modal-left ── */
  .kz-modal-close {
    position: absolute;
    top: 14px;
    right: 12px;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.6);
    border: 1.5px solid rgba(255,255,255,0.25);
    border-radius: 50%;
    color: transparent;
    cursor: pointer;
    font-size: 0;
    line-height: 1;
    z-index: 11;
    transition: background .25s ease, border-color .25s ease, transform .25s ease, box-shadow .25s ease;
  }
  .kz-modal-close::before,
  .kz-modal-close::after {
    content: '';
    position: absolute;
    width: 13px;
    height: 1.5px;
    background: #fff;
    border-radius: 1px;
    top: 50%;
    left: 50%;
    transform-origin: center center;
  }
  .kz-modal-close::before { transform: translate(-50%, -50%) rotate(45deg); }
  .kz-modal-close::after  { transform: translate(-50%, -50%) rotate(-45deg); }
  .kz-modal-close:hover {
    background: #E8272A;
    border-color: #E8272A;
    transform: scale(1.12) rotate(90deg);
    box-shadow: 0 0 14px rgba(232,39,42,0.6);
  }
  .kz-modal-close:active {
    transform: scale(0.95) rotate(90deg);
    box-shadow: 0 0 6px rgba(232,39,42,0.4);
  }

  /* ── CURSORE X — segue il mouse sull'overlay fuori dal popup ── */
  #kz-modal-cursor-x {
    position: fixed;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(0,0,0,0.6);
    border: 1.5px solid rgba(255,255,255,0.25);
    pointer-events: none;
    z-index: 1000001;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5) rotate(0deg);
    transition: opacity .18s ease, transform .25s ease, background .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  #kz-modal-cursor-x::before,
  #kz-modal-cursor-x::after {
    content: '';
    position: absolute;
    width: 13px;
    height: 1.5px;
    background: #fff;
    border-radius: 1px;
    top: 50%;
    left: 50%;
  }
  #kz-modal-cursor-x::before { transform: translate(-50%, -50%) rotate(45deg); }
  #kz-modal-cursor-x::after  { transform: translate(-50%, -50%) rotate(-45deg); }
  #kz-modal-cursor-x.show {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.12) rotate(90deg);
    background: #E8272A;
    border-color: #E8272A;
    box-shadow: 0 0 14px rgba(232,39,42,0.6);
  }

  /* ── LEFT ── */
  .kz-modal-left {
    width: 52%;
    background: #0d0d0d;
    display: flex;
    flex-direction: column;
    position: relative;
    flex-shrink: 0;
  }

  .kz-modal-badge-new {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #E8272A;
    color: #fff;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: .12em;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    z-index: 2;
  }
  .kz-modal-img-wrap {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0d0d0d;
    overflow: hidden;
    border: var(--kz-modal-img-border);
    box-sizing: border-box;
    position: relative;
    cursor: pointer;
  }
  /* gradient scuro in cima per leggibilità di barra e X */
  .kz-modal-img-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, transparent 38%);
    z-index: 2;
    pointer-events: none;
  }
  .kz-modal-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--kz-modal-slide-speed) ease;
    pointer-events: none;
  }
  .kz-modal-img-wrap img.kz-fade { opacity: 0; }

  /* Zone tap stile stories (sx = indietro, dx = avanti) */
  .kz-modal-tap-zone {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 30%;
    z-index: 3;
  }
  .kz-modal-tap-zone.right { right: 0; }
  .kz-modal-tap-zone.left { left: 0; }

  /* ── PROGRESS BAR — sopra l'immagine, dentro kz-modal-left ── */
  .kz-modal-progress {
    position: absolute;
    top: 14px;
    left: 12px;
    right: 52px;
    height: 28px;
    display: flex;
    align-items: center;
    gap: 4px;
    z-index: 10;
    pointer-events: none;
  }
  .kz-modal-progress-seg {
    flex: 1;
    height: 3px;
    background: rgba(255,255,255,0.28);
    border-radius: 2px;
    overflow: hidden;
  }
  .kz-modal-progress-fill {
    height: 100%;
    width: 0%;
    background: #E8272A;
    border-radius: 2px;
  }
  @keyframes kz-progress-grow {
    from { width: 0%; }
    to   { width: 100%; }
  }
  .kz-modal-thumbs {
    display: flex;
    gap: 6px;
    padding: 10px 12px;
    border-top: 1px solid rgba(255,255,255,0.06);
    flex-wrap: wrap;
    align-items: center;
  }
  .kz-modal-thumb {
    width: 44px;
    height: 44px;
    background: #1a1a1a;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
    cursor: pointer;
    overflow: hidden;
    flex-shrink: 0;
    transition: border-color .15s;
  }
  .kz-modal-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .kz-modal-thumb.active { border-color: #E8272A; }
  .kz-modal-urgency {
    background: #1a0a0a;
    border-top: 1px solid rgba(232,39,42,0.2);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .kz-modal-urgency-dot {
    width: 7px;
    height: 7px;
    background: #E8272A;
    border-radius: 50%;
    flex-shrink: 0;
    animation: kz-pulse 1.5s infinite;
  }
  @keyframes kz-pulse {
    0%,100% { opacity: 1; }
    50% { opacity: .4; }
  }
  .kz-modal-urgency-text {
    font-size: 11px;
    color: #F2F0EB;
    font-weight: 600;
    letter-spacing: .04em;
  }
  .kz-modal-urgency-text #kz-modal-viewers {
    color: #FF4548;
    font-weight: 800;
    letter-spacing: .04em;
  }

  /* ── RIGHT ── */
  .kz-modal-right {
    width: 48%;
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow-y: visible;
    border-left: 1px solid rgba(255,255,255,0.06);
  }
  .kz-modal-category {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .14em;
    color: #888880;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .kz-modal-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 900;
    color: #F2F0EB;
    text-transform: uppercase;
    line-height: 1.05;
    margin-bottom: 10px;
  }
  .kz-modal-price-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 4px;
    flex-wrap: wrap;
  }
  .kz-modal-price {
    font-size: 26px;
    font-weight: 800;
    color: #F2F0EB;
    font-family: 'Barlow Condensed', sans-serif;
  }
  .kz-modal-price-old {
    font-size: 14px;
    color: #555;
    text-decoration: line-through;
  }
  .kz-modal-price-save {
    font-size: 11px;
    font-weight: 800;
    color: #fff;
    background: #E8272A;
    padding: 3px 8px;
    border-radius: 3px;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  .kz-modal-divider {
    height: 1px;
    background: rgba(255,255,255,0.06);
    margin: 12px 0;
  }
  .kz-modal-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    color: #888880;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  /* ── VARIANTI ── */
  .kz-modal-variants {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .kz-modal-var-btn {
    min-width: 48px;
    height: 48px;
    padding: 0 16px;
    background: transparent;
    border: 1px solid rgba(242,240,235,0.25);
    border-radius: 1px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .04em;
    cursor: pointer;
    transition: background .15s, border-color .15s, transform .1s;
  }
  .kz-modal-var-btn:hover:not(.unavailable):not(.active) { border-color: rgba(242,240,235,0.6); transform: translateY(-1px); }
  .kz-modal-var-btn.active { background: #E8272A; border-color: #E8272A; color: #fff; box-shadow: 0 0 14px rgba(232,39,42,.35); }
  .kz-modal-var-btn.active:hover { background: #c41f22; }
  .kz-modal-var-btn.unavailable { opacity: .35; text-decoration: line-through; cursor: not-allowed; }

  /* Pallini colore — identici a .kzpr-swatch della pagina prodotto */
  .kz-modal-swatches { gap: 10px; }
  .kz-modal-swatch {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid rgba(242,240,235,0.2);
    cursor: pointer;
    position: relative;
    padding: 0;
    background-size: cover;
    background-position: center;
    transition: border-color .15s, transform .1s;
  }
  .kz-modal-swatch:hover:not(.unavailable) { transform: translateY(-1px); }
  .kz-modal-swatch.active { border-color: #E8272A; }
  .kz-modal-swatch.unavailable { opacity: .25; cursor: not-allowed; }

  /* ── STOCK ── */
  .kz-modal-stock-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 5px;
  }
  .kz-modal-stock-label {
    font-size: 9px;
    color: #E8272A;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .kz-modal-stock-num { font-size: 9px; color: #888880; }
  .kz-modal-stock-bar {
    height: 3px;
    background: rgba(255,255,255,0.08);
    margin-bottom: 14px;
    border-radius: 99px;
    overflow: hidden;
  }
  .kz-modal-stock-fill { height: 3px; background: #E8272A; transition: width .4s; border-radius: 99px; }

  /* ── BUY ROW: identica alla pagina prodotto (qty pill + CTA) ── */
  .kz-modal-buy-row {
    display: flex;
    gap: 10px;
    margin-bottom: 8px;
  }
  .kz-modal-qty {
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    background: #161616;
    overflow: hidden;
    height: 52px;
    flex-shrink: 0;
  }
  .kz-modal-qty button {
    width: 44px;
    height: 100%;
    background: transparent;
    border: none;
    color: #a5a59d;
    font-size: 18px;
    font-weight: 300;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background .15s, color .15s;
  }
  .kz-modal-qty button:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .kz-modal-qty button:active { background: rgba(232,39,42,0.85); color: #fff; }
  .kz-modal-qty input {
    width: 42px;
    height: 100%;
    background: transparent;
    border: none;
    color: #F2F0EB;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 0;
    margin: 0;
    box-sizing: border-box;
    -moz-appearance: textfield;
    appearance: textfield;
  }
  .kz-modal-qty input::-webkit-outer-spin-button,
  .kz-modal-qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .kz-modal-cta {
    flex: 1;
    height: 52px;
    background: #E8272A;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .kz-modal-cta:hover {
    background: #c41f22;
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(232, 39, 42, .35);
  }
  .kz-modal-cta:active { transform: translateY(0) scale(.98); box-shadow: none; }
  .kz-modal-cta:disabled { background: #3a3a36; cursor: not-allowed; transform: none; box-shadow: none; }
  .kz-modal-cta-secondary {
    width: 100%;
    background: transparent;
    border: 1px solid rgba(242,240,235,0.35);
    border-radius: 8px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 14px;
    cursor: pointer;
    margin-bottom: 14px;
    transition: border-color .2s ease, color .2s ease, transform .2s ease, background .2s ease;
    text-decoration: none;
    display: block;
    text-align: center;
  }
  .kz-modal-cta-secondary:hover { border-color: #F2F0EB; transform: translateY(-2px); background: rgba(255,255,255,.04); }
  .kz-modal-cta-secondary:active { transform: translateY(0) scale(.99); }

  /* ── TRUST ── */
  .kz-modal-trust {
    display: flex;
    justify-content: space-between;
    margin-bottom: 14px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .kz-modal-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    flex: 1;
    min-width: 56px;
  }
  .kz-modal-trust-icon { font-size: 16px; color: #888880; }
  .kz-modal-trust-icon svg { width: 16px; height: 16px; color: #E8272A; display: block; }
  .kz-modal-delivery {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 10.5px;
    color: #888880;
    letter-spacing: .03em;
    margin: -4px 0 12px;
  }
  .kz-modal-delivery svg { width: 14px; height: 14px; color: #4cbb7a; flex-shrink: 0; }
  .kz-modal-delivery strong { color: #F2F0EB; font-weight: 600; }
  .kz-modal-trust-item span {
    font-size: 8px;
    color: #888880;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-align: center;
    line-height: 1.3;
  }

  /* ── MINI-POPUP "AGGIUNTO AL CARRELLO" ── */
  #kz-modal-added {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease;
    z-index: 30;
  }
  #kz-modal-added.show { opacity: 1; pointer-events: auto; }
  .kz-modal-added-card {
    background: #161616;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 26px 26px 22px;
    width: min(320px, calc(100% - 48px));
    text-align: center;
    box-shadow: 0 22px 60px rgba(0,0,0,.6);
    transform: translateY(10px) scale(.96);
    transition: transform .25s cubic-bezier(.2,.6,.2,1);
  }
  #kz-modal-added.show .kz-modal-added-card { transform: translateY(0) scale(1); }
  .kz-modal-added-check {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(76,187,122,0.12);
    border: 1.5px solid #4cbb7a;
    color: #4cbb7a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }
  .kz-modal-added-check svg { width: 22px; height: 22px; }
  .kz-modal-added-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    color: #F2F0EB;
    margin-bottom: 16px;
  }
  .kz-modal-added-cart {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: 46px;
    background: #E8272A;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    margin-bottom: 8px;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .kz-modal-added-cart:hover { background: #c41f22; transform: translateY(-2px); box-shadow: 0 8px 22px rgba(232,39,42,.35); }
  .kz-modal-added-cart:active { transform: translateY(0) scale(.98); box-shadow: none; }
  .kz-modal-added-continue {
    width: 100%;
    height: 42px;
    background: transparent;
    border: 1px solid rgba(242,240,235,0.35);
    border-radius: 8px;
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color .2s ease, transform .2s ease, background .2s ease;
  }
  .kz-modal-added-continue:hover { border-color: #F2F0EB; transform: translateY(-2px); background: rgba(255,255,255,.04); }

  /* ── TOAST ── */
  #kz-modal-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: #1a1a1a;
    border: 1px solid rgba(232,39,42,0.4);
    color: #F2F0EB;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    padding: 12px 20px;
    border-radius: 10px;
    z-index: 9999;
    transform: translateY(80px);
    opacity: 0;
    transition: all .3s;
    pointer-events: none;
  }
  #kz-modal-toast.show { transform: translateY(0); opacity: 1; }

  /* ── RESPONSIVE MOBILE ── */
  @media (max-width: 600px) {
    /* Overlay: bottom sheet con overlay visibile sopra */
    #kz-modal-overlay {
      padding: 0;
      align-items: flex-end;
      justify-content: center;
    }

    /* Modal: bottom sheet con angoli arrotondati in alto */
    .kz-modal {
      width: 100%;
      max-width: 100%;
      min-height: unset;
      max-height: 92dvh;
      border-radius: 18px 18px 0 0;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .kz-modal-inner { flex-direction: column; }
    .kz-modal-left, .kz-modal-right { width: 100%; }
    .kz-modal-img-wrap { aspect-ratio: 4/3; }
    .kz-modal-right { max-height: none; padding: 16px 16px 24px; }
    .kz-modal-close { top: 10px; right: 10px; width: 28px; height: 28px; }
    .kz-modal-progress { top: 10px; right: 48px; }
  }
</style>

<!-- OVERLAY -->
<div id="kz-modal-overlay" role="dialog" aria-modal="true" aria-label="Dettaglio prodotto">
  <div id="kz-modal-cursor-x" aria-hidden="true"></div>
  <div class="kz-modal">

    <div class="kz-modal-inner">
      <!-- LEFT: immagini -->
      <div class="kz-modal-left">
        <div class="kz-modal-badge-new" id="kz-modal-badge" style="display:none">Nuovo</div>
        <!-- progress e close sono figli diretti di kz-modal-left (position:relative) -->
        <!-- così float sopra l'immagine senza essere clippati da overflow:hidden -->
        <div class="kz-modal-progress" id="kz-modal-progress"></div>
        <button class="kz-modal-close" id="kz-modal-close" aria-label="Chiudi"></button>
        <div class="kz-modal-img-wrap" id="kz-modal-img-wrap">
          <img id="kz-modal-main-img" src="" alt="" loading="lazy">
          <div class="kz-modal-tap-zone left" data-kz-tap="prev" aria-hidden="true"></div>
          <div class="kz-modal-tap-zone right" data-kz-tap="next" aria-hidden="true"></div>
        </div>
        <div class="kz-modal-thumbs" id="kz-modal-thumbs"></div>
        <div class="kz-modal-urgency">
          <div class="kz-modal-urgency-dot"></div>
          <div class="kz-modal-urgency-text" id="kz-modal-urgency-text">
            <span id="kz-modal-viewers">12 persone</span> stanno guardando questo prodotto
          </div>
        </div>
      </div>

      <!-- RIGHT: info + acquisto -->
      <div class="kz-modal-right">
        <div class="kz-modal-category" id="kz-modal-category"></div>
        <div class="kz-modal-title" id="kz-modal-title"></div>

        <div class="kz-modal-price-row">
          <span class="kz-modal-price" id="kz-modal-price"></span>
          <span class="kz-modal-price-old" id="kz-modal-price-old" style="display:none"></span>
          <span class="kz-modal-price-save" id="kz-modal-price-save" style="display:none"></span>
        </div>

        <div class="kz-modal-divider"></div>

        <!-- Varianti (gruppi generati dal JS: taglie a bottone, colori a pallino) -->
        <div id="kz-modal-variants-wrap" style="display:none"></div>

        <!-- Stock bar -->
        <div id="kz-modal-stock-wrap" style="display:none">
          <div class="kz-modal-stock-meta">
            <span class="kz-modal-stock-label">⚠ Quasi esaurito</span>
            <span class="kz-modal-stock-num" id="kz-modal-stock-num"></span>
          </div>
          <div class="kz-modal-stock-bar">
            <div class="kz-modal-stock-fill" id="kz-modal-stock-fill"></div>
          </div>
        </div>

        <!-- CTA: quantita + aggiungi (come pagina prodotto) -->
        <div class="kz-modal-buy-row">
          <div class="kz-modal-qty">
            <button type="button" id="kz-modal-qty-minus" aria-label="Diminuisci quantit&#224;">&minus;</button>
            <input type="number" id="kz-modal-qty-input" value="1" min="1" aria-label="Quantit&#224;">
            <button type="button" id="kz-modal-qty-plus" aria-label="Aumenta quantit&#224;">+</button>
          </div>
          <button class="kz-modal-cta" id="kz-modal-add-btn">
            Aggiungi al carrello
          </button>
        </div>
        <a class="kz-modal-cta-secondary" id="kz-modal-product-link" href="#">
          Vedi pagina prodotto completa
        </a>

        {%- comment -%} Stima consegna dinamica: oggi +14 / +18 giorni {%- endcomment -%}
        {%- liquid
          assign kzm_months = 'gen,feb,mar,apr,mag,giu,lug,ago,set,ott,nov,dic' | split: ','
          assign kzm_a = 'now' | date: '%s' | plus: 1209600
          assign kzm_b = 'now' | date: '%s' | plus: 1555200
          assign kzm_am = kzm_a | date: '%m' | plus: 0 | minus: 1
          assign kzm_bm = kzm_b | date: '%m' | plus: 0 | minus: 1
        -%}
        <div class="kz-modal-delivery">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
          Consegna stimata: <strong>{{ kzm_a | date: '%-d' }} {{ kzm_months[kzm_am] }} – {{ kzm_b | date: '%-d' }} {{ kzm_months[kzm_bm] }}</strong>
        </div>

        <!-- Trust badges -->
        {%- comment -%} Promo lancio: stessa data del countdown banner {%- endcomment -%}
        {%- assign kzm_promo_end = '2026-07-30T23:59:59' -%}
        {%- assign kzm_now_s = 'now' | date: '%s' | plus: 0 -%}
        {%- assign kzm_end_s = kzm_promo_end | date: '%s' | plus: 0 -%}
        <div class="kz-modal-trust">
          <div class="kz-modal-trust-item">
            <span class="kz-modal-trust-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg></span>
            <span>{% if kzm_now_s < kzm_end_s %}Spedizione gratuita su tutto{% else %}Spedizione gratuita sopra €60{% endif %}</span>
          </div>
          <div class="kz-modal-trust-item">
            <span class="kz-modal-trust-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg></span>
            <span>Reso gratuito 30 giorni</span>
          </div>
          <div class="kz-modal-trust-item">
            <span class="kz-modal-trust-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg></span>
            <span>Pagamento sicuro</span>
          </div>
          <div class="kz-modal-trust-item">
            <span class="kz-modal-trust-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg></span>
            <span>Ordina entro 2h per oggi</span>
          </div>
        </div>
      </div>
    </div>

    <!-- MINI-POPUP: scelta dopo l'aggiunta -->
    <div id="kz-modal-added" aria-hidden="true">
      <div class="kz-modal-added-card">
        <div class="kz-modal-added-check">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
        </div>
        <div class="kz-modal-added-title">Aggiunto al carrello!</div>
        <a class="kz-modal-added-cart" href="/cart">
          Vai al carrello
        </a>
        <button type="button" class="kz-modal-added-continue" id="kz-modal-added-continue">Continua lo shopping</button>
      </div>
    </div>
  </div>
</div>

<!-- TOAST notifica -->
<div id="kz-modal-toast">✓ Prodotto aggiunto al carrello</div>

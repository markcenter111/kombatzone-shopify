<style>
  .kz-payment-badges {
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.07);
    text-align: center;
  }
  .kz-payment-label {
    display: block;
    font-family: var(--kz-ff-body, 'Inter', sans-serif);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--kz-text-dim, #888880);
    margin-bottom: 10px;
  }
  .kz-payment-icons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
  }
  .kz-payment-icons .kz-pay-badge {
    width: {{ section.settings.payment_badge_size | default: 52 }}px;
    height: {{ section.settings.payment_badge_size | default: 52 | times: 2 | divided_by: 3 }}px;
    border-radius: 5px;
    opacity: 0.88;
    transition: opacity .15s, transform .15s;
    box-shadow: 0 1px 4px rgba(0,0,0,.3);
    flex-shrink: 0;
  }
  .kz-payment-icons .kz-pay-badge:hover {
    opacity: 1;
    transform: translateY(-1px);
  }
</style>

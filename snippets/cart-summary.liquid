{%- comment -%}
  snippets/cart-summary.liquid
  ----------------------------------------------------------------------
  Sidebar di riepilogo: coupon, subtotale, sconti, spedizione, omaggio,
  IVA, totale, pulsanti checkout/PayPal, trust badge.

  Parametri attesi (passati dalla section main-cart):
    - free_shipping_threshold : prezzo soglia spedizione gratuita (in valuta shop, non cent)
    - trust_badges            : array di oggetti {icon, text} (dai blocks della section)
{%- endcomment -%}

{%- assign has_free_gift = false -%}
{%- assign free_gift_name = '' -%}
{%- for item in cart.items -%}
  {%- if item.product.tags contains 'omaggio-automatico' -%}
    {%- assign has_free_gift = true -%}
    {%- assign free_gift_name = item.product.title -%}
  {%- endif -%}
{%- endfor -%}

{%- assign total_discount = cart.original_total_price | minus: cart.total_price -%}
{%- assign free_shipping_threshold_cents = free_shipping_threshold | times: 100 -%}
{%- assign qualifies_free_shipping = false -%}
{%- if cart.original_total_price >= free_shipping_threshold_cents -%}
  {%- assign qualifies_free_shipping = true -%}
{%- endif -%}
{%- if promo_active -%}
  {%- assign qualifies_free_shipping = true -%}
{%- endif -%}

<div class="kz-sidebar" data-cart-summary>

  {%- comment -%}
    Il carrello Shopify non applica codici sconto via AJAX: il flusso standard
    è reindirizzare a /discount/CODICE?redirect=/checkout (il codice va nel
    PATH dell'URL, non come query string — per questo l'invio del form è
    gestito via JS in sections/main-cart.liquid, non come submit nativo).
  {%- endcomment -%}
  <form class="kz-coupon-wrap" data-coupon-form>
    <input
      class="kz-coupon-input"
      type="text"
      name="code"
      placeholder="Codice sconto"
      autocomplete="off"
      data-coupon-input
    />
    <button type="submit" class="kz-coupon-btn" data-coupon-submit>Applica</button>
  </form>
  <div class="kz-coupon-msg" data-coupon-msg></div>

  {%- capture kz_coupon_tags -%}
    {%- for application in cart.discount_applications -%}
      {%- if application.type == 'discount_code' -%}
        <div class="kz-coupon-tag">
          <span class="kz-coupon-tag-code">{{ application.title }}</span>
          <button type="button" class="kz-coupon-tag-x" data-coupon-remove aria-label="Rimuovi codice sconto {{ application.title | escape }}">&times;</button>
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}
  {%- if kz_coupon_tags contains 'kz-coupon-tag' -%}
    <div class="kz-coupon-tags">{{ kz_coupon_tags }}</div>
  {%- endif -%}

  <div class="kz-summary-row">
    <span class="kz-summary-label">Subtotale ({{ cart.item_count }} articol{% if cart.item_count == 1 %}o{% else %}i{% endif %})</span>
    <span class="kz-summary-val">{{ cart.original_total_price | money }}</span>
  </div>

  {%- if total_discount > 0 -%}
    <div class="kz-summary-row">
      <span class="kz-summary-label">Sconti applicati</span>
      <span class="kz-summary-val green">−{{ total_discount | money }}</span>
    </div>
  {%- endif -%}

  <div class="kz-summary-row">
    <span class="kz-summary-label">Spedizione</span>
    {%- if qualifies_free_shipping -%}
      <span class="kz-summary-val green">Gratuita</span>
    {%- else -%}
      <span class="kz-summary-val">Calcolata al checkout</span>
    {%- endif -%}
  </div>

  {%- if has_free_gift -%}
    <div class="kz-summary-row">
      <span class="kz-summary-label">Omaggio</span>
      <span class="kz-summary-val" style="color:#C9992A;">{{ free_gift_name }} inclusa</span>
    </div>
  {%- endif -%}

  {%- if total_discount > 0 or qualifies_free_shipping -%}
    <div class="kz-summary-hype">
      {%- if total_discount > 0 -%}
        <i class="ti ti-flame" aria-hidden="true"></i>
        <span>Stai risparmiando <strong>{{ total_discount | money }}</strong> su quest'ordine</span>
      {%- elsif qualifies_free_shipping -%}
        <i class="ti ti-circle-check" aria-hidden="true"></i>
        <span>Spedizione gratuita inclusa in questo ordine</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="kz-summary-total">
    <div class="kz-total-label">Totale</div>
    <div class="kz-total-val">{{ cart.total_price | money }}</div>
  </div>

  {%- form 'cart', cart, id: 'kz-cart-form' -%}
    <a href="/checkout" class="kz-checkout-btn">
      <i class="ti ti-lock" aria-hidden="true"></i>
      Procedi al checkout
    </a>

    {%- comment -%}
      Pulsanti di checkout dinamici nativi Shopify (PayPal, Shop Pay, ecc.),
      mostrati automaticamente in base ai payment provider attivi sullo shop.
    {%- endcomment -%}
    {%- if additional_checkout_buttons -%}
      <div class="kz-paypal-btn-wrap">
        {{ content_for_additional_checkout_buttons }}
      </div>
    {%- endif -%}
  {%- endform -%}

  {%- liquid
    assign months_it = 'gen,feb,mar,apr,mag,giu,lug,ago,set,ott,nov,dic' | split: ','
    assign eta_start_s = 'now' | date: '%s' | plus: 1209600
    assign eta_end_s = 'now' | date: '%s' | plus: 1555200
    assign eta_start_m = eta_start_s | date: '%m' | plus: 0 | minus: 1
    assign eta_end_m = eta_end_s | date: '%m' | plus: 0 | minus: 1
  -%}
  <div class="kz-delivery-estimate">
    <i class="ti ti-truck-delivery" aria-hidden="true"></i>
    <span>Consegna stimata: <strong>{{ eta_start_s | date: '%-d' }} {{ months_it[eta_start_m] }} – {{ eta_end_s | date: '%-d' }} {{ months_it[eta_end_m] }}</strong></span>
  </div>

  <div class="kz-trust-mini">
    {%- if trust_badges and trust_badges.size > 0 -%}
      {%- for badge in trust_badges -%}
        <div class="kz-trust-mini-item">
          <i class="ti ti-{{ badge.icon }}" aria-hidden="true"></i>
          {{ badge.text }}
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="kz-trust-mini-item"><i class="ti ti-shield-check" aria-hidden="true"></i> Pagamento sicuro SSL</div>
      <div class="kz-trust-mini-item"><i class="ti ti-truck" aria-hidden="true"></i> Spedizione in 48–72h dall'Italia</div>
      <div class="kz-trust-mini-item"><i class="ti ti-refresh" aria-hidden="true"></i> Reso gratuito entro 30 giorni</div>
      <div class="kz-trust-mini-item"><i class="ti ti-pencil" aria-hidden="true"></i> Personalizzazione inclusa</div>
    {%- endif -%}
  </div>

  <!-- Badge metodi di pagamento — icone ufficiali Shopify (sempre corrette e aggiornate) -->
  <div class="kz-payment-badges">
    <span class="kz-payment-label">Pagamenti accettati</span>
    <div class="kz-payment-icons">
      {%- for type in shop.enabled_payment_types -%}
        {%- unless forloop.index == 3 -%}
          {{ type | payment_type_svg_tag: class: 'kz-pay-badge' }}
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>

</div>
</div>

<style>
  .kz-payment-badges {
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.07);
    text-align: center;
  }
  .kz-payment-label {
    display: block;
    font-family: var(--kz-ff-body, 'Inter', sans-serif);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--kz-text-dim, #888880);
    margin-bottom: 10px;
  }
  .kz-payment-icons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
  }
  .kz-payment-icons .kz-pay-badge {
    width: {{ section.settings.payment_badge_size | default: 52 }}px;
    height: auto;
    border-radius: 5px;
    opacity: 0.88;
    transition: opacity .15s, transform .15s;
    box-shadow: 0 1px 4px rgba(0,0,0,.3);
    flex-shrink: 0;
  }
  .kz-payment-icons .kz-pay-badge:hover {
    opacity: 1;
    transform: translateY(-1px);
  }
</style>

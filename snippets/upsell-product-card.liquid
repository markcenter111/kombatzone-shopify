{%- comment -%}
  snippets/upsell-product-card.liquid
  ----------------------------------------------------------------------
  Card upsell carrello — struttura identica a snippets/kz2-product-card.liquid.
  L'unica differenza: il FAB usa data-kz-modal (come la collection) per
  aprire il modale di selezione variante già presente nel tema.
{%- endcomment -%}

{%- liquid
  assign has_discount = false
  if product.compare_at_price > product.price
    assign has_discount = true
    assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round
  endif

  assign badge_text    = ''
  assign badge_color   = ''
  assign is_bestseller = false

  if product.tags contains 'bestseller'
    assign badge_text    = 'BESTSELLER'
    assign badge_color   = '#E8272A'
    assign is_bestseller = true
  elsif product.tags contains 'novità'
    assign badge_text  = 'NOVITÀ'
    assign badge_color = '#2196F3'
  elsif product.tags contains 'pro'
    assign badge_text  = 'PRO'
    assign badge_color = '#8B5CF6'
  elsif product.tags contains 'top-rated'
    assign badge_text  = 'TOP RATED'
    assign badge_color = '#F59E0B'
  elsif has_discount
    assign badge_text  = '-' | append: discount_pct | append: '%'
    assign badge_color = '#E8272A'
  endif

  assign discipline_label = ''
  if product.tags contains 'mma'
    assign discipline_label = 'MMA'
  elsif product.tags contains 'boxe'
    assign discipline_label = 'Boxe'
  elsif product.tags contains 'muay-thai'
    assign discipline_label = 'Muay Thai'
  elsif product.tags contains 'kick-boxing'
    assign discipline_label = 'Kick Boxing'
  endif

  assign level_label = ''
  if product.tags contains 'principiante'
    assign level_label = 'Principiante'
  elsif product.tags contains 'intermedio'
    assign level_label = 'Intermedio'
  elsif product.tags contains 'agonista'
    assign level_label = 'Agonista'
  endif

  assign low_stock = false
  if product.tags contains 'scorta-bassa'
    assign low_stock = true
  endif

  assign show_name_badge = false
  if product.tags contains 'nome-gratis'
    assign show_name_badge = true
  endif

  assign first_variant = product.variants.first
-%}

<div class="kz-card kz-also-card{% if is_bestseller %} kz-card--hero{% endif %}" data-also-card>

  {%- comment -%} ── Immagine ── {%- endcomment -%}
  <a href="{{ product.url }}"
     class="kz-card__image-wrap"
     aria-label="{{ product.title | escape }}">

    {%- if is_bestseller -%}
      <div class="kz-card__bestseller-label" aria-label="Più venduto">PIÙ VENDUTO</div>
    {%- endif -%}

    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        class="kz-card__image"
        width="600"
        height="600"
        loading="lazy">
    {%- else -%}
      <div class="kz-card__image-placeholder" aria-hidden="true">🥊</div>
    {%- endif -%}

    <div class="kz-card__image-overlay" aria-hidden="true"></div>

    {%- if badge_text != '' and is_bestseller == false -%}
      <div class="kz-card__badge" style="background:{{ badge_color }}">
        {{- badge_text -}}
      </div>
    {%- elsif has_discount and is_bestseller -%}
      <div class="kz-card__badge" style="background:{{ badge_color }}; top:28px;">
        -{{ discount_pct }}%
      </div>
    {%- endif -%}

    {%- if low_stock -%}
      <div class="kz-card__stock-badge">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
        </svg>
        Solo pochi rimasti
      </div>
    {%- endif -%}

    <button
      type="button"
      class="kz-card__cart-fab"
      data-kz-modal="{{ product.handle }}"
      aria-label="Aggiungi {{ product.title | escape }} al carrello"
      {%- unless product.available %} disabled aria-disabled="true"{%- endunless %}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M2.25 2.25a.75.75 0 0 0 0 1.5h1.386c.17 0 .318.114.362.278l2.558 9.592a3.752 3.752 0 0 0-2.806 3.63c0 .414.336.75.75.75h15.75a.75.75 0 0 0 0-1.5H5.378A2.25 2.25 0 0 1 7.5 15h11.218a.75.75 0 0 0 .674-.421 60.358 60.358 0 0 0 2.96-7.228.75.75 0 0 0-.525-.965A60.864 60.864 0 0 0 5.68 4.509l-.232-.867A1.875 1.875 0 0 0 3.636 2.25H2.25ZM3.75 20.25a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0ZM16.5 20.25a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Z"/>
      </svg>
    </button>

  </a>

  {%- comment -%} ── Body testo ── {%- endcomment -%}
  <div class="kz-card__body">

    {%- if discipline_label != '' or level_label != '' -%}
      <div class="kz-card__discipline">
        {%- if discipline_label != '' and level_label != '' -%}
          {{ discipline_label }} · {{ level_label }}
        {%- elsif discipline_label != '' -%}
          {{ discipline_label }}
        {%- else -%}
          {{ level_label }}
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="kz-card__type">{{ product.type | upcase }}</div>
    {%- endif -%}

    <a href="{{ product.url }}" class="kz-card__title">
      {{- product.title -}}
    </a>

    {%- if show_name_badge -%}
      <div class="kz-card__name-badge" aria-label="Nome personalizzato gratis incluso">
        Nome gratis incluso
      </div>
    {%- endif -%}

    <div class="kz-card__price">
      <span class="kz-card__price-current">{{ product.price | money }}</span>
      {%- if has_discount -%}
        <span class="kz-card__price-old">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    {%- assign contenuto = product.metafields.kzone.contenuto.value -%}
    {%- if contenuto != blank -%}
      <div class="kz-card__contenuto">
        {%- assign pezzi = contenuto | split: ', ' -%}
        {%- for pezzo in pezzi -%}
          <span class="kz-card__pezzo">{{ pezzo }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <button
      type="button"
      class="kz-card__atc"
      data-kz-modal="{{ product.handle }}"
      aria-hidden="true"
      tabindex="-1"
      {%- unless product.available %} disabled{%- endunless %}>
      {%- if product.available -%}+ Aggiungi al carrello{%- else -%}Esaurito{%- endif -%}
    </button>

  </div>
</div>

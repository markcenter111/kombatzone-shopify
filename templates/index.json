    "faq_z3XhaP": {
      "type": "faq",
      "blocks": {
        "faq_item_RHnbyY": {
          "type": "faq_item",
          "disabled": true,
          "settings": {
            "question": "Quanto tempo ci vuole per la personalizzazione?",
            "answer": "<p>La personalizzazione è inclusa in ogni ordine e non allunga i tempi di spedizione. Il tuo prodotto viene personalizzato e spedito entro 48 ore lavorative dall'ordine.</p>"
          }
        },
        "faq_item_wGHYhb": {
          "type": "faq_item",
          "settings": {
            "question": "Come scelgo la taglia giusta dei guantoni?",
            "answer": "<p>I guantoni da boxe si scelgono in base al peso corporeo e all'uso. Per allenamento generale: 10–12 oz sotto i 70 kg, 14–16 oz sopra. Contattaci e ti guidiamo nella scelta.</p>"
          }
        },
        "faq_item_b4dTeR": {
          "type": "faq_item",
          "settings": {
            "question": "Spedite in tutta Europa?",
            "answer": "<p>Sì, spediamo in tutta l'UE. I tempi sono 48–72 ore lavorative per l'Italia, 3–5 giorni per il resto d'Europa. La spedizione è gratuita sopra €60.</p>"
          }
        },
        "faq_item_ywKa6c": {
          "type": "faq_item",
          "settings": {
            "question": "Posso cambiare o restituire un prodotto personalizzato?",
            "answer": "<p>Accettiamo resi e cambi entro 30 giorni per problemi di taglia o difetti. I prodotti personalizzati con nome/numero non sono rimborsabili salvo difetti di produzione.</p>"
          }
        },
        "faq_item_VHyK3z": {
          "type": "faq_item",
          "disabled": true,
          "settings": {
            "question": "Quali metodi di pagamento accettate?",
            "answer": "<p>Accettiamo tutte le principali carte di credito e debito (Visa, Mastercard), PayPal, Apple Pay e Google Pay. Il pagamento è sempre protetto con crittografia SSL.</p>"
          }
        },
        "faq_item_neAXAi": {
          "type": "faq_item",
          "settings": {
            "question": "I prodotti sono adatti per uso professionale?",
            "answer": "<p>Sì, i nostri prodotti sono utilizzati da atleti professionisti e amatori. I materiali sono scelti per resistere a sessioni intensive. Molti nostri ambassador si allenano con il nostro gear ogni giorno.</p>"
          }
        }
      },

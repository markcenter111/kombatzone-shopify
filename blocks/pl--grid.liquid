{% stylesheet %}
  .--pl--grid {
    display: grid;
    align-items: var(--pl-column-align);
    grid-auto-flow: var(--pl-grid-auto-flow);
    grid-auto-columns: 1fr;
    gap: var(--pl-row-gap) var(--pl-column-gap);
    grid-template-columns: var(--pl-grid-template-columns);
    grid-template-rows: var(--pl-grid-template-rows);
    width: var(--pl-width);
    max-width: var(--pl-max-width);
    height: var(--pl-height);
    max-height: var(--pl-max-height);
    padding: var(--pl-padding-top) var(--pl-padding-right) var(--pl-padding-bottom)
      var(--pl-padding-left);
  }

  @media screen and (max-width: 768px) {
    .--pl--grid {
      align-items: var(--pl-column-align-mobile);
      grid-auto-flow: var(--pl-grid-auto-flow-mobile);
      grid-auto-columns: 1fr;
      gap: var(--pl-row-gap-mobile) var(--pl-column-gap-mobile);
      grid-template-columns: var(--pl-grid-template-columns-mobile);
      grid-template-rows: var(--pl-grid-template-rows-mobile);
      width: var(--pl-width-mobile);
      max-width: var(--pl-max-width-mobile);
      height: var(--pl-height-mobile);
      max-height: var(--pl-max-height-mobile);
      padding: var(--pl-padding-top-mobile) var(--pl-padding-right-mobile) var(--pl-padding-bottom-mobile)
        var(--pl-padding-left-mobile);
    }
  }
{% endstylesheet %}


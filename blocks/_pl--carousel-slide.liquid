  <div
    {{ block.shopify_attributes }}
    class="pl--carousel__slide__inner"
    style="
      {% if block.settings.use_bg_image and block.settings.bg_image != blank %}
        background-image:
          {% if block.settings.overlay_opacity > 0 %}
            linear-gradient(rgba(0,0,0,{{ block.settings.overlay_opacity | divided_by: 100.0 }}), rgba(0,0,0,{{ block.settings.overlay_opacity | divided_by: 100.0 }})),
          {% endif %}
          url('{{ block.settings.bg_image | image_url: width: block.settings.bg_image.width }}');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      {% endif %}
    "
  >
    {% if block.settings.is_link and request.design_mode == false %}
      <a
        href="{{ block.settings.link_url }}"
        {% if block.settings.target_blank %}
          target="_blank" rel="noopener noreferrer"
        {% endif %}
        class="pl--carousel__slide-link"
        aria-label=""
      ></a>
    {% endif %}
    {% content_for 'blocks' %}
  </div>

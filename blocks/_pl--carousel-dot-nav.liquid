{% stylesheet %}
  .pl--carousel__dots {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--pl-car-dot-nav-gap);
  }

  .pl--carousel__dot {
    -webkit-tap-highlight-color: rgba(49, 49, 49, 0.3);
    -webkit-appearance: none;
    appearance: none;
    text-decoration: none;
    display: flex;
    background-color: var(--pl-car-dot-nav-bg-color);
    touch-action: manipulation;
    text-decoration: none;
    cursor: pointer;
    padding: 0;
    margin: 0;
    width: var(--pl-car-dot-nav-width);
    height: var(--pl-car-dot-nav-height);
    border-radius: var(--pl-car-dot-nav-border-radius);
    border: var(--pl-car-dot-nav-border-width) var(--pl-car-dot-nav-border-style)
      var(--pl-car-dot-nav-border-color);
    transition: background-color var(--pl-car-dot-nav-transition-speed) ease,
      width var(--pl-car-dot-nav-transition-speed) ease,
      border-radius var(--pl-car-dot-nav-transition-speed) ease;
  }

  .pl--carousel__dot:hover {
    background-color: var(--pl-car-dot-nav-bg-color-hover);
  }

  .pl--carousel__dot--selected {
    background-color: var(--pl-car-dot-nav-bg-color-selected);
    width: var(--pl-car-dot-nav-active-width);
    border-radius: 15px;
  }

  .pl--carousel__dot--selected:hover {
    background-color: var(--pl-car-dot-nav-bg-color-selected);
  }

  @media screen and (max-width: 768px) {
    .pl--carousel__dots {
      gap: var(--pl-car-dot-nav-gap-mobile);
    }

    .pl--carousel__dot {
      background-color: var(--pl-car-dot-nav-bg-color-mobile);
      width: var(--pl-car-dot-nav-width-mobile);
      height: var(--pl-car-dot-nav-height-mobile);
      border-radius: var(--pl-car-dot-nav-border-radius-mobile);
      border: var(--pl-car-dot-nav-border-width-mobile) var(--pl-car-dot-nav-border-style-mobile)
        var(--pl-car-dot-nav-border-color-mobile);
      transition: background-color var(--pl-car-dot-nav-transition-speed-mobile) ease,
        width var(--pl-car-dot-nav-transition-speed-mobile) ease,
        border-radius var(--pl-car-dot-nav-transition-speed-mobile) ease;
    }

    .pl--carousel__dot:hover {
      background-color: var(--pl-car-dot-nav-bg-color-hover-mobile);
    }

    .pl--carousel__dot--selected {
      background-color: var(--pl-car-dot-nav-bg-color-selected-mobile);
      width: var(--pl-car-dot-nav-active-width-mobile);
    }

    .pl--carousel__dot--selected:hover {
      background-color: var(--pl-car-dot-nav-bg-color-selected-mobile);
    }
  }
{% endstylesheet %}

{% liquid
  assign dot_bg_color = block.settings.bg_color
  assign dot_bg_color_hover = dot_bg_color | color_darken: 5
  assign dot_bg_color_selected = block.settings.bg_color_active

  assign dot_bg_color_mobile = block.settings.bg_color_mobile
  assign dot_bg_color_hover_mobile = dot_bg_color_mobile | color_darken: 5
  assign dot_bg_color_selected_mobile = block.settings.bg_color_active_mobile
%}
<div
  {{ block.shopify_attributes }}
  data-embla-dot-nav
  class="pl--carousel__dots"
  style="
    --pl-car-dot-nav-width: {{ block.settings.custom_width }}{{ block.settings.custom_width_unit }};
    --pl-car-dot-nav-height: {{ block.settings.custom_height }}{{ block.settings.custom_height_unit }};
    --pl-car-dot-nav-gap: {{ block.settings.gap_horizontal }}{{ block.settings.gap_horizontal_unit }};
    --pl-car-dot-nav-bg-color: {{ dot_bg_color }};
    --pl-car-dot-nav-bg-color-hover: {{ dot_bg_color_hover }};
    --pl-car-dot-nav-bg-color-selected: {{ dot_bg_color_selected }};
    --pl-car-dot-nav-border-radius: {{ block.settings.border_radius}}{{ block.settings.border_radius_unit }};
    --pl-car-dot-nav-border-style: {{ block.settings.border_style }};
    --pl-car-dot-nav-border-width: {{ block.settings.border_width }}{{ block.settings.border_width_unit }};
    --pl-car-dot-nav-border-color: {{ block.settings.border_color }};
    {% render 'pl--css-var',
     variableName: 'pl-car-dot-nav-transition-speed',
     baseValue: block.settings.transition_speed,
     baseUnit: 'ms',
     overrideTrigger: 'custom',
     overrideValue: block.settings.transition_speed_custom,
     overrideUnit: 'ms',
     defaultValue: block.settings.transition_speed,
     defaultValueUnit: 'ms',
    -%}
    --pl-car-dot-nav-active-width: {% if block.settings.width_on_active == 'wide' %}calc(var(--pl-car-dot-nav-width) * 3){% else %}var(--pl-car-dot-nav-width){% endif %};

    --pl-car-dot-nav-width-mobile: {{ block.settings.custom_width_mobile }}{{ block.settings.custom_width_unit_mobile }};
    --pl-car-dot-nav-height-mobile: {{ block.settings.custom_height_mobile }}{{ block.settings.custom_height_unit_mobile }};
    --pl-car-dot-nav-gap-mobile: {{ block.settings.gap_horizontal_mobile }}{{ block.settings.gap_horizontal_unit_mobile }};
    --pl-car-dot-nav-bg-color-mobile: {{ dot_bg_color_mobile }};
    --pl-car-dot-nav-bg-color-hover-mobile: {{ dot_bg_color_hover_mobile }};
    --pl-car-dot-nav-bg-color-selected-mobile: {{ dot_bg_color_selected_mobile }};
    --pl-car-dot-nav-border-radius-mobile: {{ block.settings.border_radius_mobile}}{{ block.settings.border_radius_unit_mobile }};
    --pl-car-dot-nav-border-style-mobile: {{ block.settings.border_style_mobile }};
    --pl-car-dot-nav-border-width-mobile: {{ block.settings.border_width_mobile }}{{ block.settings.border_width_unit_mobile }};
    --pl-car-dot-nav-border-color-mobile: {{ block.settings.border_color_mobile }};
    {% render 'pl--css-var',
     variableName: 'pl-car-dot-nav-transition-speed-mobile',
     baseValue: block.settings.transition_speed_mobile,
     baseUnit: 'ms',
     overrideTrigger: 'custom',
     overrideValue: block.settings.transition_speed_custom_mobile,
     overrideUnit: 'ms',
     defaultValue: block.settings.transition_speed_mobile,
     defaultValueUnit: 'ms',
    -%}
    --pl-car-dot-nav-active-width-mobile: {% if block.settings.width_on_active_mobile == 'wide' %}calc(var(--pl-car-dot-nav-width-mobile) * 3){% else %}var(--pl-car-dot-nav-width-mobile){% endif %};
  "
></div>

